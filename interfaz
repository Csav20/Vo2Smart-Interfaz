// SIDEBAR DRAG & DROP REORDER
// ═══════════════════════════════════════════════════
let _dragItem=null;

function initSidebarDrag(){
  const nav=document.getElementById('sidebar-nav');
  if(!nav)return;
  nav.addEventListener('dragstart',e=>{
    const item=e.target.closest('.nav-item');
    if(!item)return;
    _dragItem=item;
    item.classList.add('dragging');
    e.dataTransfer.effectAllowed='move';
    e.dataTransfer.setData('text/plain',item.dataset.page);
  });
  nav.addEventListener('dragend',e=>{
    if(_dragItem)_dragItem.classList.remove('dragging');
    nav.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('drag-over'));
    _dragItem=null;
  });
  nav.addEventListener('dragover',e=>{
    e.preventDefault();
    e.dataTransfer.dropEffect='move';
    const target=e.target.closest('.nav-item');
    if(!target||target===_dragItem)return;
    nav.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('drag-over'));
    target.classList.add('drag-over');
  });
  nav.addEventListener('dragleave',e=>{
    const target=e.target.closest('.nav-item');
    if(target)target.classList.remove('drag-over');
  });
  nav.addEventListener('drop',e=>{
    e.preventDefault();
    const target=e.target.closest('.nav-item');
    if(!target||!_dragItem||target===_dragItem)return;
    target.classList.remove('drag-over');
    // Determine insert position: before or after target
    const rect=target.getBoundingClientRect();
    const midY=rect.top+rect.height/2;
    if(e.clientY<midY){
      target.parentNode.insertBefore(_dragItem,target);
    }else{
      target.parentNode.insertBefore(_dragItem,target.nextSibling);
    }
    saveSidebarOrder();
  });
  // Restore saved order
  restoreSidebarOrder();
}

function saveSidebarOrder(){
  const nav=document.getElementById('sidebar-nav');
  if(!nav)return;
  const order=[];
  nav.querySelectorAll('.nav-item').forEach(item=>{
    order.push(item.dataset.page);
  });
  localStorage.setItem('vo2smart_sidebar_order',JSON.stringify(order));
}

function restoreSidebarOrder(){
  const saved=localStorage.getItem('vo2smart_sidebar_order');
  if(!saved)return;
  try{
    const order=JSON.parse(saved);
    if(!Array.isArray(order)||!order.length)return;
    const nav=document.getElementById('sidebar-nav');
    if(!nav)return;
    // Collect all nav-items and labels
    const items={};
    nav.querySelectorAll('.nav-item').forEach(item=>{items[item.dataset.page]=item;});
    const labels=nav.querySelectorAll('.nav-label');
    // Remove all nav-labels (groups won't apply after reorder)
    labels.forEach(l=>l.remove());
    // Reorder items according to saved order
    order.forEach(pageId=>{
      if(items[pageId])nav.appendChild(items[pageId]);
    });
    // Append any items not in saved order (new pages added later)
    Object.keys(items).forEach(k=>{
      if(!order.includes(k))nav.appendChild(items[k]);
    });
  }catch(e){/* ignore corrupt data */}
}

