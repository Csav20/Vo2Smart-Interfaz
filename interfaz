// ── Master renderer ───────────────────────────────────────────────────────────
function _vtRender() {
  const canvas=document.getElementById('virt-tft-canvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  ctx.fillStyle='#000'; ctx.fillRect(0,0,_VTC.W,_VTC.H);
  const s=_VD.stage;
  if(!s)                               _vtOffline(ctx);
  else if(s==='INIT')                  _vtBootSplash(ctx);
  else if(s==='ALERT_O2'||s==='ALERT_CO2') _vtBootSensors(ctx);
  else if(s==='MENU')                  _vtBootMenu(ctx);
  else if(s==='PARAMETERS')            _vtS6(ctx);   // boot params screen = screen 6
  else if(s==='READY') {               // operational: live screens 1-6
    [_vtS1,_vtS2,_vtS3,_vtS4,_vtS5,_vtS6][_VD.screenNr-1](ctx);
  } else _vtBootSplash(ctx);
  // Demo badge
  const badge=document.getElementById('virt-demo-badge');
  if(badge) badge.style.display=_VD.demo?'block':'none';
  // Boot progress stepper
  const order=['INIT','ALERT_O2','ALERT_CO2','MENU','PARAMETERS','READY'];
  const idx=order.indexOf(s);
  document.querySelectorAll('.boot-step').forEach((el,i)=>{
    el.style.background=i<idx?_VTC.SUC:i===idx?_VTC.ORG:'rgba(255,255,255,0.1)';
  });
}

// ── State update helpers ──────────────────────────────────────────────────────
function vtInitOffline() {
  _VD.stage=null; _VD.deviceName=''; _VD.demo=false; _VD.sessionStartMs=0;
  _VD.board='';
  Object.keys(_VD.sensors).forEach(k=>_VD.sensors[k]=null);
  // Reset canvas to default TTGO dimensions
  _vtSetLayout(240, 135);
  _vtRender();
}
function vtUpdateFromConfig(r) {
  if(r.device)           _VD.deviceName=r.device;
  if(r.version)          _VD.version=r.version;
  if(r.demo!==undefined) _VD.demo=!!r.demo;
  if(r.weight)           _VD.cfg.weight=parseFloat(r.weight).toFixed(1);
  if(r.correction)       _VD.cfg.correction=parseFloat(r.correction).toFixed(2);
  if(r.co2_on!==undefined) _VD.data.co2_on=!!r.co2_on;
  // Adapt virtual TFT to device screen dimensions
  if(r.screen_w && r.screen_h && (r.screen_w !== _VTC.W || r.screen_h !== _VTC.H)) {
    _vtSetLayout(r.screen_w, r.screen_h);
  }
  if(r.board) _VD.board = r.board;
  _vtRender();
}
function vtUpdateFromData(d) {
  if(!_VD.sessionStartMs&&(d.vo2>0||d.ve>0)) _VD.sessionStartMs=Date.now();
  if(d.device_id)        _VD.deviceName='VO2-'+d.device_id;
  if(d.demo!==undefined) _VD.demo=!!d.demo;
  const m=_VD.data;
  if(d.vo2  !==undefined) m.vo2     =+d.vo2;
  if(d.vo2max!==undefined) m.vo2max =+d.vo2max;
  if(d.vco2 !==undefined) m.vco2    =+d.vco2;
  if(d.rq   !==undefined) m.rq      =+d.rq;
  if(d.ve   !==undefined) m.ve      =+d.ve;
  if(d.freq !==undefined) m.freq    =+d.freq;
  if(d.vol  !==undefined) m.vol     =+d.vol;
  if(d.o2   !==undefined) { m.o2=+d.o2; if(+d.o2>20.5) _VD.cfg.o2base=+d.o2; }
  if(d.co2  !==undefined) m.co2     =+d.co2;
  if(d.temp !==undefined) m.temp    =+d.temp;
  if(d.humid!==undefined) m.humid   =+d.humid;
  if(d.pres !==undefined) m.pres    =+d.pres;
  if(d.rho  !==undefined) { m.rho=+d.rho; }
  if(d.calTotal !==undefined) m.calTotal =+d.calTotal;
  if(d.calHour  !==undefined) m.calHour  =+d.calHour;
  if(d.batteryV !==undefined) m.batteryV =+d.batteryV;
  if(d.battery  !==undefined) m.battery  =+d.battery;
  if(_VD.stage==='READY') Object.keys(_VD.sensors).forEach(k=>{if(_VD.sensors[k]===null)_VD.sensors[k]=true;});
  _vtRender();
}

