let _protocolSkipSession=false;

function startTest(){
  if(G.testState==='paused'){
    G.testState='running';
    G.testPauseElapsed+=(Date.now()-G.testPauseStart);
    G.testPauseStart=null;
    updateTestUI();
    toast(t('toast_test_resumed'),'success');
    return;
  }
  // Show protocol modal or go direct
  if(_protocolSkipSession){
    _doStartTest();
  } else {
    var ov=document.getElementById('protocol-overlay');
    if(ov) ov.style.display='flex';
    else _doStartTest();
  }
}

function _doStartTest(){
  // Hide modal
  var ov=document.getElementById('protocol-overlay');
  if(ov) ov.style.display='none';
  // Check skip preference
  var cb=document.getElementById('protocol-noshow');
  if(cb&&cb.checked) _protocolSkipSession=true;
  // Fresh start — initialize everything
  G.session=[];
  G.fullHist={labels:[],vo2:[],vco2:[],hr:[],rer:[],ee:[],ve:[],fat:[],cho:[],veVCO2:[],veVO2:[],o2pulse:[],peto2:[],petco2:[],ee1:[],ee2:[],ee3:[],hrv:[]};
  G.snaHist={labels:[],sns:[],pns:[],hrv:[]};
  G.chartView='live';
  G.rawBuffer=[];
  G.epochBuffer=[];
  G.lastEpochUpdate=Date.now();
  G.vo2Peak=0;G.hrPeak=0;G.vePeak=0;G.rerPeak=0;G._lastRER=NaN;
  G.totalCalories=0;
  G.zoneTimes=[0,0,0,0,0];
  G.zoneTimers={z1:0,z2:0,z3:0,z4:0,z5:0};
  G.crossoverDetected=null;G.fatmaxDetected=null;G.prevFatPct=null;G.prevChoPct=null;
  G.kinetics={baseline:0,transitionStart:null,peak:0,tau:null,amplitude:null,valid:false,history:[]};
  G.rrBuffer=[];G.rrTimestamps=[];
  G.lastZoneTs=null;
  G.testMarkers=[];
  G.testPhaseIndex=0;
  G.testPauseElapsed=0;
  G.testPauseStart=null;
  resetStabilityIndicator();
  document.getElementById('markers-container').style.display='none';
  document.getElementById('markers-bar').innerHTML='';

  // Reset charts
  Object.keys(G.hist).forEach(k=>{G.hist[k].length=0;});
  Object.values(G.charts).forEach(ch=>{
    if(ch&&ch.data){ch.data.labels.length=0;ch.data.datasets.forEach(ds=>{ds.data.length=0;});ch.update('none');}
    if(ch&&typeof ch==='object'&&!ch.data){Object.values(ch).forEach(mc=>{if(mc&&mc.data){mc.data.labels.length=0;mc.data.datasets.forEach(ds=>{ds.data.length=0;});mc.update('none');}});}
  });

  // Reset table
  const tb=document.getElementById('log-body');
  if(tb)tb.innerHTML='<tr class="log-empty"><td colspan="16">Registrando… esperando datos.</td></tr>';
  document.getElementById('log-foot').style.display='none';

  G.testState='running';
  G.testStartTime=Date.now();
  G.sessionStart=Date.now();
  G.sessionActive=true;
  // Reset chart view toggle to live mode
  const cvToggle=document.getElementById('chart-view-toggle');
  if(cvToggle){cvToggle.querySelectorAll('.toggle-btn').forEach((b,i)=>{b.classList.toggle('active',i===0);});}
  const cvInfo=document.getElementById('chart-view-info');
  if(cvInfo)cvInfo.textContent='Últimos '+MAX_PTS+' puntos';
  setTestPhase('rest');

  if(G.testTimer)clearInterval(G.testTimer);
  G.testTimer=setInterval(updateTestTimer,100);

  updateTestUI();

  const pName=document.getElementById('protocol-select').selectedOptions[0].text;
  G.currentProtocol=document.getElementById('protocol-select').value;
  setText('protocol-display',pName);
  setText('sess-protocol',pName);
  setText('rep-protocol',pName);
  resetProtocolRuntime(true);
  updateProtocolPanelTick(true);

  // ═══ SYNC CON DISPOSITIVO ESP32 ═══
  sendBLECommand('START_TEST');
  sendProtocolToDevice(G.currentProtocol);
  sendPhaseToDevice('rest');
  // Enviar peso actual al dispositivo al iniciar prueba (asegurar sincronización)
  const w=getPatient().weight;
  if(w&&w>=20)sendWeightToDevice(w);

  toast(t('toast_test_started')+' — '+pName,'success');
}

function _cancelProtocol(){
  var ov=document.getElementById('protocol-overlay');
  if(ov) ov.style.display='none';
}

function pauseTest(){
  if(G.testState!=='running')return;
  G.testState='paused';
  G.testPauseStart=Date.now();
  updateTestUI();
  sendBLECommand('PAUSE_TEST');
  toast(t('toast_test_paused'),'info');
}

function stopTest(){
  if(G.testState==='idle')return;
  if(G.protocolRuntime){
    G.protocolRuntime.completed=true;
    G.protocolRuntime.elapsedSec=Math.floor(getTestElapsed()/1000);
  }
  G.testState='idle';
  G.sessionActive=false;
  _protocolSkipSession=false;
  if(G.simOn){clearInterval(G.sim);G.sim=null;G.simOn=false;}
  if(G.testTimer){clearInterval(G.testTimer);G.testTimer=null;}
  setTestPhase('standby');
  updateTestUI();
  updateSessionStats();
  updateProtocolPanelTick(true);
  sendBLECommand('STOP_TEST');
  // Auto-save session to local archive
  const saved=saveSessionToArchive();
  if(saved)toast(t('toast_test_stopped')+' — '+G.session.length+' pts · Sesión guardada','info');
  else toast(t('toast_test_stopped')+' — '+G.session.length,'info');
}

function setTestPhase(phase){
  G.testPhase=phase;
  const el=document.getElementById('test-phase');
  if(!el)return;
  const map={
    standby:{text:t('test_standby','STANDBY'),cls:'phase-idle'},
    rest:{text:t('test_rest','REPOSO'),cls:'phase-rest'},
    warmup:{text:t('test_warmup','CALENTAMIENTO'),cls:'phase-warmup'},
    exercise:{text:t('test_exercise','EJERCICIO'),cls:'phase-exercise'},
    recovery:{text:t('test_recovery','RECUPERACIÓN'),cls:'phase-recovery'},
    paused:{text:t('test_paused','PAUSA'),cls:'phase-paused'}
  };
  const m=map[phase]||map.standby;
  el.textContent=m.text;
  el.className='test-phase-label '+m.cls;
  setText('stage-display','Fase: '+m.text);
  updateProtocolPanelTick(true);
}

function advancePhase(){
  const phases=['rest','warmup','exercise','recovery'];
  G.testPhaseIndex=Math.min(G.testPhaseIndex+1,phases.length-1);
  setTestPhase(phases[G.testPhaseIndex]);
  addMarker('Fase: '+G.testPhase.toUpperCase());
  sendPhaseToDevice(G.testPhase);
  updateProtocolPanelTick(true);
  toast(t('toast_phase_advanced')+' '+G.testPhase,'info');
}

