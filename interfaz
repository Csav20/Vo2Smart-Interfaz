  try{if(G.serialWriter){G.serialWriter.releaseLock();}}catch(e){console.warn('Serial writer cleanup:',e.message);}
  try{if(G.serialPort){await G.serialPort.close();}}catch(e){console.warn('Serial port close:',e.message);}
  G.serialReader=null;
  G.serialWriter=null;
  G.serialPort=null;
  G.serialConnected=false;
  if(!silent){
    if(!G.bleCh&&!G.bleApiCh)setDiagDeviceName('--');
    if(!G.bleCh&&!G.bleApiCh)setConnected(false,t('status_disconnected'));
