function buildProtocolChecklist(protocolId){
  const list=[
    {key:'mask',labelKey:'protocol_check_mask',type:'manual',critical:true},
    {key:'oral',labelKey:'protocol_check_oral',type:'manual',critical:true},
    {key:'baseline',labelKey:'protocol_check_baseline',type:'auto',critical:true},
    {key:'warmup',labelKey:'protocol_check_warmup',type:'auto',critical:false},
    {key:'exercise',labelKey:'protocol_check_exercise',type:'auto',critical:false},
    {key:'recovery',labelKey:'protocol_check_recovery',type:'auto',critical:false},
    {key:'close',labelKey:'protocol_check_close',type:'auto',critical:true}
  ];
  if(protocolId==='rmr')list.splice(3,0,{key:'rmr_quiet',labelKey:'protocol_check_rmr_quiet',type:'manual',critical:true});
  if(protocolId==='wingate')list.splice(3,0,{key:'wingate_ready',labelKey:'protocol_check_wingate_ready',type:'manual',critical:true});
  if(protocolId==='lactate-step-bike'||protocolId==='lactate-step-run'){
    list.splice(4,0,{key:'lactate_sample',labelKey:'protocol_check_lactate_sample',type:'manual',critical:true});
  }
  if(protocolId==='ftp-20-bike'||protocolId==='conconi-run'||protocolId==='vam-incremental'||protocolId==='vo2max-inc-treadmill'||protocolId==='vo2max-inc-bike'){
    list.splice(4,0,{key:'pacing',labelKey:'protocol_check_pacing',type:'manual',critical:true});
  }
  if(protocolId==='yoyo-ir1'){
    list.splice(4,0,{key:'cone_spacing',labelKey:'protocol_check_cone_spacing',type:'manual',critical:true});
  }
  return list.map(i=>({...i,done:false}));
}

function resolveProtocolDefinition(protocolId){
  const id=protocolId||G.currentProtocol||'bruce';
  const meta=PROTOCOL_META[id]||PROTOCOL_META.bruce;
  const typeKey={
    rampa:'protocol_type_ramp',
    escalonado:'protocol_type_step',
    especial:'protocol_type_special',
    custom:'protocol_type_custom'
  }[meta.type]||'protocol_type_ramp';
  return {
    id,
    name:id==='custom'&&G.customProtocol?.name?`${G.customProtocol.name} (Custom)`:getProtocolOptionName(id),
    type:meta.type,
    typeLabel:t(typeKey,'--'),
    dynamic:meta.dynamic!==false,
    goalKey:meta.goalKey||'protocol_goal_vo2max',
    stages:buildStagesForProtocol(id),
    checklist:buildProtocolChecklist(id)
  };
}

function getStageLabel(stage){
  return stage.labelKey ? t(stage.labelKey,stage.labelKey) : (stage.label||t('protocol_stage_exercise','Exercise'));
}

function getStageStateFromElapsed(stages,elapsedSec){
  let acc=0;
  for(let i=0;i<stages.length;i++){
    const sec=Math.max(1,Math.floor(Number(stages[i].sec)||0));
    if(elapsedSec<acc+sec){
      return {index:i,stageElapsed:Math.max(0,elapsedSec-acc),stageSec:sec};
    }
    acc+=sec;
  }
  const last=Math.max(0,stages.length-1);
  const stageSec=Math.max(1,Math.floor(Number(stages[last]?.sec)||1));
  return {index:last,stageElapsed:stageSec,stageSec};
}

function getStageIndexFromPhase(stages,phase){
  const idx=stages.findIndex(s=>s.phase===phase);
  return idx>=0?idx:0;
}

function resetProtocolRuntime(started=false){
  const def=resolveProtocolDefinition(G.currentProtocol);
  G.protocolRuntime={
    active:def,
    stageIndex:0,
    stageProgress:0,
    totalProgress:0,
    elapsedSec:0,
    started:!!started,
    completed:false,
    checklist:def.checklist.map(i=>({...i})),
    alerts:[],
    advanceMode:'auto',
    stageChecked:def.stages.map(()=>false),
    manualStageIndex:0,
    stagePauseActive:false,
    stagePauseStart:null,
    stagePauseElapsedAll:def.stages.map(()=>0)
  };
  G.protocolPanelLastSec=-1;
  renderProtocolPanel(true);
}

function syncProtocolPanelFromSelection(){
  const v=document.getElementById('protocol-select')?.value||G.currentProtocol||'bruce';
  G.currentProtocol=v;
  if(!G.protocolRuntime||G.testState==='idle'){
    resetProtocolRuntime(false);
    return;
  }
  renderProtocolPanel(true);
}

function applyProtocolAutoChecks(runtime){
  const elapsed=Math.max(0,Math.floor(runtime.elapsedSec||0));
  runtime.checklist.forEach(item=>{
    if(item.type!=='auto')return;
    if(item.key==='baseline')item.done=(elapsed>=120||G.testPhase!=='rest');
    if(item.key==='warmup')item.done=(['warmup','exercise','recovery'].includes(G.testPhase));
    if(item.key==='exercise')item.done=(['exercise','recovery'].includes(G.testPhase));
    if(item.key==='recovery')item.done=(G.testPhase==='recovery'||runtime.completed===true);
    if(item.key==='close')item.done=(runtime.completed===true);
  });
}

function computeProtocolAlerts(runtime){
  const pending=runtime.checklist.filter(i=>{
    if(!(i.critical&&!i.done))return false;
    if(i.key==='close' && !runtime.completed)return false;
    return true;
  });
  if(!pending.length)return [{ok:true,msg:t('protocol_alert_ok','Sin alertas críticas')}];
  return pending.slice(0,3).map(i=>({ok:false,msg:`${t('protocol_alert_pending','Pendiente crítico:')} ${t(i.labelKey,i.labelKey)}`}));
}

function renderProtocolPanel(force=false){
  const panel=document.getElementById('protocol-live-panel');
  if(!panel)return;
  if(!G.protocolRuntime)resetProtocolRuntime(false);
  const rt=G.protocolRuntime;
  if(!rt||!rt.active)return;

  const sec=Math.floor(rt.elapsedSec||0);
  if(!force&&sec===G.protocolPanelLastSec)return;
  G.protocolPanelLastSec=sec;

  const mode=document.getElementById('protocol-live-mode');
  if(rt.advanceMode==='manual'){
    mode.textContent='MANUAL';mode.classList.add('dynamic');
  }else{
    mode.textContent=rt.active.dynamic?t('protocol_dynamic','DINÁMICO'):t('protocol_static','ESTÁTICO');
    mode.classList.toggle('dynamic',!!rt.active.dynamic);
  }

  setText('protocol-live-name',rt.active.name||'--');
  setText('protocol-live-type',rt.active.typeLabel||'--');
  setText('protocol-live-goal',t(rt.active.goalKey,'--'));

  const stage=rt.active.stages[Math.min(rt.stageIndex,rt.active.stages.length-1)]||null;
  const stageLabel=stage?getStageLabel(stage):'--';
  setText('protocol-live-stage',stageLabel);

  const p=Math.max(0,Math.min(100,Math.round((rt.totalProgress||0)*100)));
  setText('protocol-live-progress',`${p}%`);
  const pFill=document.getElementById('protocol-live-progress-fill');
  if(pFill)pFill.style.width=`${p}%`;

  const timeline=document.getElementById('protocol-live-timeline');
  if(timeline){
    timeline.innerHTML=rt.active.stages.map((s,idx)=>{
      const pct=idx<rt.stageIndex?100:(idx===rt.stageIndex?Math.round((rt.stageProgress||0)*100):0);
      const isDone=idx<rt.stageIndex||rt.stageChecked[idx];
      const isActive=idx===rt.stageIndex;
      const cls=`protocol-stage has-check ${isDone?'done':''} ${isActive?'active':''}`.trim();
      const meta=[secLabel(s.sec),s.target||''].filter(Boolean).join(' · ');
      const checkCls=`protocol-stage-check ${rt.stageChecked[idx]?'checked':''}`;
      const showPause=isActive&&G.testState==='running';
      const pauseIcon=(rt.stagePauseActive&&isActive)?'▶':'⏸';
      const pauseCls=`protocol-stage-pause ${(rt.stagePauseActive&&isActive)?'paused':''}`;
      return `<li class="${cls}">
        <div class="${checkCls}" onclick="onProtocolStageCheck(${idx})"></div>
        <div class="protocol-stage-dot"></div>
        <div>
          <div class="protocol-stage-name">${escHtml(getStageLabel(s))}</div>
          <div class="protocol-stage-meta">${escHtml(meta)}</div>
        </div>
        <button class="${pauseCls}" ${showPause?'':'style="visibility:hidden"'} onclick="protocolToggleStagePause()" title="Pausar etapa">${pauseIcon}</button>
        <div class="protocol-stage-pct">${pct}%</div>
      </li>`;
    }).join('');
  }

  const nextBtn=document.getElementById('protocol-next-stage-btn');
  if(nextBtn)nextBtn.classList.toggle('visible',rt.advanceMode==='manual'&&!rt.completed&&G.testState==='running');

  const checklist=document.getElementById('protocol-live-checklist');
  if(checklist){
    checklist.innerHTML=rt.checklist.map(item=>{
      const modeLabel=item.type==='auto'?t('protocol_auto','Auto'):t('protocol_manual','Manual');
      const cls=`protocol-check-item ${item.done?'done':''}`.trim();
      const dis=item.type==='auto'?'disabled':'';
      const chk=item.done?'checked':'';
      return `<label class="${cls}">
        <input type="checkbox" ${chk} ${dis} onchange="onProtocolChecklistToggle('${escHtml(item.key)}', this.checked)">
        <span class="protocol-check-body">
          <span class="protocol-check-label">${escHtml(t(item.labelKey,item.labelKey))}</span>
          <span class="protocol-check-meta">${escHtml(modeLabel)}${item.critical?' · CRIT':''}</span>
        </span>
      </label>`;
    }).join('');
  }

  const alerts=document.getElementById('protocol-live-alerts');
  if(alerts){
    alerts.innerHTML=(rt.alerts||[]).map(a=>`<div class="protocol-alert-item ${a.ok?'ok':''}">${escHtml(a.msg)}</div>`).join('');
  }
}

function updateProtocolPanelTick(force=false){
  if(!G.protocolRuntime||!G.protocolRuntime.active){
    resetProtocolRuntime(false);
    return;
  }
  const rt=G.protocolRuntime;
  const totalSec=rt.active.stages.reduce((acc,s)=>acc+Math.max(0,Number(s.sec)||0),0);
  if(G.testState==='running' || G.testState==='paused'){
    rt.elapsedSec=Math.floor(getTestElapsed()/1000);
    if(rt.advanceMode==='manual'){
      // Manual: stageIndex controlled by user, not time
      rt.stageIndex=rt.manualStageIndex;
      const stagesBeforeCurrent=rt.active.stages.slice(0,rt.stageIndex);
      const secBefore=stagesBeforeCurrent.reduce((a,s)=>a+Math.max(0,Number(s.sec)||0),0);
      const currentStageSec=Math.max(1,Number(rt.active.stages[rt.stageIndex]?.sec)||1);
      let stageElapsed=Math.max(0,rt.elapsedSec-secBefore);
      const pauseSec=Math.floor((rt.stagePauseElapsedAll[rt.stageIndex]||0)/1000);
      stageElapsed=Math.max(0,stageElapsed-pauseSec);
      if(rt.stagePauseActive&&rt.stagePauseStart){
        stageElapsed=Math.max(0,stageElapsed-Math.floor((Date.now()-rt.stagePauseStart)/1000));
      }
      rt.stageProgress=Math.max(0,Math.min(1,stageElapsed/currentStageSec));
    }else if(rt.active.dynamic){
      const st=getStageStateFromElapsed(rt.active.stages,rt.elapsedSec);
      rt.stageIndex=st.index;
      rt.stageProgress=Math.max(0,Math.min(1,st.stageElapsed/st.stageSec));
      for(let i=0;i<st.index;i++)rt.stageChecked[i]=true;
    }else{
      rt.stageIndex=getStageIndexFromPhase(rt.active.stages,G.testPhase);
      rt.stageProgress=0;
      for(let i=0;i<rt.stageIndex;i++)rt.stageChecked[i]=true;
    }
    rt.totalProgress=totalSec>0?Math.max(0,Math.min(1,rt.elapsedSec/totalSec)):0;
  }
  applyProtocolAutoChecks(rt);
  rt.alerts=computeProtocolAlerts(rt);
  renderProtocolPanel(force);
}

function onProtocolChecklistToggle(key,checked){
  const rt=G.protocolRuntime;
  if(!rt)return;
  const item=rt.checklist.find(i=>i.key===key);
  if(!item||item.type!=='manual')return;
  item.done=!!checked;
  rt.alerts=computeProtocolAlerts(rt);
  renderProtocolPanel(true);
}
window.onProtocolChecklistToggle=onProtocolChecklistToggle;

