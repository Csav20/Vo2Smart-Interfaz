async function connectWired(){
  if(!('serial' in navigator)){
    toast('Web Serial no soportado en este navegador','error');
    return;
  }
  if(G.serialConnected){
    await disconnectWired(false);
    return;
  }
  try{
    const grantedPorts=await navigator.serial.getPorts();
    let port;
    if(grantedPorts.length>0){
      const scorePort=(p)=>{
        const info=p.getInfo?p.getInfo():{};
        const vid=info.usbVendorId;
        if(vid===0x10c4)return 3;
        if(vid===0x1a86||vid===0x0403||vid===0x2341)return 2;
        return 1;
      };
      port=[...grantedPorts].sort((a,b)=>scorePort(b)-scorePort(a))[0];
      toast(t('toast_wired_autouse'),'info');
    }else{
      toast(t('toast_wired_pick_hint'),'info');
      port=await navigator.serial.requestPort({filters:WIRED_PORT_FILTERS});
    }
    await port.open({baudRate:9600});
    G.serialPort=port;
    G.serialReader=port.readable.getReader();
    G.serialWriter=port.writable.getWriter();
    G.serialConnected=true;
    setDiagDeviceName('Detectando...');
    setConnected(true,'Conectando: USB/Wired...');
    toast('USB/Wired conectado (9600)','success');
    startWiredReadLoop();
    await sendBLECommand('GET_BOOT_STATE');
    await sendBLECommand('GET_CONFIG');
    setTimeout(()=>sendBLECommand('GET_VERSION'),200);
  }catch(e){
    toast('Error USB/Wired: '+e.message,'error');
  }
}

/* ── HRV COMPUTATION ENGINE ── */
function computeHRV(){
  const rr=G.rrBuffer;
  if(rr.length<6)return;
  // Successive differences for RMSSD and pNN50
  const diffs=[];
  let nn50=0;
  for(let i=1;i<rr.length;i++){
    const d=Math.abs(rr[i]-rr[i-1]);
    diffs.push(d);
    if(d>50)nn50++;
  }
  // RMSSD
  const sumSqDiff=diffs.reduce((s,d)=>s+d*d,0);
  const rmssd=Math.sqrt(sumSqDiff/diffs.length);
  // SDNN
  const meanRR=rr.reduce((s,v)=>s+v,0)/rr.length;
  const varRR=rr.reduce((s,v)=>s+Math.pow(v-meanRR,2),0)/rr.length;
  const sdnn=Math.sqrt(varRR);
  // pNN50
  const pnn50=(diffs.length>0)?(nn50/diffs.length)*100:0;
  // LF/HF estimation (time-domain proxy: SDNN/RMSSD)
  // Higher ratio = sympathetic dominance; lower = parasympathetic
  const lfhf=rmssd>0?(sdnn/rmssd):1.0;

  G.hrvMetrics={rmssd:rmssd,sdnn:sdnn,pnn50:pnn50,meanRR:meanRR,lfhf:lfhf};

  // Baseline: first stable measurement at rest (RMSSD > 10, enough samples)
  if(!G.hrvBaseline&&rmssd>5&&rr.length>=20){
    G.hrvBaseline=rmssd;
  }
  // SNA balance
  const hr=60000/meanRR;
  const fcFactor=Math.min(100,Math.max(0,(hr-55)*1.8));
  const hrvRatio=G.hrvBaseline?(rmssd/G.hrvBaseline):1.0;
  const pnsRaw=Math.min(100,Math.max(0,hrvRatio*55));
  const snsRaw=fcFactor;
  const total=snsRaw+pnsRaw;
  if(total>0){
    G.snsIndex=Math.round((snsRaw/total)*100);
    G.pnsIndex=100-G.snsIndex;
  }
  updateHRVDisplay();
}

