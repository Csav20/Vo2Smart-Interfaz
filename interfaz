function escHtml(v){
  return String(v ?? '')
    .replaceAll('&','&amp;')
    .replaceAll('<','&lt;')
    .replaceAll('>','&gt;')
    .replaceAll('"','&quot;')
    .replaceAll("'",'&#39;');
}

function secLabel(sec){
  const s=Math.max(0,Math.floor(Number(sec)||0));
  const m=Math.floor(s/60);
  const r=s%60;
  return `${m}m ${String(r).padStart(2,'0')}s`;
}

