<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>VO₂Smart PRO v5</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" onerror="console.warn('Chart.js CDN failed — charts will not render. Check network connection.')"></script>
<style>
:root {
  --primary: #6b7280;
  --primary-light: #8b95a5;
  --accent: #dfe312;
  --accent2: #ff7a45;
  --accent3: #b06ef7;
  --bg: #ffffff;
  --bg2: #f1f3f6;
  --card: #0b1022;
  --card2: #131a2e;
  --border: rgba(214,218,19,0.20);
  --border2: rgba(255,255,255,0.10);
  --text: #f1f5f9;
  --text-page: #1e293b;
  --muted: #94a3b8;
  --muted2: #a0aec0;
  --fg: #f1f5f9;
  --success: #22c55e;
  --danger: #ff4d6d;
  --warn: #ffbe0b;
  --mono: 'DM Mono', monospace;
  --display: 'Syne', sans-serif;
  --body: 'Inter', sans-serif;
  --radius: 16px;
  --radius-sm: 10px;
}

*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--body);background:var(--bg);color:var(--text-page);min-height:100vh;overflow-x:hidden;}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px;height:6px;}
::-webkit-scrollbar-track{background:var(--bg2);}
::-webkit-scrollbar-thumb{background:rgba(100,116,139,0.45);border-radius:3px;}

/* ── GRID LAYOUT ── */
.app{display:grid;grid-template-rows:auto 1fr;min-height:100vh;}

/* ── TOPBAR ── */
.topbar{
  background:linear-gradient(135deg,rgba(75,85,99,0.97),rgba(100,110,120,0.92));
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(255,255,255,0.12);
  padding:0 20px;
  position:sticky;top:0;z-index:100;
}
.topbar-inner{
  max-width:1600px;margin:0 auto;
  display:flex;align-items:center;gap:16px;height:60px;flex-wrap:wrap;
}
.brand{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.brand-icon{
  width:36px;height:36px;border-radius:10px;
  background:transparent;
  display:flex;align-items:center;justify-content:center;font-size:18px;
}
.brand-name{font-family:var(--display);font-size:1.2rem;font-weight:900;letter-spacing:-0.5px;}
.brand-name span{color:var(--accent);}
.brand-badge{
  font-family:var(--mono);font-size:0.65rem;
  background:rgba(214,218,19,0.15);border:1px solid rgba(214,218,19,0.4);
  color:var(--accent);padding:2px 8px;border-radius:20px;
}
.topbar-right{display:flex;align-items:center;gap:10px;margin-left:auto;flex-wrap:wrap;}
.status-pill{
  display:flex;align-items:center;gap:7px;
  background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);
  border-radius:20px;padding:6px 12px;font-size:0.8rem;font-weight:600;color:#fff;
}
.status-dot{width:8px;height:8px;border-radius:50%;background:#94a3b8;flex-shrink:0;}
.status-dot.on{background:var(--success);animation:pulse2 2s infinite;}
@keyframes pulse2{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0.5);}70%{box-shadow:0 0 0 8px rgba(34,197,94,0);}}

/* ── BUTTONS ── */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:8px 14px;border-radius:var(--radius-sm);border:none;
  font-family:var(--body);font-size:0.82rem;font-weight:700;cursor:pointer;
  transition:all .2s ease;text-decoration:none;white-space:nowrap;
}
.btn:hover{transform:translateY(-1px);}
.btn-primary{background:linear-gradient(135deg,var(--primary-light),var(--accent));color:#2a2a32;}
.btn-primary:hover{box-shadow:0 6px 20px rgba(214,218,19,0.3);}
.btn-ghost{background:rgba(255,255,255,0.07);color:var(--text);border:1px solid rgba(255,255,255,0.15);}
.btn-ghost:hover{background:rgba(255,255,255,0.12);}
.btn-danger{background:rgba(255,77,109,0.15);color:var(--danger);border:1px solid rgba(255,77,109,0.3);}
.btn-danger:hover{background:rgba(255,77,109,0.25);}
.btn-warn{background:rgba(255,190,11,0.15);color:var(--warn);border:1px solid rgba(255,190,11,0.3);}
.btn-warn:hover{background:rgba(255,190,11,0.25);}
.btn-success{background:rgba(34,197,94,0.15);color:var(--success);border:1px solid rgba(34,197,94,0.3);}
.btn-success:hover{background:rgba(34,197,94,0.25);}
.btn-seq1{background:rgba(0,180,255,0.18);color:#8ad8ff;border:1px solid rgba(0,180,255,0.45);} /* Paso 1 */
.btn-seq1:hover{background:rgba(0,180,255,0.28);}
.btn-seq2{background:rgba(255,190,11,0.2);color:#ffd76a;border:1px solid rgba(255,190,11,0.45);} /* Paso 2 */
.btn-seq2:hover{background:rgba(255,190,11,0.3);}
.btn-seq3{background:rgba(214,218,19,0.2);color:#e8eacc;border:1px solid rgba(214,218,19,0.45);} /* Paso 3 */
.btn-seq3:hover{background:rgba(214,218,19,0.3);}
.btn-seq4{background:rgba(255,107,53,0.2);color:#ffb08e;border:1px solid rgba(255,107,53,0.45);} /* Paso 4 */
.btn-seq4:hover{background:rgba(255,107,53,0.3);}
.btn-sm{padding:6px 11px;font-size:0.78rem;}
.btn-xs{padding:4px 9px;font-size:0.73rem;}
.btn:disabled{opacity:0.4;pointer-events:none;}

/* ── TOGGLE SWITCH ── */
.toggle-group{display:inline-flex;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:8px;overflow:hidden;}
.toggle-btn{
  padding:5px 12px;font-size:0.72rem;font-weight:700;font-family:var(--mono);
  background:transparent;border:none;color:rgba(255,255,255,0.7);cursor:pointer;
  transition:all .2s;white-space:nowrap;
}
.toggle-btn.active{background:rgba(214,218,19,0.2);color:var(--accent);box-shadow:inset 0 0 0 1px rgba(214,218,19,0.4);}
.toggle-btn:hover:not(.active){background:rgba(255,255,255,0.06);}

/* ── MAIN LAYOUT ── */
.main{display:flex;height:calc(100vh - 60px);}
.sidebar{
  width:200px;flex-shrink:0;
  background:var(--bg2);border-right:1px solid rgba(0,0,0,0.08);
  display:flex;flex-direction:column;overflow-y:auto;
}
.sidebar-nav{padding:12px 8px;flex:1;}
.nav-label{font-size:0.65rem;color:#64748b;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:8px 10px 4px;}
.nav-item{
  display:flex;align-items:center;gap:9px;
  padding:9px 12px;border-radius:var(--radius-sm);
  font-size:0.83rem;font-weight:600;color:#374151;cursor:pointer;
  transition:all .2s;margin-bottom:2px;border:none;background:none;width:100%;text-align:left;
}
.nav-item:hover{background:rgba(0,0,0,0.05);color:var(--text-page);}
.nav-item.active{background:rgba(91,91,95,0.1);color:var(--primary);border-left:2px solid var(--primary);}
.nav-item .icon{font-size:1rem;flex-shrink:0;}
.nav-item.dragging{opacity:0.4;background:rgba(214,218,19,0.06);}
.nav-item.drag-over{border-top:2px solid var(--accent);margin-top:-2px;}
.nav-item .drag-handle{cursor:grab;font-size:0.7rem;color:#64748b;margin-left:auto;opacity:0;transition:opacity .2s;}
.nav-item:hover .drag-handle{opacity:0.6;}
.nav-item .drag-handle:active{cursor:grabbing;}
.nav-badge{margin-left:auto;background:var(--primary);color:#fff;font-size:0.65rem;font-weight:800;padding:1px 6px;border-radius:10px;display:none;}
.nav-badge.show{display:block;}

/* ── CONTENT ── */
.content{flex:1;overflow-y:auto;padding:16px 20px;}
.page{display:none;}
.page.active{display:block;}

/* ── CONNECTION BAR ── */
.conn-bar{
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;color:var(--text);
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);
  padding:12px 16px;margin-bottom:16px;
}
.conn-bar input[type=text]{
  flex:1;min-width:160px;background:rgba(255,255,255,0.07);
  border:1px solid rgba(163,85,247,0.45);border-radius:8px;
  color:var(--fg);font-family:var(--mono);font-size:0.8rem;padding:7px 10px;
}
.conn-bar input[type=text]:focus{outline:none;border-color:var(--accent3);}
.cortex-indicator{
  display:flex;align-items:center;gap:6px;font-size:0.78rem;color:var(--accent3);
  background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.3);
  border-radius:8px;padding:5px 10px;
}

/* ── TEST CONTROL BAR ── */
.test-control-bar{
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;color:var(--text);
  background:linear-gradient(135deg,#101838,#0c1128);
  border:1px solid var(--border);border-radius:var(--radius);
  padding:14px 18px;margin-bottom:16px;
  position:relative;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.15);
}
.test-control-bar::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
  opacity:0.5;
}
.test-control-bar.recording{border-color:rgba(214,218,19,0.5);box-shadow:0 0 20px rgba(214,218,19,0.1);}
.test-control-bar.recording::before{
  animation:recScan 2s linear infinite;opacity:1;
}
@keyframes recScan{0%{background-position:-200% 0;}100%{background-position:200% 0;}}
.test-control-bar.paused{border-color:rgba(255,190,11,0.5);}

.test-phase-label{
  font-family:var(--mono);font-size:0.7rem;font-weight:700;
  text-transform:uppercase;letter-spacing:1px;padding:3px 10px;
  border-radius:6px;
}
.phase-idle{background:rgba(107,127,163,0.2);color:var(--muted);}
.phase-rest{background:rgba(59,130,246,0.2);color:#60a5fa;}
.phase-warmup{background:rgba(245,158,11,0.2);color:#fbbf24;}
.phase-exercise{background:rgba(214,218,19,0.2);color:var(--accent);}
.phase-recovery{background:rgba(168,85,247,0.2);color:#c084fc;}
.phase-paused{background:rgba(255,190,11,0.3);color:var(--warn);}

.test-timer{
  font-family:var(--display);font-size:1.8rem;font-weight:900;
  color:var(--text);letter-spacing:1px;min-width:100px;text-align:center;
}
.test-timer.recording{color:var(--accent);}
.test-timer.paused{color:var(--warn);animation:blink 1s step-end infinite;}
@keyframes blink{50%{opacity:0.3;}}

.rec-dot{
  width:10px;height:10px;border-radius:50%;background:var(--danger);
  animation:recPulse 1s infinite;display:none;
}
.rec-dot.on{display:block;}
@keyframes recPulse{0%,100%{opacity:1;}50%{opacity:0.3;}}

.protocol-selector{
  display:flex;align-items:center;gap:8px;
}
.protocol-select{
  background:var(--card2);border:1px solid var(--border2);border-radius:8px;
  color:var(--text);font-family:var(--body);font-size:0.82rem;padding:6px 10px;
  cursor:pointer;min-width:180px;
}
.protocol-select:focus{outline:none;border-color:rgba(214,218,19,0.5);}
.protocol-select option{background:var(--card);}

/* ── CUSTOM PROTOCOL MODAL ── */
.modal-overlay{
  position:fixed;inset:0;z-index:500;
  background:rgba(6,9,26,0.85);backdrop-filter:blur(8px);
  display:none;align-items:center;justify-content:center;
}
.modal-overlay.show{display:flex;}
.modal-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);
  padding:28px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;
  box-shadow:0 20px 60px rgba(0,0,0,0.5);
}
.modal-card h3{font-family:var(--display);font-size:1.1rem;font-weight:800;margin-bottom:16px;color:var(--accent);}
.modal-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.modal-field{display:flex;flex-direction:column;gap:5px;}
.modal-field label{font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;}
.modal-field input,.modal-field select,.modal-field textarea{
  background:var(--card2);border:1px solid var(--border2);border-radius:8px;
  color:var(--text);font-family:var(--body);font-size:0.85rem;padding:8px 10px;
}
.modal-field input:focus,.modal-field select:focus,.modal-field textarea:focus{outline:none;border-color:rgba(214,218,19,0.5);}
.modal-actions{display:flex;gap:10px;margin-top:18px;justify-content:flex-end;}

/* ── SMOOTHING BAR ── */
.smoothing-bar{
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;color:var(--text);
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);
  padding:10px 16px;margin-bottom:16px;
}
.smoothing-label{font-size:0.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;}

/* ── PAGE-LEVEL TEXT on white bg ── */
.content{color:var(--text-page);}
.content .stat-item{color:var(--muted2);}
.content .stat-item strong{color:var(--text);}

/* Sidebar ghost buttons need dark text on light bg */
.sidebar .btn-ghost{background:rgba(0,0,0,0.04);color:var(--text-page);border-color:rgba(0,0,0,0.12);}
.sidebar .btn-ghost:hover{background:rgba(0,0,0,0.08);}
.sidebar div[style*="border-top"]{border-top-color:rgba(0,0,0,0.08)!important;}

/* ── DASHBOARD: MAIN + RIGHT PANEL ── */
.dashboard-layout{
  display:grid;
  grid-template-columns:minmax(0,1fr) 330px;
  gap:14px;
  align-items:start;
}
.dashboard-main{min-width:0;}

.protocol-live-panel{
  background:linear-gradient(165deg,rgba(16,24,56,0.96),rgba(12,17,40,0.96));color:var(--text);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:12px;
  position:sticky;
  top:74px;
}
.protocol-panel-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:8px;
  margin-bottom:10px;
}
.protocol-panel-title{
  font-family:var(--display);
  font-size:0.95rem;
  font-weight:800;
  letter-spacing:0.2px;
}
.protocol-live-pill{
  font-family:var(--mono);
  font-size:0.64rem;
  font-weight:700;
  letter-spacing:0.6px;
  text-transform:uppercase;
  border-radius:999px;
  padding:4px 8px;
  border:1px solid rgba(255,255,255,0.25);
  color:var(--muted);
  background:rgba(255,255,255,0.08);
}
.protocol-live-pill.dynamic{
  border-color:rgba(214,218,19,0.45);
  color:var(--accent);
  background:rgba(214,218,19,0.14);
}
.protocol-panel-card{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.09);
  border-radius:12px;
  padding:9px 10px;
  margin-bottom:10px;
}
.protocol-meta-row{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:8px;
  font-size:0.76rem;
}
.protocol-meta-row + .protocol-meta-row{margin-top:6px;}
.protocol-meta-row .k{color:var(--muted2);}
.protocol-meta-row .v{color:var(--text);font-weight:700;text-align:right;}

.protocol-progress-wrap{margin-top:8px;}
.protocol-progress-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:5px;
  font-size:0.7rem;
  color:var(--muted2);
}
.protocol-progress-bar{
  height:7px;
  border-radius:5px;
  background:rgba(255,255,255,0.08);
  overflow:hidden;
}
.protocol-progress-fill{
  height:100%;
  width:0%;
  background:linear-gradient(90deg,var(--accent2),var(--accent));
  transition:width .25s ease;
}

.protocol-block-title{
  font-size:0.67rem;
  color:var(--muted);
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:0.6px;
  margin-bottom:7px;
}
.protocol-timeline{
  list-style:none;
  margin:0;
  padding:0;
  display:grid;
  gap:6px;
}
.protocol-stage{
  display:grid;
  grid-template-columns:12px minmax(0,1fr) auto;
  gap:8px;
  align-items:start;
  padding:7px;
  border-radius:8px;
  border:1px solid rgba(255,255,255,0.06);
  background:rgba(255,255,255,0.02);
}
.protocol-stage-dot{
  width:10px;height:10px;border-radius:50%;
  margin-top:2px;
  background:rgba(255,255,255,0.30);
}
.protocol-stage.active{
  border-color:rgba(214,218,19,0.35);
  background:rgba(214,218,19,0.08);
}
.protocol-stage.active .protocol-stage-dot{background:var(--accent);}
.protocol-stage.done .protocol-stage-dot{background:#60a5fa;}
.protocol-stage-name{font-size:0.74rem;font-weight:700;color:var(--fg);line-height:1.2;}
.protocol-stage-meta{font-size:0.66rem;color:var(--muted2);margin-top:2px;line-height:1.2;}
.protocol-stage-pct{font-family:var(--mono);font-size:0.66rem;color:var(--muted2);}

.protocol-checklist{display:grid;gap:6px;}
.protocol-check-item{
  display:flex;
  align-items:flex-start;
  gap:8px;
  padding:7px;
  border:1px solid rgba(255,255,255,0.06);
  border-radius:8px;
  background:rgba(255,255,255,0.02);
}
.protocol-check-item.done{
  border-color:rgba(214,218,19,0.35);
  background:rgba(214,218,19,0.08);
}
.protocol-check-item input{
  margin-top:1px;
  width:15px;
  height:15px;
  accent-color:var(--accent);
}
.protocol-check-body{min-width:0;}
.protocol-check-label{font-size:0.72rem;color:var(--text);line-height:1.2;}
.protocol-check-meta{font-size:0.64rem;color:var(--muted2);margin-top:2px;}

.protocol-alerts{display:grid;gap:6px;}
.protocol-alert-item{
  font-size:0.68rem;
  line-height:1.25;
  padding:7px 8px;
  border-radius:8px;
  border:1px solid rgba(255,190,11,0.3);
  color:#fcd34d;
  background:rgba(255,190,11,0.08);
}
.protocol-alert-item.ok{
  border-color:rgba(214,218,19,0.3);
  color:#d6da13;
  background:rgba(214,218,19,0.08);
}

/* ── PROTOCOL: AUTO/MANUAL TOGGLE ── */
.protocol-mode-toggle{display:inline-flex;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:8px;overflow:hidden;}
.protocol-mode-toggle .toggle-btn{padding:3px 8px;font-size:0.62rem;border-radius:0;}

/* ── PROTOCOL: STAGE CHECKMARK ── */
.protocol-stage-check{
  width:14px;height:14px;border-radius:4px;border:1.5px solid rgba(255,255,255,0.2);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  transition:all .2s;flex-shrink:0;margin-top:2px;
}
.protocol-stage-check.checked{border-color:var(--accent);background:rgba(214,218,19,0.2);}
.protocol-stage-check.checked::after{content:'\2713';font-size:0.6rem;color:var(--accent);font-weight:700;}

/* ── PROTOCOL: STAGE PAUSE BUTTON ── */
.protocol-stage-pause{
  background:none;border:none;font-size:0.6rem;cursor:pointer;
  color:var(--muted2);padding:2px 4px;border-radius:4px;transition:color .2s;
}
.protocol-stage-pause:hover{color:var(--accent);}
.protocol-stage-pause.paused{color:var(--warn);animation:blink 1s step-end infinite;}

/* ── PROTOCOL: NEXT STAGE BUTTON ── */
.protocol-next-stage-btn{
  display:none;width:100%;margin-top:8px;padding:6px 12px;font-size:0.72rem;
  font-weight:700;font-family:var(--mono);background:rgba(214,218,19,0.15);
  border:1px solid rgba(214,218,19,0.35);border-radius:8px;color:var(--accent);
  cursor:pointer;text-transform:uppercase;letter-spacing:0.5px;transition:background .2s;
}
.protocol-next-stage-btn:hover{background:rgba(214,218,19,0.25);}
.protocol-next-stage-btn.visible{display:block;}

/* ── PROTOCOL: STAGE WITH CHECK GRID ── */
.protocol-stage.has-check{grid-template-columns:14px 12px minmax(0,1fr) auto auto;}

/* ── METRIC CARDS (BIG NUMBERS) ── */
.metrics-hero{
  display:grid;gap:12px;margin-bottom:16px;
  grid-template-columns:repeat(4,1fr);
}
.metric-card{
  background:var(--card);border:1px solid rgba(255,255,255,0.09);border-radius:var(--radius);color:var(--text);
  padding:16px;position:relative;overflow:hidden;cursor:default;
  transition:border-color .2s;
  min-height:210px;height:210px;max-height:210px;
  contain:layout style;
  box-sizing:border-box;
}
.metric-card:hover{border-color:rgba(214,218,19,0.3);}
.metric-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(214,218,19,0.04),transparent 60%);
  pointer-events:none;
}
.metric-card.highlight{border-color:rgba(214,218,19,0.35);}
.metric-card.highlight::before{background:linear-gradient(135deg,rgba(214,218,19,0.1),transparent 60%);}
.m-label{font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;height:16px;line-height:16px;}
.m-value{
  font-family:var(--display);font-weight:900;
  font-size:2.4rem;line-height:1;
  color:var(--text);margin:4px 0;
  height:38px;overflow:hidden;
}
.m-value span.accent{color:var(--accent);}
.m-unit{font-size:0.75rem;color:var(--muted);font-family:var(--mono);height:16px;line-height:16px;}
.m-sub{display:flex;gap:12px;margin-top:4px;flex-wrap:wrap;height:20px;overflow:hidden;}
.m-sub-item{font-size:0.72rem;color:var(--muted);font-family:var(--mono);white-space:nowrap;}
.m-sub-item strong{color:var(--text);}
.m-trend{position:absolute;top:12px;right:12px;font-size:0.7rem;font-family:var(--mono);}
.trend-up{color:var(--success);}
.trend-down{color:var(--danger);}

/* ── MINI CHARTS IN CARDS ── */
.mini-chart-wrap{height:60px;margin-top:6px;flex-shrink:0;}
.mini-chart-wrap canvas{width:100%!important;height:60px!important;}

/* ── CHART VIEW TOGGLE ── */
.chart-view-bar{display:flex;align-items:center;gap:10px;margin-bottom:12px;padding:8px 12px;background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);}
.chart-view-bar .view-label{font-size:0.8rem;color:var(--muted);font-weight:600;}
.chart-view-bar .toggle-group{display:flex;gap:0;}
.chart-view-bar .toggle-btn.active{background:var(--accent);color:#0a0f1e;}
/* ── REPORT CHART IMAGES ── */
.report-chart-section{margin-bottom:20px;}
.report-chart-img{width:100%;border-radius:8px;margin:8px 0;border:1px solid var(--border2);display:none;}

/* ── CHARTS GRID ── */
.charts-grid{display:grid;gap:12px;grid-template-columns:2fr 1fr;margin-bottom:16px;}
.chart-card{
  background:var(--card);border:1px solid rgba(255,255,255,0.09);border-radius:var(--radius);color:var(--text);
  padding:16px;
}
.chart-card.full{grid-column:1/-1;}
.chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;gap:8px;flex-wrap:wrap;}
.chart-title{font-family:var(--display);font-size:0.95rem;font-weight:800;color:var(--text);}
.chart-legend{display:flex;gap:12px;flex-wrap:wrap;}
.leg-item{display:flex;align-items:center;gap:5px;font-size:0.72rem;color:var(--muted);}
.leg-dot{width:8px;height:8px;border-radius:50%;}
.chart-body canvas{width:100%!important;}
.chart-h300 canvas{height:300px!important;}
.chart-h220 canvas{height:220px!important;}
.chart-h180 canvas{height:180px!important;}

/* ── SECONDARY METRICS GRID ── */
.metrics-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:10px;margin-bottom:16px;}
.metric-mini{
  background:var(--card2);border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--text);
  padding:10px 12px;
  min-height:72px;height:72px;max-height:72px;
  contain:layout style;
  box-sizing:border-box;
  overflow:hidden;
}
.mm-label{font-size:0.67rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;height:14px;line-height:14px;white-space:nowrap;overflow:hidden;}
.mm-value{font-family:var(--mono);font-size:1.3rem;font-weight:500;color:var(--text);margin:3px 0;height:22px;line-height:22px;overflow:hidden;white-space:nowrap;}
.mm-unit{font-size:0.67rem;color:var(--muted);height:12px;line-height:12px;}

/* ── REFERENCE PANEL ── */
.ref-panel{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  padding:14px 16px;margin-bottom:16px;overflow:hidden;
  position:relative;
}
.ref-panel::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,#c0392b,#e67e22,#f1c40f,#27ae60,#00aeff,#d6da13);
}
.ref-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:12px;}
.ref-profile{font-size:0.82rem;color:var(--muted2);font-weight:600;}
.ref-class-badge{
  font-family:var(--display);font-weight:800;font-size:0.8rem;
  padding:4px 14px;border-radius:20px;display:inline-block;
  transition:all 0.3s;letter-spacing:0.03em;
  box-shadow:0 0 10px rgba(0,0,0,0.2);
}
.ref-ranges{display:flex;gap:3px;flex-wrap:nowrap;}
.ref-range-block{
  flex:1;min-width:0;padding:8px 2px 6px;border-radius:8px;text-align:center;
  font-size:0.6rem;opacity:0.35;transition:all 0.4s cubic-bezier(.4,0,.2,1);
  border:1px solid transparent;position:relative;
}
.ref-range-block.active{
  opacity:1;transform:scaleY(1.08);border-color:currentColor;font-weight:700;
  box-shadow:0 0 12px rgba(255,255,255,0.1);z-index:1;
}
.ref-range-block.active::before{
  content:'●';position:absolute;top:-8px;left:50%;transform:translateX(-50%);
  font-size:0.5rem;color:inherit;text-shadow:0 0 6px currentColor;
}
.ref-range-label{font-weight:800;margin-bottom:3px;letter-spacing:0.04em;font-size:0.58rem;}
.ref-range-val{font-family:var(--mono);font-size:0.68rem;font-weight:600;}
.vo2-class-badge{
  font-weight:800;font-size:0.68rem;padding:2px 10px;border-radius:10px;
  display:inline-block;vertical-align:middle;letter-spacing:0.03em;
  box-shadow:0 0 6px rgba(0,0,0,0.15);
}

/* ── ZONE BAR ── */
.zone-bar{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  padding:14px 16px;margin-bottom:16px;
}
.zone-bar-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.zone-title{font-family:var(--display);font-size:0.9rem;font-weight:800;}
.zone-current{display:flex;align-items:center;gap:8px;}
.zone-badge{
  font-family:var(--display);font-weight:900;font-size:1.4rem;
  padding:4px 16px;border-radius:8px;
}
.zones-row{display:flex;gap:8px;flex-wrap:wrap;}
.zone-block{
  flex:1;min-width:60px;padding:8px 10px;border-radius:8px;border:1px solid;
  text-align:center;
}
.zone-block .znum{font-family:var(--display);font-weight:900;font-size:0.9rem;}
.zone-block .zpct{font-size:0.65rem;opacity:0.75;margin:2px 0;}
.zone-block .ztime{font-family:var(--mono);font-size:0.8rem;font-weight:500;}
.z1{border-color:rgba(59,130,246,0.4);background:rgba(59,130,246,0.1);color:#60a5fa;}
.z2{border-color:rgba(16,185,129,0.4);background:rgba(16,185,129,0.1);color:#34d399;}
.z3{border-color:rgba(245,158,11,0.4);background:rgba(245,158,11,0.1);color:#fbbf24;}
.z4{border-color:rgba(239,68,68,0.4);background:rgba(239,68,68,0.1);color:#f87171;}
.z5{border-color:rgba(168,85,247,0.4);background:rgba(168,85,247,0.1);color:#c084fc;}

/* ── SUBSTRATE BAR ── */
.substrate-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.substrate-card{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  padding:14px;
}
.sub-header{font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;}
.sub-value{font-family:var(--display);font-size:2rem;font-weight:900;}
.sub-unit{font-size:0.75rem;color:var(--muted);font-family:var(--mono);}
.sub-bar-wrap{height:6px;border-radius:3px;background:rgba(255,255,255,0.08);margin:10px 0;overflow:hidden;}
.sub-bar-fill{height:100%;border-radius:3px;transition:width .4s;}
.sub-pct{font-family:var(--mono);font-size:0.8rem;}

/* ── CORTEX COMPARISON ── */
.cortex-panel{
  background:var(--card);border:1px solid rgba(168,85,247,0.3);border-radius:var(--radius);color:var(--text);
  padding:16px;margin-bottom:16px;
}
.cortex-title{
  font-family:var(--display);font-size:0.9rem;font-weight:800;color:var(--accent3);
  margin-bottom:14px;display:flex;align-items:center;gap:8px;
}
.cortex-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.cortex-metric-label{font-size:0.67rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
.cortex-device-val{font-family:var(--mono);font-size:1.8rem;font-weight:500;color:var(--fg);}
.cortex-device-unit{font-size:0.67rem;color:var(--muted);font-family:var(--mono);}
.cortex-input{
  width:100%;background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.4);
  border-radius:8px;color:var(--accent3);font-family:var(--mono);font-size:1.1rem;
  font-weight:500;padding:6px 10px;text-align:right;margin-top:6px;
}
.cortex-input:focus{outline:none;border-color:var(--accent3);}
.cortex-diff{
  margin-top:6px;font-family:var(--mono);font-size:0.78rem;font-weight:700;
  padding:2px 8px;border-radius:6px;display:inline-block;
}
.diff-ok{background:rgba(214,218,19,0.15);color:var(--success);}
.diff-warn{background:rgba(255,190,11,0.15);color:var(--warn);}
.diff-err{background:rgba(255,77,109,0.15);color:var(--danger);}

/* ── USER FORM ── */
.form-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:16px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-label{font-size:0.75rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.5px;}
.form-input{
  background:#fff;border:1px solid rgba(0,0,0,0.15);border-radius:8px;
  color:var(--text-page);font-family:var(--body);font-size:0.9rem;padding:9px 12px;
  transition:border-color .2s;
}
.form-input:focus{outline:none;border-color:rgba(91,91,95,0.5);}
.form-input option{background:#fff;}
textarea.form-input{resize:vertical;min-height:100px;}
.section-header{
  font-family:var(--display);font-size:1rem;font-weight:900;color:var(--text-page);
  margin-bottom:12px;display:flex;align-items:center;gap:8px;
}
.section-header::after{content:'';flex:1;height:1px;background:rgba(0,0,0,0.1);}

/* ── CALORIC PANEL ── */
.caloric-hero{
  display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px;
}
.caloric-card{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  padding:16px;text-align:center;
}
.caloric-value{font-family:var(--display);font-size:2.5rem;font-weight:900;line-height:1;color:var(--text);}
.caloric-label{font-size:0.7rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-top:6px;}
.methods-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px;}
.method-card{
  background:var(--card2);border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--text);
  padding:12px;text-align:center;
}
.method-name{font-size:0.67rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;}
.method-value{font-family:var(--mono);font-size:1.3rem;font-weight:500;margin:4px 0;}
.method-unit{font-size:0.65rem;color:var(--muted);}

/* ── CALORIMETRY PROTOTYPE LAYOUT ── */
.calo-proto-protocol{
  background:linear-gradient(135deg,rgba(245,158,11,0.08),rgba(230,126,34,0.05));
  border:1px solid rgba(245,158,11,0.22);border-left:4px solid var(--warn);
  border-radius:var(--radius);padding:16px 18px;margin-bottom:14px;color:var(--text);
}
.calo-proto-protocol-head{display:flex;align-items:center;gap:8px;margin-bottom:10px;font-weight:800;color:var(--warn);}
.calo-proto-hero{
  display:grid;grid-template-columns:1.7fr 0.95fr;gap:14px;align-items:stretch;margin-bottom:14px;
  background:linear-gradient(135deg,#0c5563,#0f4257);border-radius:18px;padding:22px 24px;color:#fff;
  box-shadow:0 10px 30px rgba(15,66,87,0.24);border:1px solid rgba(112,212,233,0.18);
}
.calo-proto-kicker{font-size:0.74rem;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.76);}
.calo-proto-hero-value{font-family:var(--display);font-size:3rem;font-weight:900;line-height:0.95;margin-top:10px;}
.calo-proto-hero-unit{margin-top:6px;font-size:0.84rem;color:rgba(255,255,255,0.72);font-weight:600;}
.calo-proto-weights{margin-top:16px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.14);font-size:0.8rem;color:rgba(255,255,255,0.84);}
.calo-proto-weights strong{color:#fff;}
.calo-proto-confidence{
  background:rgba(8,16,30,0.16);border:1px solid rgba(255,255,255,0.12);border-radius:16px;
  padding:18px;text-align:right;display:flex;flex-direction:column;justify-content:center;
}
.calo-proto-confidence-value{font-family:var(--display);font-size:2.5rem;font-weight:900;line-height:1;margin:8px 0 10px;}
.calo-proto-confidence-note{font-size:0.8rem;color:rgba(255,255,255,0.74);line-height:1.45;}
.calo-proto-subgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.calo-proto-mini{
  background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:18px;
  box-shadow:var(--shadow-soft);color:var(--text);
}
.calo-proto-mini-label{font-size:0.76rem;color:var(--muted);font-weight:800;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;}
.calo-proto-mini-value{font-family:var(--display);font-size:2.2rem;font-weight:900;line-height:1;color:var(--text);}
.calo-proto-mini-unit{font-size:0.78rem;color:var(--muted);margin-top:4px;}
.calo-proto-badge{
  display:inline-block;margin-top:10px;padding:5px 12px;border-radius:999px;font-size:0.74rem;font-weight:800;
  letter-spacing:0.02em;
}
.calo-proto-badge.ok{background:rgba(34,197,94,0.14);color:#15803d;}
.calo-proto-badge.warn{background:rgba(245,158,11,0.15);color:#b45309;}
.calo-proto-badge.danger{background:rgba(239,68,68,0.14);color:#dc2626;}
.calo-proto-clinical{display:grid;grid-template-columns:1.05fr 1.05fr 1.15fr;gap:14px;margin-bottom:14px;}
.calo-proto-column{display:grid;gap:12px;}
.calo-proto-box{
  background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:16px 18px;color:var(--text);
  box-shadow:var(--shadow-soft);
}
.calo-proto-box-title{
  font-size:0.74rem;color:var(--muted);font-weight:800;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;
}
.calo-proto-row{
  display:flex;justify-content:space-between;align-items:baseline;gap:10px;padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.06);
}
.calo-proto-row:last-child{border-bottom:none;padding-bottom:0;}
.calo-proto-row label{font-size:0.82rem;color:var(--muted);}
.calo-proto-row span{font-family:var(--mono);font-size:0.94rem;font-weight:700;color:var(--text);text-align:right;}
.calo-proto-note{
  margin-top:10px;padding:10px 12px;border-radius:10px;background:rgba(91,91,95,0.06);font-size:0.78rem;color:var(--text);line-height:1.45;
}
.calo-proto-stack{
  display:flex;height:28px;border-radius:999px;overflow:hidden;background:rgba(0,0,0,0.06);margin:10px 0 8px;
}
.calo-proto-seg{
  display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.74rem;font-weight:800;min-width:0;transition:width 0.35s ease;
}
.calo-proto-seg.fat{background:linear-gradient(90deg,#e67e22,#f39c12);}
.calo-proto-seg.cho{background:linear-gradient(90deg,#2980b9,#3498db);}
.calo-proto-legend{display:flex;justify-content:space-between;gap:10px;font-size:0.76rem;color:var(--muted);}
.calo-proto-table{width:100%;border-collapse:collapse;font-size:0.8rem;}
.calo-proto-table th{
  text-align:left;padding:6px;color:var(--muted);font-weight:800;border-bottom:1px solid var(--border2);
}
.calo-proto-table td{padding:6px;border-bottom:1px solid rgba(0,0,0,0.05);}
.calo-proto-table td:last-child{text-align:right;font-family:var(--mono);font-weight:700;color:var(--text);}
.calo-proto-table tr:last-child td{border-bottom:none;}
.calo-proto-recs{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px;}
.calo-proto-rec{
  background:var(--card);border:1px solid var(--border2);border-radius:14px;padding:16px;text-align:center;box-shadow:var(--shadow-soft);
}
.calo-proto-rec-label{font-size:0.76rem;font-weight:800;margin-bottom:8px;}
.calo-proto-rec-value{font-family:var(--display);font-size:1.85rem;font-weight:900;line-height:1;color:var(--text);}
.calo-proto-rec-unit{font-size:0.74rem;color:var(--muted);margin-top:5px;}
.calo-proto-macro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.calo-proto-macro{
  background:rgba(91,91,95,0.04);border:1px solid var(--border2);border-radius:12px;padding:12px;text-align:center;
}
.calo-proto-macro-value{font-family:var(--display);font-size:1.45rem;font-weight:900;line-height:1;}
.calo-proto-macro-label{font-size:0.74rem;color:var(--muted);margin-top:5px;}
.calo-proto-macro-sub{font-size:0.66rem;color:var(--muted2);margin-top:3px;}

/* ── SESSION TABLE ── */
.session-stats-bar{
  display:flex;gap:16px;flex-wrap:wrap;align-items:center;color:var(--text);
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);
  padding:12px 16px;margin-bottom:12px;
}
.stat-item{font-size:0.78rem;color:var(--muted);}
.stat-item strong{color:var(--text);font-family:var(--mono);}
.log-table-wrap{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  overflow:auto;max-height:540px;
}
.log-table{width:100%;border-collapse:collapse;font-size:0.78rem;}
.log-table thead{position:sticky;top:0;z-index:2;}
.log-table thead tr{background:linear-gradient(135deg,#4b5563,#6b7f96);}
.log-table th{
  padding:10px 12px;text-align:right;font-weight:700;font-size:0.7rem;
  letter-spacing:0.3px;color:rgba(255,255,255,0.9);white-space:nowrap;
}
.log-table th:first-child{text-align:left;}
.log-table td{padding:8px 12px;text-align:right;border-bottom:1px solid rgba(255,255,255,0.06);white-space:nowrap;font-family:var(--mono);font-size:0.76rem;}
.log-table td:first-child{text-align:left;font-family:var(--body);color:var(--muted2);}
.log-table tbody tr:hover{background:rgba(214,218,19,0.04);}
.row-match{background:rgba(214,218,19,0.06)!important;}
.col-cortex{color:var(--accent3)!important;}
.log-table tfoot td{background:rgba(91,91,95,0.3);font-weight:700;color:var(--accent);border-top:1px solid var(--border);}
.log-empty td{text-align:center!important;color:var(--muted);padding:32px!important;font-family:var(--body)!important;}
.row-marker{background:rgba(168,85,247,0.12)!important;}
.row-marker td:first-child{border-left:3px solid var(--accent3);}
.row-artifact{background:rgba(255,188,0,0.10)!important;}
.row-artifact td:first-child{border-left:3px solid #f0a030;}
.art-badge{display:inline-block;background:#f0a030;color:#1a1a2e;font-size:0.6rem;font-weight:800;padding:1px 5px;border-radius:4px;margin-left:4px;vertical-align:middle;animation:artPulse 1.5s ease-in-out infinite;}
@keyframes artPulse{0%,100%{opacity:1;}50%{opacity:0.5;}}
.art-cell{font-size:0.65rem;color:#f0a030;font-weight:700;}

/* ── STABILITY INDICATOR ── */
.stability-strip{
  display:flex;align-items:center;gap:20px;color:var(--text);
  padding:10px 20px;margin:0 0 10px 0;
  background:var(--card);border:1px solid var(--border2);
  border-radius:10px;
}
.stab-timer{text-align:center;min-width:60px;}
.stab-ring{position:relative;display:inline-block;}
.stab-ring-text{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font:600 11px/1 var(--mono);color:#e2e8f0;
}
.stab-timer-label{font-size:9px;color:#94a3b8;text-transform:uppercase;margin-top:2px;}
.stab-metrics{display:flex;gap:16px;flex:1;flex-wrap:wrap;}
.stab-metric{text-align:center;min-width:60px;}
.stab-label{display:block;font-size:9px;color:#78889e;text-transform:uppercase;letter-spacing:0.5px;}
.stab-value{font:600 14px/1.4 var(--mono);color:#e2e8f0;}
.stab-state{display:flex;align-items:center;gap:6px;}
.stab-state-icon{font-size:18px;}
.stab-state-text{font:600 11px/1.2 var(--mono);color:#e2e8f0;text-transform:uppercase;max-width:180px;}
.stab-rest-badge{
  background:rgba(59,130,246,0.2);border:1px solid rgba(59,130,246,0.4);
  color:#60a5fa;border-radius:8px;padding:4px 10px;
  font:600 11px/1.2 var(--mono);
  animation:stabPulse 2s ease-in-out infinite;
}
@keyframes stabPulse{0%,100%{opacity:0.8;}50%{opacity:1;}}
@media(max-width:700px){
  .stability-strip{flex-wrap:wrap;gap:10px;padding:8px 12px;}
  .stab-metrics{gap:10px;}
}

/* ── REPORT ── */
.report-preview{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  padding:32px;min-height:600px;
}
.report-header-block{text-align:center;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border2);}
.report-title{font-family:var(--display);font-size:2rem;font-weight:900;color:var(--accent);}
.report-subtitle{color:var(--muted2);font-size:0.9rem;margin-top:4px;}
.report-meta{font-size:0.78rem;color:var(--muted);margin-top:8px;font-family:var(--mono);}
.report-section{margin-bottom:24px;}
.report-section-title{font-family:var(--display);font-size:1rem;font-weight:800;color:var(--text);margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--border2);}
.report-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.report-field{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:0.85rem;}
.report-field label{color:var(--muted2);}
.report-field span{font-family:var(--mono);color:var(--text);font-weight:500;}

/* Calorimetry report module */
.report-calo-hero{
  display:grid;grid-template-columns:1.7fr 0.9fr;gap:18px;align-items:center;
  background:linear-gradient(135deg,rgba(0,201,167,0.16),rgba(0,121,167,0.14));
  border:1px solid rgba(0,201,167,0.24);border-radius:18px;padding:22px 24px;margin-bottom:14px;
  box-shadow:0 10px 28px rgba(0,0,0,0.16);
}
.report-calo-kicker{
  font-size:0.74rem;color:rgba(255,255,255,0.78);font-weight:800;letter-spacing:0.08em;text-transform:uppercase;
}
.report-calo-main-value{
  font-family:var(--display);font-size:2.8rem;font-weight:900;color:#fff;line-height:0.95;margin-top:8px;
}
.report-calo-main-unit{
  margin-top:4px;font-size:0.82rem;color:rgba(255,255,255,0.72);font-weight:600;letter-spacing:0.04em;
}
.report-calo-weights{
  margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.16);
  font-size:0.78rem;color:rgba(255,255,255,0.82);line-height:1.5;
}
.report-calo-weights strong{color:#fff;}
.report-calo-conf{
  background:rgba(9,16,30,0.18);border:1px solid rgba(255,255,255,0.12);border-radius:16px;
  padding:16px 18px;text-align:right;
}
.report-calo-conf-value{
  font-family:var(--display);font-size:2.2rem;font-weight:900;color:#fff;line-height:1;margin:6px 0;
}
.report-calo-conf-sub{font-size:0.78rem;color:rgba(255,255,255,0.72);line-height:1.45;}
.report-calo-subgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.report-calo-mini{
  background:rgba(255,255,255,0.03);border:1px solid var(--border2);border-radius:14px;padding:16px 18px;
}
.report-calo-mini-label{font-size:0.76rem;color:var(--muted2);font-weight:700;margin-bottom:8px;}
.report-calo-mini-value{font-family:var(--display);font-size:2rem;font-weight:900;line-height:1;color:var(--text);}
.report-calo-mini-unit{font-size:0.78rem;color:var(--muted);margin-top:4px;}
.report-calo-badge{
  display:inline-block;margin-top:8px;padding:5px 10px;border-radius:999px;
  font-size:0.72rem;font-weight:700;letter-spacing:0.02em;
}
.report-calo-badge.ok{background:rgba(34,197,94,0.14);color:#22c55e;}
.report-calo-badge.warn{background:rgba(255,170,0,0.14);color:#ffb347;}
.report-calo-badge.danger{background:rgba(255,80,80,0.16);color:#ff7a7a;}
.report-calo-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px 18px;margin-bottom:14px;}
.report-calo-clinical{display:grid;grid-template-columns:1.05fr 1.05fr 1.15fr;gap:14px;margin-bottom:14px;}
.report-calo-column{display:grid;gap:10px;}
.report-calo-box{
  background:rgba(255,255,255,0.03);border:1px solid var(--border2);border-radius:14px;padding:14px 16px;
}
.report-calo-box-title{
  font-size:0.74rem;color:var(--muted2);font-weight:700;letter-spacing:0.04em;
  text-transform:uppercase;margin-bottom:10px;
}
.report-calo-signal-row{
  display:flex;justify-content:space-between;align-items:baseline;padding:7px 0;
  border-bottom:1px solid rgba(255,255,255,0.05);gap:10px;
}
.report-calo-signal-row:last-child{border-bottom:none;padding-bottom:0;}
.report-calo-signal-row label{font-size:0.8rem;color:var(--muted2);}
.report-calo-signal-row span{font-family:var(--mono);font-size:0.92rem;color:var(--text);font-weight:700;text-align:right;}
.report-calo-compare-note{
  margin-top:10px;padding:10px 12px;border-radius:10px;background:rgba(255,255,255,0.04);
  font-size:0.78rem;color:var(--text);line-height:1.45;
}
.report-calo-stack{
  display:flex;height:28px;border-radius:999px;overflow:hidden;background:rgba(255,255,255,0.05);
  margin:10px 0 6px;
}
.report-calo-seg{
  display:flex;align-items:center;justify-content:center;font-size:0.73rem;font-weight:800;color:#fff;
  min-width:0;transition:width 0.35s ease;
}
.report-calo-seg.fat{background:linear-gradient(90deg,#f39c12,#e67e22);}
.report-calo-seg.cho{background:linear-gradient(90deg,#3498db,#00aeff);}
.report-calo-legend{display:flex;justify-content:space-between;gap:10px;font-size:0.75rem;color:var(--muted2);}
.report-calo-table{width:100%;border-collapse:collapse;font-size:0.8rem;}
.report-calo-table th{
  text-align:left;padding:6px;color:var(--muted2);font-weight:700;border-bottom:1px solid var(--border2);
}
.report-calo-table td{padding:6px;border-bottom:1px solid rgba(255,255,255,0.05);}
.report-calo-table td:last-child{text-align:right;font-family:var(--mono);font-weight:700;color:var(--text);}
.report-calo-methods{
  width:100%;font-size:0.8rem;border-collapse:collapse;margin-bottom:12px;background:rgba(255,255,255,0.02);
  border:1px solid var(--border2);border-radius:14px;overflow:hidden;
}
.report-calo-methods th{padding:8px 10px;color:var(--muted2);text-align:left;background:rgba(255,255,255,0.03);}
.report-calo-methods td{padding:8px 10px;border-top:1px solid rgba(255,255,255,0.05);}
.report-calo-methods td:nth-child(2),.report-calo-methods td:nth-child(3),
.report-calo-methods th:nth-child(2),.report-calo-methods th:nth-child(3){text-align:right;font-family:var(--mono);}
.report-calo-methods tr.is-total td{border-top:1px solid rgba(0,201,167,0.35);font-weight:700;}

/* ── FIFA-STYLE RADAR SECTION ── */
.radar-layout{display:grid;grid-template-columns:260px 1fr;gap:24px;align-items:start;}
.radar-card{
  background:linear-gradient(145deg,#0a0f1e,#12172a);
  border:2px solid rgba(214,218,19,0.35);border-radius:16px;
  padding:20px;text-align:center;position:relative;overflow:hidden;
}
.radar-card::before{
  content:'';position:absolute;top:-40px;right:-40px;
  width:160px;height:160px;border-radius:50%;
  background:radial-gradient(circle,rgba(214,218,19,0.15),transparent 70%);
  pointer-events:none;
}
.radar-score-badge{
  display:inline-flex;align-items:center;justify-content:center;
  width:72px;height:72px;border-radius:12px;
  background:linear-gradient(135deg,#d6da13,#00aeff);
  font-family:var(--display);font-size:2.2rem;font-weight:900;
  color:#06091a;margin-bottom:8px;box-shadow:0 0 24px rgba(214,218,19,0.5);
}
.radar-patient-name{font-family:var(--display);font-size:1.1rem;font-weight:800;color:#fff;letter-spacing:0.05em;text-transform:uppercase;}
.radar-category{font-size:0.75rem;color:rgba(214,218,19,0.85);margin-top:3px;letter-spacing:0.08em;font-weight:700;}
.radar-stat-row{display:flex;justify-content:space-between;align-items:center;margin-top:8px;font-size:0.8rem;}
.radar-stat-row span:first-child{color:rgba(255,255,255,0.6);}
.radar-stat-row span:last-child{font-family:var(--mono);font-weight:700;color:#fff;}
.radar-canvas-wrap{position:relative;height:260px;}

/* Attribute bars (right panel) */
.attr-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px 16px;margin-top:8px;}
.attr-item{font-size:0.78rem;}
.attr-label{color:var(--muted2);margin-bottom:3px;font-weight:600;letter-spacing:0.04em;}
.attr-bar-row{display:flex;align-items:center;gap:8px;}
.attr-bar-bg{flex:1;height:6px;background:rgba(255,255,255,0.08);border-radius:3px;overflow:hidden;}
.attr-bar-fill{height:100%;border-radius:3px;transition:width 0.5s ease;}
.attr-val{font-family:var(--mono);font-weight:700;font-size:0.82rem;min-width:28px;text-align:right;}

/* Fitness rating bar — enhanced */
.fitness-rating-wrap{margin:18px 0;padding:16px;background:rgba(255,255,255,0.02);border:1px solid var(--border2);border-radius:var(--radius);}
.fitness-rating-label{font-size:0.78rem;color:var(--muted2);margin-bottom:10px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;}
.fitness-rating-track{display:flex;border-radius:10px;overflow:hidden;height:36px;gap:2px;position:relative;}
.fitness-zone{
  flex:1;display:flex;align-items:center;justify-content:center;
  font-size:0.62rem;font-weight:800;letter-spacing:0.06em;
  opacity:0.3;transition:all 0.4s cubic-bezier(.4,0,.2,1);cursor:default;
  position:relative;text-shadow:0 1px 2px rgba(0,0,0,0.3);
}
.fitness-zone.active{
  opacity:1;transform:scaleY(1.15);z-index:2;
  box-shadow:0 0 18px rgba(255,255,255,0.25),inset 0 1px 0 rgba(255,255,255,0.2);
  border-radius:6px;
}
.fitness-zone.active::after{
  content:'▼';position:absolute;bottom:-14px;left:50%;transform:translateX(-50%);
  font-size:0.6rem;color:inherit;text-shadow:0 0 6px currentColor;
}
.fitness-result{
  display:flex;align-items:center;gap:10px;margin-top:14px;padding:8px 12px;
  background:rgba(255,255,255,0.04);border-radius:8px;border:1px solid var(--border2);
}
.fitness-result-dot{
  width:10px;height:10px;border-radius:50%;flex-shrink:0;
  box-shadow:0 0 8px currentColor;
}
.fitness-result-text{font-size:0.78rem;color:var(--text);line-height:1.4;}
.fitness-result-text strong{font-weight:800;}

/* Specialties / Traits */
.spec-grid{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
.spec-badge{
  padding:4px 10px;border-radius:20px;font-size:0.72rem;font-weight:700;
  letter-spacing:0.05em;border:1px solid;
}
.spec-green{background:rgba(34,197,94,0.12);border-color:rgba(34,197,94,0.4);color:#22c55e;}
.spec-blue{background:rgba(0,174,255,0.12);border-color:rgba(0,174,255,0.4);color:#00aeff;}
.spec-orange{background:rgba(255,160,0,0.12);border-color:rgba(255,160,0,0.4);color:#ffa000;}
.spec-red{background:rgba(255,80,80,0.12);border-color:rgba(255,80,80,0.35);color:#ff5050;}

/* ── NOTICE BOX ── */
.notice{
  background:rgba(214,218,19,0.06);border:1px solid rgba(214,218,19,0.25);
  border-radius:var(--radius-sm);padding:10px 14px;font-size:0.8rem;
  color:#374151;margin-bottom:12px;
}

/* ── NOTIFICATION TOAST ── */
.toast{
  position:fixed;top:76px;right:16px;z-index:10001;color:var(--text);
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:12px 16px;font-size:0.84rem;box-shadow:0 8px 32px rgba(0,0,0,0.4);
  transform:translateX(120%);transition:transform .3s ease;max-width:300px;
}
.toast.show{transform:translateX(0);}
.toast.success{border-left:3px solid var(--success);}
.toast.error{border-left:3px solid var(--danger);}
.toast.info{border-left:3px solid var(--primary-light);}

/* ── AMBIENT ── */
.ambient-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-bottom:16px;}

/* ── PROTOCOL MODAL ── */
.protocol-overlay{
  position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.7);
  display:none;align-items:center;justify-content:center;
}
.protocol-modal{
  background:var(--card);border:1px solid var(--border2);border-radius:12px;color:var(--text);
  padding:28px 24px;max-width:520px;width:90%;box-shadow:0 16px 64px rgba(0,0,0,0.5);
}
.protocol-modal h3{font-family:var(--display);font-size:1.1rem;margin:0 0 16px;color:var(--text);}
.protocol-steps{list-style:none;padding:0;margin:0 0 18px;}
.protocol-steps li{
  display:flex;align-items:flex-start;gap:10px;padding:8px 0;
  font-size:0.84rem;color:var(--muted2);border-bottom:1px solid var(--border);
}
.protocol-steps li:last-child{border-bottom:none;}
.protocol-steps .step-icon{font-size:1.2rem;flex-shrink:0;margin-top:1px;}
.protocol-steps .step-text strong{color:var(--text);}
.protocol-check{
  display:flex;align-items:center;gap:8px;margin:14px 0;
  font-size:0.82rem;color:var(--muted2);cursor:pointer;
}
.protocol-check input{accent-color:var(--primary-light);width:16px;height:16px;}
.protocol-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:16px;}

/* ── HRV PANEL ── */
.hrv-panels{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
.hrv-side{
  background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);
  padding:16px;
}

/* ── INFO BOX ── */
.info-box{
  background:rgba(110,110,115,0.06);border:1px solid rgba(110,110,115,0.25);
  border-radius:var(--radius-sm);padding:12px 16px;font-size:0.8rem;
  color:#374151;line-height:1.6;margin-top:10px;
}

/* ── SPLASH / LOGIN ── */
#splash{
  position:fixed;inset:0;z-index:9998;
  background:linear-gradient(135deg,#0a0f1e 0%,#0c1225 50%,#0a0f1e 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;
  transition:opacity .8s ease;
}
.splash-brand{font-family:var(--display);font-size:3rem;font-weight:900;text-align:center;color:var(--text);}
.splash-brand span{color:var(--accent);}
.splash-subtitle{color:var(--muted);font-size:0.95rem;text-align:center;max-width:380px;}
.login-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);
  padding:32px;width:100%;max-width:360px;
  box-shadow:0 20px 60px rgba(0,0,0,0.5);
}
.login-card h3{font-family:var(--display);font-size:1.1rem;font-weight:800;margin-bottom:20px;color:var(--accent);}
.login-field{margin-bottom:14px;}
.login-field label{display:block;font-size:0.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
.login-field input{
  width:100%;background:var(--card2);border:1px solid var(--border2);border-radius:8px;
  color:var(--text);font-family:var(--body);font-size:0.95rem;padding:10px 12px;
}
.login-field input:focus{outline:none;border-color:rgba(214,218,19,0.5);}
.btn-login{
  width:100%;padding:12px;background:linear-gradient(135deg,var(--primary-light),var(--accent));
  color:#2a2a32;border:none;border-radius:10px;font-family:var(--display);font-size:1rem;
  font-weight:800;cursor:pointer;letter-spacing:0.3px;margin-top:4px;
  transition:all .2s ease;
}
.btn-login:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(214,218,19,0.3);}

/* ── THRESHOLDS DISPLAY ── */
.threshold-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.threshold-card{
  background:var(--card2);border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--text);
  padding:14px;text-align:center;
}
.threshold-label{font-size:0.67rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;}
.threshold-value{font-family:var(--display);font-size:1.6rem;font-weight:900;margin:6px 0;}

/* ── EVENT MARKERS LOG ── */
.markers-bar{
  display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;
}
.marker-tag{
  font-family:var(--mono);font-size:0.68rem;font-weight:700;
  padding:3px 8px;border-radius:6px;
  background:rgba(168,85,247,0.15);border:1px solid rgba(168,85,247,0.3);color:#c084fc;
}
/* ── MARKER INPUT MODAL ── */
#marker-modal-overlay{
  position:fixed;inset:0;z-index:9999;
  background:rgba(0,0,0,0.72);
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:opacity 0.18s ease;
}
#marker-modal-overlay.open{opacity:1;pointer-events:all;}
#marker-modal{
  background:var(--card);border:1px solid var(--border2);color:var(--text);
  border-radius:16px;padding:24px 28px 20px;
  width:min(480px,94vw);box-shadow:0 24px 64px rgba(0,0,0,0.55);
  transform:translateY(12px);transition:transform 0.18s ease;
}
#marker-modal-overlay.open #marker-modal{transform:translateY(0);}
.marker-modal-title{
  font-size:1rem;font-weight:800;color:var(--fg);
  margin-bottom:4px;display:flex;align-items:center;gap:8px;
}
.marker-modal-sub{font-size:0.72rem;color:var(--muted2);margin-bottom:16px;}
.marker-modal-label{font-size:0.72rem;font-weight:700;color:var(--muted);
  text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
.borg-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:5px;
  margin-bottom:16px;
}
.borg-btn{
  border:1px solid rgba(255,255,255,0.12);border-radius:8px;
  padding:6px 2px;font-size:0.75rem;font-weight:700;cursor:pointer;
  background:rgba(255,255,255,0.04);color:var(--fg);
  transition:all 0.12s;text-align:center;
}
.borg-btn:hover{background:rgba(255,255,255,0.12);}
.borg-btn.selected{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent);}
.borg-label{font-size:0.6rem;color:var(--muted2);display:block;margin-top:1px;font-weight:400;}
.marker-cat-row{
  display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;
}
.marker-cat-btn{
  font-size:0.7rem;font-weight:700;padding:4px 10px;border-radius:20px;
  border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.04);
  color:var(--muted2);cursor:pointer;transition:all 0.12s;
}
.marker-cat-btn.active{background:rgba(168,85,247,0.2);border-color:#a855f7;color:#c084fc;}
.marker-text-input{
