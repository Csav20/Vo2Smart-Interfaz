// ── Referencia demográfica ACSM ──
function getAgeReference(){
  const _rp=getPatient();
  const age=_rp.age;
  const sex=_rp.sex;
  const activity=_rp.activity;
  if(age<=0) return null;
  const isFem=sex==='F'||sex==='Femenino'||sex==='f';
  const tables={
    M:[[20,31,42,52,60],[19,30,41,51,59],[18,29,40,50,58],[16,27,38,47,56],[15,25,36,45,54],[13,22,32,41,50]],
    F:[[18,26,35,44,52],[17,25,34,43,51],[16,24,33,42,50],[14,22,31,39,48],[13,20,29,37,46],[11,18,25,33,43]]
  };
  const ageBrackets=['<30','30-39','40-49','50-59','60-69','70+'];
  const ageIdx=age<30?0:age<40?1:age<50?2:age<60?3:age<70?4:5;
  const tbl=isFem?tables.F:tables.M;
  const th=tbl[ageIdx]||tbl[0];
  const labels=['Muy Bajo','Bajo','Regular','Bueno','Excelente','Elite'];
  const colors=['#c0392b','#e67e22','#f1c40f','#27ae60','#00aeff','#d6da13'];
  const actLabels={sedentary:'Sedentario',light:'Act. Ligera',moderate:'Act. Moderada',active:'Activo','very-active':'Muy Activo',athlete:'Atleta'};
  const predicted=isFem?44.2-0.26*age:52-0.25*age;
  const sexLabel=isFem?'\u2640':'♂';
  const profile=`${sexLabel} ${age} a\u00f1os \u00b7 ${actLabels[activity]||activity}`;
  const ranges=[];
  for(let i=0;i<6;i++){
    const lo=i===0?0:th[i-1];
    const hi=i<5?th[i]:99;
    ranges.push({label:labels[i],lo,hi,color:colors[i]});
  }
  return {age,sex,ageIdx,ageBracket:ageBrackets[ageIdx],thresholds:th,labels,colors,ranges,predicted,profile,activity};
}

function updateRefPanel(vo2){
  const ref=getAgeReference();
  const panel=document.getElementById('ref-panel');
  if(!ref||!panel){if(panel)panel.style.display='none';return;}
  panel.style.display='';
  setText('ref-profile',ref.profile);
  // VO2 predicho en header del panel
  setText('ref-vo2pred',ref.predicted.toFixed(1));
  // Rango de referencia en tarjeta hero: Bajo→Bueno para la edad/sexo
  const th=ref.thresholds;
  const refEl=document.getElementById('d-vo2-ref');
  if(refEl) refEl.textContent=`${th[0]}–${th[3]}`;
  const cls=aerobicClass(vo2,ref.age,ref.sex);
  const badge=document.getElementById('ref-class-badge');
  if(badge){badge.textContent=cls.label;badge.style.background=cls.color+'33';badge.style.color=cls.color;badge.style.border='1px solid '+cls.color+'66';}
  const vo2Badge=document.getElementById('d-vo2-class');
  if(vo2Badge){vo2Badge.textContent=cls.label;vo2Badge.style.background=cls.color+'33';vo2Badge.style.color=cls.color;}
  const container=document.getElementById('ref-ranges');
  if(container){
    container.innerHTML=ref.ranges.map((r,i)=>{
      const isActive=cls.level===i;
      const rangeStr=i<5?`${r.lo}-${r.hi}`:`>${r.lo}`;
      return `<div class="ref-range-block${isActive?' active':''}" style="color:${r.color};background:${r.color}${isActive?'22':'11'};">
        <div class="ref-range-label">${r.label}</div><div class="ref-range-val">${rangeStr}</div></div>`;
    }).join('');
  }
  // Nota de actividad sedentaria
  const noteEl=document.getElementById('ref-activity-note');
  if(noteEl){
    const isSed=ref.activity==='sedentary'||ref.activity==='light';
    if(isSed){
      noteEl.style.display='';
      noteEl.textContent=`⚠ Nivel de actividad ${ref.activity==='sedentary'?'sedentario':'ligero'}: valores en rango Muy Bajo–Regular son esperados para esta demografía (ACSM 2022).`;
    } else {
      noteEl.style.display='none';
    }
  }
}

function toScore(val, min, max){
  if(val===null||val===undefined||isNaN(val))return 0;
  return Math.min(99,Math.max(1,Math.round((val-min)/(max-min)*98)+1));
}

function aerobicClass(vo2, age, sex){
  const isFem = sex==='F'||sex==='Femenino'||sex==='f';
  const tables = {
    M:[[20,31,42,52,60],[19,30,41,51,59],[18,29,40,50,58],[16,27,38,47,56],[15,25,36,45,54],[13,22,32,41,50]],
    F:[[18,26,35,44,52],[17,25,34,43,51],[16,24,33,42,50],[14,22,31,39,48],[13,20,29,37,46],[11,18,25,33,43]]
  };
  const ageIdx = age<30?0:age<40?1:age<50?2:age<60?3:age<70?4:5;
  const tbl = isFem?tables.F:tables.M;
  const th = tbl[ageIdx]||tbl[0];
  let level=0;
  if(vo2>=th[4])level=5; else if(vo2>=th[3])level=4; else if(vo2>=th[2])level=3;
  else if(vo2>=th[1])level=2; else if(vo2>=th[0])level=1; else level=0;
  const labels=['Muy Bajo','Bajo','Regular','Bueno','Excelente','Élite/Superior'];
  const colors=['#c0392b','#e67e22','#f1c40f','#27ae60','#00aeff','#d6da13'];
  return {level,label:labels[level],color:colors[level]};
}

function getSpecialties(d){
  const specs=[];
  if(d.vo2Peak>55) specs.push({label:'Alto VO₂max',cls:'spec-green'});
  if(d.vo2Peak>65) specs.push({label:'Resistencia élite',cls:'spec-green'});
  if(d.rer<0.85&&d.rer>0) specs.push({label:'Oxidador de grasas',cls:'spec-blue'});
  if(d.rer>=0.85&&d.rer<0.95) specs.push({label:'Sustrato mixto',cls:'spec-orange'});
  if(d.rer>=1.10) specs.push({label:'Alta capacidad glucolítica',cls:'spec-orange'});
  if(d.hr>180) specs.push({label:'FC alta',cls:'spec-orange'});
  if(d.ve>100) specs.push({label:'Alta ventilación',cls:'spec-blue'});
  if(d.eePeak>15) specs.push({label:'Alto gasto calórico',cls:'spec-green'});
  if(d.pctPred>=100) specs.push({label:'Supera predicción',cls:'spec-green'});
  if(d.pctPred>=110) specs.push({label:'Rendimiento excepcional',cls:'spec-green'});
  if(d.pctPred<70&&d.pctPred>0) specs.push({label:'Capacidad reducida',cls:'spec-red'});
  if(d.vo2Peak>0&&d.hr>0&&d.vo2Peak/d.hr>0.22) specs.push({label:'Pulso O₂ eficiente',cls:'spec-blue'});
  return specs;
}

function renderAttrBars(attrs){
  const barColor = v => v>=80?'#d6da13':v>=65?'#27ae60':v>=50?'#f1c40f':v>=35?'#e67e22':'#c0392b';
  const grid = document.getElementById('attr-grid');
  if(!grid)return;
  grid.innerHTML = attrs.map(a=>`
    <div class="attr-item">
      <div class="attr-label">${a.label}</div>
      <div class="attr-bar-row">
        <div class="attr-bar-bg"><div class="attr-bar-fill" style="width:${a.score}%;background:${barColor(a.score)};"></div></div>
        <span class="attr-val" style="color:${barColor(a.score)};">${a.score}</span>
      </div>
      <div style="font-size:0.68rem;color:var(--muted);margin-top:1px;">${a.raw}</div>
    </div>
  `).join('');
}

function renderSpecialties(specs){
  const grid=document.getElementById('spec-grid');
  if(!grid)return;
  if(!specs.length){grid.innerHTML='<span class="spec-badge spec-green" style="opacity:0.4;">Sin datos suficientes</span>';return;}
  grid.innerHTML=specs.map(s=>`<span class="spec-badge ${s.cls}">${s.label}</span>`).join('');
}

function renderFitnessRating(level,color){
  document.querySelectorAll('.fitness-zone').forEach(z=>{
    z.classList.toggle('active',parseInt(z.dataset.level)===level);
  });
  const result=document.getElementById('fitness-result');
  const dot=document.getElementById('fitness-result-dot');
  if(result){result.style.display=level>=0?'flex':'none';}
  if(dot&&color){dot.style.background=color;dot.style.color=color;}
}

let radarChartInst=null;
function renderRadar(labels, data, pointColors){
  const ctx=document.getElementById('radarChart');
  if(!ctx)return;
  if(radarChartInst){radarChartInst.destroy();radarChartInst=null;}
  // Use dual-compatible colors: visible on both dark UI (#0a0f1e) and white print backgrounds
  const tickC='rgba(143,160,192,0.6)';   // muted2 @ 60% — visible on dark & light
  const gridC='rgba(143,160,192,0.2)';   // subtle grid lines
  const angleC='rgba(143,160,192,0.15)'; // subtle angle lines
  const labelC='rgba(143,160,192,0.95)'; // bright enough for dark bg, dim enough for print
  radarChartInst=new Chart(ctx,{
    type:'radar',
    data:{
      labels,
      datasets:[{
        label:'Perfil Cardiorrespiratorio',
        data,
        fill:true,
        backgroundColor:'rgba(214,218,19,0.15)',
        borderColor:'rgba(214,218,19,0.85)',
        borderWidth:2.5,
        pointBackgroundColor:pointColors,
        pointBorderColor:'#fff',
        pointBorderWidth:1.5,
        pointRadius:6,
        pointHoverRadius:8,
      }]
    },
    options:{
      animation:{duration:600,easing:'easeOutQuart'},
      responsive:true,
      maintainAspectRatio:false,
      scales:{
        r:{
          min:0,max:99,
          ticks:{stepSize:20,display:true,
            color:tickC,font:{size:9},
            backdropColor:'transparent'},
          grid:{color:gridC},
          angleLines:{color:angleC},
          pointLabels:{
            color:labelC,
            font:{size:11,weight:'700'},
          }
        }
      },
      plugins:{
        legend:{display:false},
        tooltip:{
          callbacks:{
            label:ctx2=>`${ctx2.label}: ${ctx2.raw}`
          }
        }
      }
    }
  });
}

