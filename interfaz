// ── Virtual TFT Display ────────────────────────────────────────────────────
// Pixel-faithful replica of device TFT from main.cpp
// TTGO T-Display: 240×135 landscape | ESP32-C6 Waveshare: 172×320 portrait
// Layout constants recalculated dynamically via _vtSetLayout()

const _VTC = {
  PRI:'#005fa0', SUC:'#00dd00', ORG:'#ffa600', GRY:'#848284',
  CRIT:'#ff2020', ACC:'#00e8ff', WARN:'#ffbc00', DIM:'#4a3a6a',
  WHT:'#ffffff', SEP:'#1c1c2e',
  W:240, H:135, HDR:22, ROW:23, ROW_Y:24, LX:6, VAL_X:206, UNIT_X:210
};

// Recalculate layout constants for a given screen size
function _vtSetLayout(w, h) {
  _VTC.W = w;
  _VTC.H = h;
  _VTC.HDR = Math.round(22 * h / 135);
  _VTC.ROW = Math.round(23 * h / 135);
  _VTC.ROW_Y = _VTC.HDR + 2;
  _VTC.LX = 6;
  _VTC.UNIT_X = w - 30;
  _VTC.VAL_X = _VTC.UNIT_X - 4;
  // Resize canvas element
  const canvas = document.getElementById('virt-tft-canvas');
  if (canvas) {
    // CSS display size: scale to max 240px wide or 320px tall
    const maxCssW = 240, maxCssH = 320;
    const scale = Math.min(maxCssW / w, maxCssH / h, 1);
    canvas.width = w;
    canvas.height = h;
    canvas.style.width = Math.round(w * scale) + 'px';
    canvas.style.height = Math.round(h * scale) + 'px';
  }
}

// Live device state — updated from BLE stream + command responses
const _VD = {
  stage: null,        // boot stage string or null = offline
  screenNr: 1,        // active operational screen 1-6
  deviceName: '',
  board: '',          // board name from GET_CONFIG (e.g. "Waveshare ESP32-C6-LCD-1.47")
  version: 'V5.0',
  demo: false,
  sessionStartMs: 0,  // set when first live data arrives
  sensors: { serial:null, bt:null, bmp:null, o2:null, co2:null, flow:null },
  cfg: { weight:'--', correction:'--', o2base:20.9 },
  data: {             // mirrors BLE JSON stream variables from main.cpp
    vo2:0, vo2max:0, vco2:0, rq:0,
    ve:0, freq:0, vol:0,
    o2:20.9, co2:0.04, temp:20, humid:50,
    pres:101300, rho:1.2,
    calTotal:0, calHour:0,
    batteryV:4.2, battery:100,
    co2_on:false
  }
};

// ── Canvas primitives ────────────────────────────────────────────────────────
function _vtFont(ctx, px, color, align='left') {
  ctx.font=`bold ${px}px "Courier New",monospace`;
  ctx.fillStyle=color; ctx.textAlign=align; ctx.textBaseline='middle';
}
// drawHeader() — blue bg + title left + elapsed center + page dots right
function _vtPageHdr(ctx, title, page) {
  ctx.fillStyle=_VTC.PRI; ctx.fillRect(0,0,_VTC.W,_VTC.HDR);
  ctx.fillStyle=_VTC.ORG; ctx.fillRect(0,_VTC.HDR,_VTC.W,1);
  _vtFont(ctx,11,_VTC.WHT,'left'); ctx.fillText(title,_VTC.LX,_VTC.HDR/2);
  const e=_VD.sessionStartMs?Math.floor((Date.now()-_VD.sessionStartMs)/1000):0;
  const ts=`${String(Math.floor(e/3600)).padStart(2,'0')}:${String(Math.floor((e%3600)/60)).padStart(2,'0')}:${String(e%60).padStart(2,'0')}`;
  _vtFont(ctx,10,_VTC.ORG,'center'); ctx.fillText(ts,_VTC.W/2,_VTC.HDR/2);
  // Page dots (dotSpacing=10, dotR=3, dotStartX=W-totalPages*10-6)
  const sp=10,r=3,sx=_VTC.W-6*sp-6;
  for(let i=0;i<6;i++){
    const cx=sx+i*sp+r, cy=_VTC.HDR/2;
    ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
    if(i===page-1){ctx.fillStyle=_VTC.ORG;ctx.fill();}
    else{ctx.strokeStyle=_VTC.GRY;ctx.lineWidth=1;ctx.stroke();}
  }
}
// drawRow() — separator + label gray left + value right at VAL_X + unit at UNIT_X
function _vtRow(ctx, row, lbl, val, unit, color) {
  const y=_VTC.ROW_Y+row*_VTC.ROW, ty=y+_VTC.ROW/2;
  if(row>0){ctx.fillStyle=_VTC.SEP; ctx.fillRect(_VTC.LX,y,_VTC.W-2*_VTC.LX,1);}
  _vtFont(ctx,11,_VTC.GRY,'left');   ctx.fillText(lbl, _VTC.LX, ty);
  _vtFont(ctx,14,color,'right');      ctx.fillText(val, _VTC.VAL_X, ty);
  _vtFont(ctx, 8,_VTC.DIM,'left');   ctx.fillText(unit,_VTC.UNIT_X, ty);
}
// drawBigMetric() — label small top-left + huge value centered + unit right
function _vtBig(ctx, y, lbl, val, unit, color) {
  _vtFont(ctx,11,_VTC.GRY,'left');  ctx.fillText(lbl, _VTC.LX, y);
  _vtFont(ctx,34,color,'center');   ctx.fillText(val, _VTC.W/2+10, y+24);
  _vtFont(ctx, 8,_VTC.DIM,'right'); ctx.fillText(unit,_VTC.W-8, y+24);
}
// drawBatteryIcon() — positioned relative to bottom-right of screen
function _vtBattery(ctx) {
  const v=_VD.data.batteryV;
  const pct=Math.max(0,Math.min(100,((v-3.3)/0.9)*100));
  const fc=v>=4.3?_VTC.ACC:pct>50?_VTC.SUC:pct>20?_VTC.WARN:_VTC.CRIT;
  const bc=v>=4.3?_VTC.WHT:_VTC.GRY;
  const bw=22,bh=9,bx=_VTC.W-bw-6,by=_VTC.H-bh-3;
  ctx.strokeStyle=bc; ctx.lineWidth=1; ctx.strokeRect(bx,by,bw,bh);
  ctx.fillStyle=bc; ctx.fillRect(bx+bw,by+2,2,bh-4);
  const fw=Math.round((bw-4)*pct/100);
  if(fw>0){ctx.fillStyle=fc; ctx.fillRect(bx+2,by+2,fw,bh-4);}
  _vtFont(ctx,8,_VTC.GRY,'right'); ctx.fillText(v.toFixed(1)+'V',bx-3,by+bh/2);
}

// ── Operational screens 1-6 (tftScreen1-5 + tftParameters) ──────────────────
function _vtS1(ctx) { // tftScreen1 — Performance
  const d=_VD.data, co2on=d.co2_on||d.vco2>0.01;
  _vtPageHdr(ctx,'PERFORMANCE',1);
  _vtRow(ctx,0,'VO2',    d.vo2.toFixed(1),  'ml/kg/min',_VTC.SUC);
  _vtRow(ctx,1,'VO2max', d.vo2max.toFixed(1),'ml/kg/min',_VTC.ACC);
  co2on?_vtRow(ctx,2,'VCO2',d.vco2.toFixed(1),'ml/kg/min',_VTC.ORG)
       :_vtRow(ctx,2,'VE',  d.ve.toFixed(1),  'L/min',   _VTC.ORG);
  _vtRow(ctx,3,'RQ', d.rq.toFixed(2), '', _VTC.WHT);
  const zc=d.vo2<20?_VTC.GRY:d.vo2<35?_VTC.SUC:d.vo2<50?_VTC.ORG:_VTC.CRIT;
  const bY=_VTC.H-4; ctx.fillStyle='#1a1a1a'; ctx.fillRect(0,bY,_VTC.W,4);
  ctx.fillStyle=zc; ctx.fillRect(0,bY,Math.min(_VTC.W,Math.round(d.vo2*_VTC.W/70)),4);
  _vtBattery(ctx);
}
function _vtS2(ctx) { // tftScreen2 — Gas/Energy
  const d=_VD.data, co2on=d.co2_on||d.vco2>0.01;
  const dO2=(parseFloat(_VD.cfg.o2base)-d.o2);
  _vtPageHdr(ctx,'GAS / ENERGY',2);
