    container.innerHTML='<div style="padding:14px;text-align:center;color:var(--muted);font-size:0.8rem;">Sin sesiones guardadas</div>';
    return;
  }
  const filter=(document.getElementById('session-search')?.value||'').toLowerCase();
  const filtered=filter?sessions.filter(s=>s.patient.toLowerCase().includes(filter)||s.evaluator.toLowerCase().includes(filter)||s.id.includes(filter)):sessions;
  if(!filtered.length){
    container.innerHTML='<div style="padding:14px;text-align:center;color:var(--muted);font-size:0.8rem;">No se encontraron resultados para "'+escHtml(filter)+'"</div>';
    return;
  }
  let html='';
  filtered.forEach(s=>{
    const d=new Date(s.date);
    const dateStr=d.toLocaleDateString('es',{day:'2-digit',month:'short',year:'numeric'});
    const dur=s.duration?Math.floor(s.duration/60)+'m '+('0'+s.duration%60).slice(-2)+'s':'--';
    const vo2Color=s.peaks.vo2>=40?'#d6da13':s.peaks.vo2>=30?'#fbbf24':'#f87171';
    html+=`<div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border2);font-size:0.78rem;">`
      +`<div style="flex:1;min-width:0;">`
      +`<div style="font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(s.patient)}</div>`
      +`<div style="color:var(--muted);font-size:0.68rem;">${escHtml(dateStr)} · ${escHtml(s.protocol)} · ${dur} · ${s.dataPoints} pts</div>`
      +`<div style="color:var(--muted2);font-size:0.65rem;">Evaluador: ${escHtml(s.evaluator)}${s.institution?' · '+escHtml(s.institution):''}</div>`
      +`</div>`
      +`<div style="text-align:right;">`
      +`<div style="font-size:1.1rem;font-weight:800;color:${vo2Color};font-family:var(--mono);">${s.peaks.vo2>0?s.peaks.vo2:'--'}</div>`
