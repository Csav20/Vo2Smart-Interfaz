              <button onclick="setBariPhase(1,this)" class="btn btn-ghost btn-sm bari-phase-btn" style="border-color:rgba(59,130,246,0.4);color:#60a5fa;">Fase 1 — Líquida</button>
              <button onclick="setBariPhase(2,this)" class="btn btn-ghost btn-sm bari-phase-btn" style="border-color:rgba(245,158,11,0.4);color:#fbbf24;">Fase 2 — Puré</button>
              <button onclick="setBariPhase(3,this)" class="btn btn-ghost btn-sm bari-phase-btn" style="border-color:rgba(34,197,94,0.4);color:#22c55e;">Fase 3 — Sólida</button>
              <button onclick="setBariPhase(4,this)" class="btn btn-ghost btn-sm bari-phase-btn" style="border-color:rgba(214,218,19,0.4);color:var(--accent);">Fase 4 — Avanzada</button>
            </div>
            <div id="bari-phase-desc" style="font-size:0.78rem;color:var(--muted2);background:rgba(255,255,255,0.03);border:1px solid var(--border2);border-radius:8px;padding:10px;line-height:1.5;">Seleccione la fase post-quirúrgica para ajustar los rangos calóricos y las recomendaciones clínicas.</div>
          </div>
        </div>

        <!-- TMB — 4 ecuaciones -->
        <div class="section-header" style="margin-bottom:10px;">🔥 Tasa Metabólica Basal — Comparativa de Ecuaciones</div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
          <div class="metric-mini" style="height:auto;min-height:80px;max-height:none;">
            <div class="mm-label">Mifflin-St Jeor</div>
            <div class="mm-value" id="bari-mifflin" style="font-size:1.2rem;color:var(--accent);">--</div>
            <div class="mm-unit">kcal/día</div>
            <div style="font-size:0.6rem;color:var(--muted2);margin-top:3px;">(10×P)+(6.25×T)−(5×E)±5</div>
          </div>
          <div class="metric-mini" style="height:auto;min-height:80px;max-height:none;">
            <div class="mm-label">Owen</div>
            <div class="mm-value" id="bari-owen" style="font-size:1.2rem;color:#60a5fa;">--</div>
            <div class="mm-unit">kcal/día</div>
            <div style="font-size:0.6rem;color:var(--muted2);margin-top:3px;">879+(10.2×P) ♂ · 795+(7.18×P) ♀</div>
          </div>
          <div class="metric-mini" style="height:auto;min-height:80px;max-height:none;">
            <div class="mm-label">Harris-Benedict</div>
            <div class="mm-value" id="bari-hb" style="font-size:1.2rem;color:#fbbf24;">--</div>
            <div class="mm-unit">kcal/día</div>
            <div style="font-size:0.6rem;color:var(--muted2);margin-top:3px;">Revisada Roza-Shizgal 1984</div>
          </div>
          <div class="metric-mini" style="height:auto;min-height:80px;max-height:none;">
            <div class="mm-label">RMR Medido (VO₂)</div>
            <div class="mm-value" id="bari-rmr" style="font-size:1.2rem;color:var(--accent2);">--</div>
            <div class="mm-unit">kcal/día</div>
            <div style="font-size:0.6rem;color:var(--muted2);margin-top:3px;">Weir híbrido directo</div>
          </div>
        </div>

        <!-- Diferencia RMR medido vs predicho -->
        <div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:12px 16px;margin-bottom:16px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:8px;">
            <div style="font-size:0.78rem;font-weight:700;color:var(--text);">Acuerdo RMR Medido vs. Ecuaciones</div>
            <div id="bari-rmr-agree" style="font-size:0.72rem;font-family:var(--mono);padding:2px 10px;border-radius:10px;background:rgba(255,255,255,0.06);color:var(--muted);">--</div>
          </div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
            <div style="text-align:center;">
              <div style="font-size:0.65rem;color:var(--muted);margin-bottom:3px;">vs Mifflin</div>
              <div id="bari-diff-mifflin" style="font-family:var(--mono);font-size:0.9rem;font-weight:700;">--</div>
            </div>
            <div style="text-align:center;">
              <div style="font-size:0.65rem;color:var(--muted);margin-bottom:3px;">vs Owen</div>
              <div id="bari-diff-owen" style="font-family:var(--mono);font-size:0.9rem;font-weight:700;">--</div>
            </div>
            <div style="text-align:center;">
              <div style="font-size:0.65rem;color:var(--muted);margin-bottom:3px;">vs H-B</div>
              <div id="bari-diff-hb" style="font-family:var(--mono);font-size:0.9rem;font-weight:700;">--</div>
            </div>
          </div>
          <div style="margin-top:8px;height:6px;border-radius:3px;background:rgba(255,255,255,0.06);overflow:hidden;position:relative;">
            <div id="bari-agree-bar" style="height:100%;border-radius:3px;background:linear-gradient(90deg,#22c55e,#d6da13);width:0%;transition:width 0.4s;"></div>
          </div>
        </div>

        <!-- RQ clínico -->
        <div class="section-header" style="margin-bottom:10px;">⚗️ Interpretación RQ — Clínica Bariátrica</div>
        <div style="display:grid;grid-template-columns:1fr 2fr;gap:14px;margin-bottom:16px;">
          <div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:16px;">
            <div style="font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">RQ Actual</div>
            <div id="bari-rq" style="font-family:var(--display);font-size:2.5rem;font-weight:900;color:var(--text);">--</div>
            <div id="bari-rq-label" style="margin-top:4px;font-size:0.82rem;font-weight:700;color:var(--accent);">--</div>
            <div id="bari-rq-color-bar" style="height:5px;border-radius:3px;background:linear-gradient(90deg,#ff6b35 0%,#fbbf24 30%,#22c55e 60%,#60a5fa 100%);margin-top:10px;position:relative;">
              <div id="bari-rq-cursor" style="position:absolute;top:-3px;width:11px;height:11px;border-radius:50%;background:#fff;border:2px solid var(--card);box-shadow:0 0 6px rgba(0,0,0,0.5);transform:translateX(-50%);left:50%;transition:left 0.4s;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:0.58rem;color:var(--muted);margin-top:2px;"><span>0.70</span><span>1.00</span></div>
          </div>
          <div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:16px;">
            <div style="font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">Interpretación Clínica RQ</div>
            <div style="display:grid;gap:5px;" id="bari-rq-interp">
              <div style="font-size:0.78rem;color:var(--muted2);">Inicie una sesión para interpretación clínica.</div>
            </div>
          </div>
        </div>

        <!-- Clasificación metabólica -->
        <div class="section-header" style="margin-bottom:10px;">🧠 Clasificación Metabólica Bariátrica</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-bottom:16px;" id="bari-class-grid">
          <div style="background:var(--card2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:12px;text-align:center;color:var(--muted);font-size:0.78rem;">Sin datos — inicie sesión</div>
        </div>

        <!-- Plan calórico por fase -->
        <div class="section-header" style="margin-bottom:10px;">🍽️ Prescripción Calórica por Fase Post-Quirúrgica</div>
        <div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);overflow:hidden;margin-bottom:16px;">
          <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
            <thead>
              <tr style="background:linear-gradient(135deg,var(--primary),var(--primary-light));">
                <th style="padding:10px 12px;text-align:left;font-size:0.7rem;letter-spacing:0.3px;color:rgba(255,255,255,0.9);">Fase</th>
                <th style="padding:10px 12px;text-align:center;font-size:0.7rem;letter-spacing:0.3px;color:rgba(255,255,255,0.9);">kcal/día objetivo</th>
                <th style="padding:10px 12px;text-align:center;font-size:0.7rem;letter-spacing:0.3px;color:rgba(255,255,255,0.9);">Proteína</th>
                <th style="padding:10px 12px;text-align:center;font-size:0.7rem;letter-spacing:0.3px;color:rgba(255,255,255,0.9);">Duración estimada</th>
                <th style="padding:10px 12px;text-align:left;font-size:0.7rem;letter-spacing:0.3px;color:rgba(255,255,255,0.9);">Objetivo clínico</th>
              </tr>
            </thead>
            <tbody id="bari-phase-table">
              <tr><td colspan="5" style="padding:14px;text-align:center;color:var(--muted);">Calculando…</td></tr>
            </tbody>
          </table>
        </div>

        <!-- TEE desglosado -->
        <div class="section-header" style="margin-bottom:10px;">📊 Gasto Energético Total (TEE) Desglosado</div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
          <div class="caloric-card" style="border-color:rgba(214,218,19,0.3);">
            <div class="caloric-value" id="bari-tee-rmr" style="font-size:1.8rem;color:var(--accent);">--</div>
            <div class="caloric-label">RMR (~71%) · kcal/día</div>
          </div>
          <div class="caloric-card">
            <div class="caloric-value" id="bari-tee-tef" style="font-size:1.8rem;">--</div>
            <div class="caloric-label">TEF (~10%) · kcal/día</div>
          </div>
          <div class="caloric-card">
            <div class="caloric-value" id="bari-tee-eat" style="font-size:1.8rem;">--</div>
            <div class="caloric-label">EAT (~19%) · kcal/día</div>
          </div>
          <div class="caloric-card" style="border-color:rgba(255,107,53,0.4);">
            <div class="caloric-value" id="bari-tee-total" style="font-size:1.8rem;color:var(--accent2);">--</div>
            <div class="caloric-label">TEE Total · kcal/día</div>
          </div>
        </div>

        <!-- Macronutrientes -->
        <div class="section-header" style="margin-bottom:10px;">🥩 Distribución de Macronutrientes (por fase)</div>
        <div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:14px;margin-bottom:16px;">
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
            <div>
              <div style="font-size:0.68rem;font-weight:700;color:#f87171;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Proteínas</div>
              <div id="bari-prot-g" style="font-family:var(--display);font-size:1.8rem;font-weight:900;color:#f87171;">--</div>
              <div style="font-size:0.7rem;color:var(--muted);">g/día (<span id="bari-prot-gkg">--</span> g/kg PC)</div>
              <div id="bari-prot-bar" style="height:4px;border-radius:2px;background:#f87171;width:0%;margin-top:6px;transition:width 0.4s;"></div>
            </div>
            <div>
              <div style="font-size:0.68rem;font-weight:700;color:#60a5fa;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Carbohidratos</div>
              <div id="bari-carb-g" style="font-family:var(--display);font-size:1.8rem;font-weight:900;color:#60a5fa;">--</div>
              <div style="font-size:0.7rem;color:var(--muted);">g/día</div>
              <div id="bari-carb-bar" style="height:4px;border-radius:2px;background:#60a5fa;width:0%;margin-top:6px;transition:width 0.4s;"></div>
            </div>
            <div>
              <div style="font-size:0.68rem;font-weight:700;color:#fbbf24;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Grasas</div>
              <div id="bari-fat-g" style="font-family:var(--display);font-size:1.8rem;font-weight:900;color:#fbbf24;">--</div>
              <div style="font-size:0.7rem;color:var(--muted);">g/día</div>
              <div id="bari-fat-bar" style="height:4px;border-radius:2px;background:#fbbf24;width:0%;margin-top:6px;transition:width 0.4s;"></div>
            </div>
          </div>
        </div>

        <!-- Riesgo pérdida masa magra -->
        <div class="section-header" style="margin-bottom:10px;">💪 Riesgo de Pérdida de Masa Magra</div>
        <div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:14px 16px;margin-bottom:16px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border2);">
            <label style="font-size:0.7rem;color:var(--muted);white-space:nowrap;font-weight:600;">Aporte proteico real:</label>
            <input id="bari-prot-input" type="number" min="0" max="500" step="1" placeholder="g/día"
              style="width:90px;padding:5px 8px;border-radius:6px;border:1px solid var(--border2);background:rgba(255,255,255,0.06);color:var(--text);font-size:0.82rem;font-family:var(--mono);"
              oninput="updateBariatric()">
            <span style="font-size:0.68rem;color:var(--muted2);">Ingrese los gramos de proteína/día consumidos por el paciente para calcular el riesgo real.</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px;">
            <div style="text-align:center;">
              <div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase;margin-bottom:4px;">Aporte proteico</div>
              <div id="bari-mm-prot-intake" style="font-family:var(--display);font-size:1.6rem;font-weight:900;color:#f87171;">--</div>
              <div style="font-size:0.65rem;color:var(--muted);">g/kg/día real</div>
            </div>
            <div style="text-align:center;">
              <div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase;margin-bottom:4px;">Recomendado</div>
              <div id="bari-mm-prot-req" style="font-family:var(--display);font-size:1.6rem;font-weight:900;color:#22c55e;">--</div>
              <div style="font-size:0.65rem;color:var(--muted);">g/kg/día fase</div>
            </div>
            <div style="text-align:center;">
              <div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase;margin-bottom:4px;">Déficit proteico</div>
              <div id="bari-mm-prot-deficit" style="font-family:var(--display);font-size:1.6rem;font-weight:900;color:var(--muted);">--</div>
              <div style="font-size:0.65rem;color:var(--muted);">g/día</div>
            </div>
          </div>
          <div style="margin-bottom:8px;">
            <div style="display:flex;justify-content:space-between;font-size:0.65rem;color:var(--muted);margin-bottom:4px;">
              <span>Riesgo pérdida masa magra</span>
              <span id="bari-mm-risk-label" style="font-weight:700;color:var(--muted);">--</span>
            </div>
            <div style="height:8px;border-radius:4px;background:rgba(255,255,255,0.06);overflow:hidden;">
              <div id="bari-mm-risk-bar" style="height:100%;border-radius:4px;background:#22c55e;width:0%;transition:width 0.5s;"></div>
            </div>
          </div>
          <div id="bari-mm-risk-interp" style="font-size:0.72rem;color:var(--muted2);line-height:1.5;padding:8px;background:rgba(255,255,255,0.02);border-radius:6px;border:1px solid var(--border2);">Seleccione fase y complete datos de paciente para calcular riesgo.</div>
        </div>

        <!-- Recomendaciones -->
        <div class="section-header" style="margin-bottom:10px;">🏃 Recomendaciones Clínicas Integradas</div>
        <div id="bari-rec-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px;margin-bottom:16px;">
          <div style="background:var(--card2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:12px;color:var(--muted);font-size:0.78rem;">Sin datos — inicie sesión</div>
        </div>

        <!-- Alertas clínicas -->
        <div id="bari-alerts-box" style="display:none;background:rgba(255,77,109,0.08);border:1px solid rgba(255,77,109,0.3);border-radius:var(--radius);padding:12px 16px;margin-bottom:16px;">
          <div style="font-size:0.78rem;font-weight:700;color:var(--danger);margin-bottom:8px;">⚠ Alertas Clínicas</div>
          <div id="bari-alerts-list" style="font-size:0.75rem;line-height:1.8;color:var(--muted2);"></div>
        </div>

        <!-- Botón actualizar -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <button class="btn btn-primary btn-sm" onclick="updateBariatric()">🔄 Actualizar Cálculos</button>
          <button class="btn btn-ghost btn-sm" onclick="printBariatric()">📄 Exportar Informe Bariátrico</button>
        </div>
        <div class="info-box" style="margin-top:12px;">
          <strong>Base científica:</strong> Mifflin JD et al. (1990) · Owen OE et al. (1986–1987) · Roza AM & Shizgal HM (1984) · Weir JB (1949) · ASMBS Guidelines (2022).
          El IRB integra VO₂, RQ, acuerdo RMR y clasificación metabólica. <em>No reemplaza evaluación nutricional clínica especializada.</em>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /app -->

<!-- PROTOCOL MODAL -->
<div class="protocol-overlay" id="protocol-overlay" onclick="event.target===this?_cancelProtocol():0">
  <div class="protocol-modal">
    <h3>Protocolo de Respiracion Pre-Evaluacion</h3>
    <ul class="protocol-steps">
      <li><span class="step-icon">1.</span><span class="step-text"><strong>Mascara Hans Rudolph</strong> — Verificar sellado completo oronasal. Sin fugas en puente nasal ni menton.</span></li>
      <li><span class="step-icon">2.</span><span class="step-text"><strong>Respiracion oral obligatoria</strong> — Inspirar y espirar por la boca a traves del Venturi. La respiracion nasal genera flujo insuficiente para la deteccion del sensor diferencial (&lt;0.2 Pa).</span></li>
      <li><span class="step-icon">3.</span><span class="step-text"><strong>Fase de reposo (3 min)</strong> — Sentado, respiracion oral tranquila y regular. Permite estabilizacion de baseline O&#8322;/CO&#8322; y calibracion automatica del umbral de presion.</span></li>
      <li><span class="step-icon">4.</span><span class="step-text"><strong>Durante ejercicio</strong> — Mantener respiracion oral. El incremento natural de flujo mejora la precision del sistema. No contener la respiracion.</span></li>
      <li><span class="step-icon">5.</span><span class="step-text"><strong>Recuperacion</strong> — Continuar respiracion oral hasta que el evaluador indique fin de prueba.</span></li>
    </ul>
    <div style="background:rgba(234,179,8,0.1);border:1px solid rgba(234,179,8,0.3);border-radius:8px;padding:10px 12px;font-size:0.78rem;color:#eab308;margin-bottom:10px;">
      <strong>Nota clinica:</strong> El sensor Venturi requiere flujo minimo ~0.15 L/s para generar diferencial de presion detectable. Respiracion nasal en reposo (~0.05-0.10 L/s) esta por debajo de este umbral, produciendo lecturas de VO&#8322; subestimadas.
    </div>
    <label class="protocol-check"><input type="checkbox" id="protocol-noshow"> No mostrar de nuevo en esta sesion</label>
    <div class="protocol-actions">
      <button class="btn btn-ghost btn-sm" type="button" onclick="_cancelProtocol()">Cancelar</button>
      <button class="btn btn-success btn-sm" type="button" onclick="_doStartTest()">Entendido — Iniciar Prueba</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>


<!-- ══ MARKER INPUT MODAL ══ -->
<div id="marker-modal-overlay" role="dialog" aria-modal="true" onclick="event.target===this?closeMarkerModal():0">
  <div id="marker-modal">
    <div class="marker-modal-title">
      🏁 Agregar Marcador
      <span class="marker-elapsed-badge" id="marker-modal-elapsed">00:00</span>
    </div>
    <div class="marker-modal-sub">Registre percepción de esfuerzo, síntoma u observación clínica</div>

    <!-- Borg RPE 6–20 -->
    <div class="marker-modal-label">Escala de Borg RPE (6–20)</div>
    <div class="borg-grid" id="borg-grid">
      <!-- populated by JS -->
    </div>

    <!-- Category -->
    <div class="marker-modal-label">Categoría</div>
    <div class="marker-cat-row" id="marker-cat-row">
      <button class="marker-cat-btn active" data-cat="RPE" onclick="selectMarkerCat(this)">🏃 RPE</button>
      <button class="marker-cat-btn" data-cat="Síntoma" onclick="selectMarkerCat(this)">⚠️ Síntoma</button>
      <button class="marker-cat-btn" data-cat="Carga" onclick="selectMarkerCat(this)">⚡ Carga</button>
      <button class="marker-cat-btn" data-cat="Nota" onclick="selectMarkerCat(this)">📝 Nota</button>
      <button class="marker-cat-btn" data-cat="Umbral" onclick="selectMarkerCat(this)">🎯 Umbral</button>
    </div>

    <!-- Free text -->
    <div class="marker-modal-label">Observación (opcional)</div>
    <input type="text" class="marker-text-input" id="marker-text-input"
      placeholder="Ej: disnea leve, zona de confort, inicio glucólisis..."
      maxlength="120"
      onkeydown="if(event.key==='Enter')confirmMarkerInput()">

    <div class="marker-modal-actions">
      <button class="btn btn-ghost btn-sm" onclick="closeMarkerModal()">Cancelar</button>
      <button class="btn btn-primary btn-sm" onclick="confirmMarkerInput()">✔ Confirmar</button>
    </div>
  </div>
</div>

