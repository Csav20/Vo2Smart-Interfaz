  if(!prev||!prev.peaks){section.style.display='none';return;}
  section.style.display='block';
  const cur={vo2:G.vo2Peak,hr:G.hrPeak,ve:G.vePeak,rer:G.rerPeak};
  const prevDate=new Date(prev.date).toLocaleDateString('es',{day:'2-digit',month:'short',year:'numeric'});
  function delta(c,p,unit,inv){
    if(!p||!c)return '<span style="color:var(--muted);">--</span>';
    const d=c-p;const pct=p>0?((d/p)*100).toFixed(1):0;
    const pos=inv?d<0:d>0;
    const color=pos?'#d6da13':'#f87171';const arrow=d>0?'▲':d<0?'▼':'●';
    return `<span style="color:${color};font-weight:700;">${arrow} ${d>0?'+':''}${d.toFixed(1)} ${unit} (${d>0?'+':''}${pct}%)</span>`;
  }
  content.innerHTML=`<div style="margin-bottom:8px;color:var(--muted);font-size:0.75rem;">Comparación con sesión del ${escHtml(prevDate)} · Evaluador: ${escHtml(prev.evaluator)} · ${escHtml(prev.protocol)}</div>`
    +`<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">`
    +`<div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:10px;"><div class="mm-label">VO₂ Peak</div><div style="font-family:var(--mono);">Anterior: <strong>${prev.peaks.vo2}</strong> → Actual: <strong>${cur.vo2.toFixed(1)}</strong></div><div>${delta(cur.vo2,prev.peaks.vo2,'ml/kg/min')}</div></div>`
    +`<div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:10px;"><div class="mm-label">FC Máx</div><div style="font-family:var(--mono);">Anterior: <strong>${prev.peaks.hr}</strong> → Actual: <strong>${cur.hr.toFixed(0)}</strong></div><div>${delta(cur.hr,prev.peaks.hr,'bpm')}</div></div>`
    +`<div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:10px;"><div class="mm-label">VE Máx</div><div style="font-family:var(--mono);">Anterior: <strong>${prev.peaks.ve}</strong> → Actual: <strong>${cur.ve.toFixed(1)}</strong></div><div>${delta(cur.ve,prev.peaks.ve,'L/min')}</div></div>`
    +`<div style="background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:10px;"><div class="mm-label">RER Máx</div><div style="font-family:var(--mono);">Anterior: <strong>${prev.peaks.rer}</strong> → Actual: <strong>${cur.rer.toFixed(3)}</strong></div><div>${delta(cur.rer,prev.peaks.rer,'',true)}</div></div>`
    +`</div>`;
}

