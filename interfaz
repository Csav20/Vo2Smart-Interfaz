// ═══════════════════════════════════════════════════
// DATA SMOOTHING (Time-Averaging)
// ═══════════════════════════════════════════════════
function setDataMode(mode,btn){
  G.dataMode=mode;
  const windowMap={bxb:0,avg5:5,avg10:10,avg15:15,avg30:30,rolling10:10};
  G.smoothWindowSec=windowMap[mode]||0;
  // Epoch (block) modes: avg5/10/15/30 — display updates only every N seconds
  // Rolling mode: rolling10 — display updates every second with sliding window
  G.smoothEpoch=(mode!=='bxb'&&mode!=='rolling10');
  G.lastEpochUpdate=Date.now();
  G.epochBuffer=[];

  const labels={
    bxb:t('smooth_info_bxb','Breath-by-breath (sin alisado)'),
    avg5:t('smooth_info_5','Bloque promedio 5 segundos'),
    avg10:t('smooth_info_10','Bloque promedio 10 segundos'),
    avg15:t('smooth_info_15','Bloque promedio 15 segundos'),
    avg30:t('smooth_info_30','Bloque promedio 30 segundos'),
    rolling10:t('smooth_info_r10','Promedio móvil 10 segundos')
  };
  setText('smooth-info',labels[mode]||'');

  // Sync all toggle groups
  document.querySelectorAll('.toggle-group').forEach(grp=>{
    grp.querySelectorAll('.toggle-btn').forEach(b=>b.classList.remove('active'));
  });
  // Find matching buttons in all groups — match by onclick attribute for i18n safety
  document.querySelectorAll('.toggle-btn').forEach(b=>{
    const onc=b.getAttribute('onclick')||'';
    const m=onc.match(/setDataMode\('([^']+)'/);
    if(m&&m[1]===mode)b.classList.add('active');
  });
}

function avgFromArray(arr,key,fallback){
  const vals=arr.map(d=>safeN(d[key])).filter(v=>v>0);
  return vals.length?vals.reduce((a,b)=>a+b)/vals.length:fallback;
}

function buildSmoothedObj(samples,raw){
  // Suavizar VE y RR juntos, luego derivar VT para coherencia: VT × RR = VE
  const ve_s=avgFromArray(samples,'ve',safeN(raw.ve));
  const rr_s=avgFromArray(samples,'freq',safeN(raw.freq))||avgFromArray(samples,'rr',safeN(raw.rr));
  const vol_s=rr_s>0?ve_s/rr_s:safeN(raw.vol); // VT derivado del suavizado conjunto
  return{
    vo2:avgFromArray(samples,'vo2',safeN(raw.vo2)),
    vco2:avgFromArray(samples,'vco2',safeN(raw.vco2)),
    hr:avgFromArray(samples,'hr',safeN(raw.hr)),
    ve:ve_s,
    freq:rr_s,
    rr:rr_s,
    vol:vol_s,
    o2:avgFromArray(samples,'o2',safeN(raw.o2)),
    co2:avgFromArray(samples,'co2',safeN(raw.co2)),
    rer:avgFromArray(samples,'rer',safeN(raw.rer)),
    temp:safeN(raw.temp,20),pres:safeN(raw.pres,101300),
    rho:safeN(raw.rho,1.2),battery:safeN(raw.battery,100),batteryV:safeN(raw.batteryV,4.2),
    calTotal:safeN(raw.calTotal),humidity:safeN(raw.humidity,50),
    time:raw.time,mode:raw.mode,demo:raw.demo,
    artifact:samples.reduce((a,s)=>a|(safeN(s.artifact)),0),
    vo2r:raw.vo2r,rqr:raw.rqr,frr:raw.frr,do2r:raw.do2r
  };
}

function getSmoothedData(raw){
  if(G.smoothWindowSec===0||G.rawBuffer.length===0)return raw;
  // Rolling mode: sliding window, updates every packet
  const now=Date.now();
  const cutoff=now-G.smoothWindowSec*1000;
  const win=G.rawBuffer.filter(d=>d._ts>=cutoff);
  if(win.length<2)return raw;
  return buildSmoothedObj(win,raw);
}

function getEpochData(raw){
  // Epoch (block) mode: average all samples in the completed epoch
  if(G.epochBuffer.length===0)return raw;
  return buildSmoothedObj(G.epochBuffer,raw);
}

