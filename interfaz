function selectBorg(val,btn){
  _markerBorgSelected=val;
  document.querySelectorAll('.borg-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  // Auto-set category to RPE if not already
  if(_markerCatSelected==='Nota'){
    const rpeBtn=document.querySelector('[data-cat="RPE"]');
    if(rpeBtn)selectMarkerCat(rpeBtn);
