async function connectDevice(){
  if(!navigator.bluetooth){toast('Web Bluetooth no soportado en este navegador','error');return;}
  try{
    toast('Buscando dispositivo VO₂Smart…','info');
    const dev=await navigator.bluetooth.requestDevice({acceptAllDevices:true,optionalServices:['0000ffe0-0000-1000-8000-00805f9b34fb']});
    const srv=await dev.gatt.connect();
    const svc=await srv.getPrimaryService('0000ffe0-0000-1000-8000-00805f9b34fb');
    const ch=await svc.getCharacteristic('0000ffe1-0000-1000-8000-00805f9b34fb');
    await ch.startNotifications();
    ch.addEventListener('characteristicvaluechanged',handleBLE);

    try {
      const apiCh = await svc.getCharacteristic('0000ffe3-0000-1000-8000-00805f9b34fb');
      await apiCh.startNotifications();
      apiCh.addEventListener('characteristicvaluechanged', handleBLECommandResponse);
      G.bleApiCh = apiCh;
      console.log('✅ BLE API (FFE3) connected');
    } catch(e) {
      console.warn('⚠️ FFE3 not available, commands via FFE1');
      G.bleApiCh = null;
    }

    // FIX-BLE-04: Auto-reconexión con backoff exponencial
    dev.addEventListener('gattserverdisconnected',async ()=>{
      G.bleCh=null;
      G.bleApiCh=null;
      if(!G.serialConnected)setDiagDeviceName('--');
      if(!G.serialConnected)setConnected(false,t('status_disconnected'));
      vtInitOffline();
      // Intentar reconexión automática (max 3 intentos)
      if(G.bleDevice && G.bleDevice.gatt){
        for(let attempt=1;attempt<=3;attempt++){
          const delay=1000*attempt; // 1s, 2s, 3s backoff
          toast(`Reconectando BLE (${attempt}/3)…`,'warning');
          await new Promise(r=>setTimeout(r,delay));
          try{
            const srv=await G.bleDevice.gatt.connect();
            const svc=await srv.getPrimaryService('0000ffe0-0000-1000-8000-00805f9b34fb');
            const ch=await svc.getCharacteristic('0000ffe1-0000-1000-8000-00805f9b34fb');
            await ch.startNotifications();
            ch.addEventListener('characteristicvaluechanged',handleBLE);
            try{
              const apiCh=await svc.getCharacteristic('0000ffe3-0000-1000-8000-00805f9b34fb');
              await apiCh.startNotifications();
              apiCh.addEventListener('characteristicvaluechanged',handleBLECommandResponse);
              G.bleApiCh=apiCh;
            }catch(e){G.bleApiCh=null;}
            G.bleCh=ch;G.bleBuffer='';
            setDiagDeviceName(G.bleDevice.name||'VO2Smart');
            setConnected(true,`Reconectado: ${G.bleDevice.name||'VO2Smart'}`);
            toast('BLE reconectado','success');
            return; // éxito — salir del loop
          }catch(e){
            console.warn(`[BLE] Reconnect attempt ${attempt} failed:`,e.message);
          }
        }
        // 3 intentos fallidos
        G.bleDevice=null;
        toast('BLE desconectado — reconexión fallida','error');
      }
    });
    G.bleDevice=dev;G.bleCh=ch;G.bleBuffer='';
    setDiagDeviceName(dev.name||'VO2Smart');
    setConnected(true,`Conectado: ${dev.name||'VO2Smart'}`);
    toast(t('toast_ble_connected'),'success');
    // Init virtual TFT at INIT stage while boot state is queried
    _VD.deviceName=dev.name||'VO2Smart'; _VD.stage='INIT';
    Object.keys(_VD.sensors).forEach(k=>_VD.sensors[k]=null);
    _vtRender();
    // Sincronizar peso desde el dispositivo al conectar
    // FIX-BLE-03: Espaciar comandos post-conexión para reducir ráfaga WDT en ESP32
    setTimeout(()=>syncWeightFromDevice(),800);
    setTimeout(()=>sendBLECommand('LANG:'+currentLang),1500);
    setTimeout(()=>cmdGetScreen(),2200);
    setTimeout(()=>cmdGetBootState(),2900);
  }catch(e){toast(t('toast_ble_error')+' '+e.message,'error');}
}

function parseWiredCsvLine(line){
  const cols=line.split(',').map(s=>s.trim());
  if(cols.length<10)return false;
  if(cols[0].toLowerCase()==='time')return true;

  const t=parseFloat(cols[0]);
  const vo2=parseFloat(cols[1]);
  const vo2max=parseFloat(cols[2]);
  const vco2=parseFloat(cols[3]);
  const rq=parseFloat(cols[4]);
  const bvol=parseFloat(cols[5]);
  const ve=parseFloat(cols[6]);
  const brate=parseFloat(cols[7]);
  const o2=parseFloat(cols[8]);
  const co2=parseFloat(cols[9]);
  if(!Number.isFinite(t)||!Number.isFinite(vo2)||!Number.isFinite(vco2))return false;

  processData({
    time:t*1000,
    vo2:Number.isFinite(vo2)?vo2:0,
    vo2max:Number.isFinite(vo2max)?vo2max:0,
    vco2:Number.isFinite(vco2)?vco2:0,
    rer:Number.isFinite(rq)?rq:0,
    ve:Number.isFinite(ve)?ve:0,
    freq:Number.isFinite(brate)?brate:0,
    vol:Number.isFinite(bvol)?bvol:0,
    o2:Number.isFinite(o2)?o2:0,
    co2:Number.isFinite(co2)?co2:0,
    mode:'wired',
    wired:true
  });
  return true;
}

function processWiredLine(rawLine){
  const line=(rawLine||'').trim();
  if(!line)return;
  if(line.startsWith('{')&&line.endsWith('}')){
    handleRemoteCommandRaw(line);
    return;
  }
  if(parseWiredCsvLine(line))return;
  if(line.startsWith('[BLE]')||line.startsWith('[BOOT]')||line.startsWith('[FLOW]')){
    console.log('📟 SERIAL LOG:',line);
  }
}

async function startWiredReadLoop(){
  try{
    while(G.serialReader){
      const {value,done}=await G.serialReader.read();
      if(done)break;
      G.serialBuffer+=new TextDecoder().decode(value);
      const lines=G.serialBuffer.split('\n');
      G.serialBuffer=lines.pop()||'';
      lines.forEach(processWiredLine);
    }
  }catch(e){
    console.warn('SERIAL RX error:',e.message);
  }
}

async function disconnectWired(silent){
