function safeN(v,d=0){const n=parseFloat(v);return isFinite(n)?n:d;}

// ── Cinética VO2 — Whipp & Ward (1990), Wasserman et al. (2012) ──────────────
// Detecta transición, calcula τ por ajuste punto-63% y MRT = τ + TD
// Buffer circular de 60 puntos (1/s) mantenido en G.kinetics.history
function computeKinetics(vo2) {
  const K = G.kinetics;
  const now = Date.now();

  // Mantener historial circular 60s a ~1Hz (pushChart ya controla frecuencia)
  K.history.push({v: vo2, t: now});
  if (K.history.length > 60) K.history.shift();
  if (K.history.length < 10) return;  // insuficiente para análisis

  // Baseline: media de los últimos 10 puntos ANTES de transición activa
  if (!K.transitionStart) {
    const win = K.history.slice(-10);
    const mean = win.reduce((s, p) => s + p.v, 0) / win.length;
    const std  = Math.sqrt(win.reduce((s, p) => s + (p.v - mean) ** 2, 0) / win.length);
    // Umbral Wasserman: cambio >15% o >3 mL/kg/min es significativo
    const threshold = Math.max(mean * 0.15, 3.0);
    const currentChange = Math.abs(vo2 - mean);
    if (currentChange > threshold && std < threshold * 0.5) {
      // Transición detectada: baseline estable previo
      K.baseline       = mean;
      K.transitionStart= now;
      K.peak           = vo2;
      K.tau            = null;
      K.amplitude      = null;
      K.valid          = false;
    } else {
      // Actualizar baseline solo si VO2 estable (down-only o pequeño cambio)
      if (mean > 0 && currentChange < threshold) K.baseline = mean;
    }
  } else {
    // Transición activa: actualizar pico
    if (vo2 > K.peak) K.peak = vo2;
    const elapsed = (now - K.transitionStart) / 1000; // segundos

    // Calcular τ desde 63% de la respuesta (>20s de datos, Whipp & Ward 1990)
    if (elapsed >= 20 && K.peak > K.baseline) {
      K.amplitude = K.peak - K.baseline;
      const currentResponse = vo2 - K.baseline;
      const fraction = currentResponse / K.amplitude;

      if (fraction > 0.1 && fraction < 0.9) {
        const lnTerm = -Math.log(1 - fraction);
        if (lnTerm > 0) {
          const tauCandidate = elapsed / lnTerm;
          // Rango fisiológico válido: 10–120s (Whipp & Ward 1990 / R-ISO-09)
          if (tauCandidate >= 10 && tauCandidate <= 120) {
            K.tau   = tauCandidate;
            K.valid = K.amplitude >= 3 && K.amplitude <= 50;
          }
        }
      }
    }

    // Finalizar transición: VO2 vuelve cerca del baseline por >30s
    const threshold = Math.max(K.baseline * 0.15, 3.0);
    if (Math.abs(vo2 - K.baseline) < threshold * 0.5 && elapsed > 30) {
      K.transitionStart = null; // listo para próxima transición
    }
  }
}

// Mejora A: Captura manual de cinética — fuerza inicio de análisis cinético
function startManualKinetics() {
  const K = G.kinetics;
  const statusEl = document.getElementById('manual-kinetics-status');
  if (K.history.length < 5) {
    if (statusEl) statusEl.textContent = 'Necesita datos VO₂ activos';
    return;
  }
  const win = K.history.slice(-10);
  const mean = win.reduce((s, p) => s + p.v, 0) / win.length;
  K.baseline = mean;
  K.transitionStart = Date.now();
  K.peak = K.history[K.history.length - 1].v;
  K.tau = null;
  K.amplitude = null;
  K.valid = false;
  if (statusEl) statusEl.textContent = 'Captura iniciada — baseline: ' + mean.toFixed(1) + ' ml/kg/min';
  const btn = document.getElementById('btn-manual-kinetics');
  if (btn) { btn.style.borderColor = 'var(--accent)'; setTimeout(() => btn.style.borderColor = 'var(--border2)', 2000); }
}

