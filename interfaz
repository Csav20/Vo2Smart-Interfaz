let simT=0;
function toggleSimulation(){
  if(G.simOn){clearInterval(G.sim);G.simOn=false;_protocolSkipSession=false;toast(t('toast_demo_off'),'info');return;}
  G.simOn=true;simT=0;
  setConnected(true,'Demo activo');
  // Auto-start test if idle (skip protocol modal for demo)
  if(G.testState==='idle'){_protocolSkipSession=true;startTest();}
  G.sim=setInterval(()=>{
    simT+=1;
    const prog=Math.min(simT/300,1);
    // VO₂ progresivo: reposo→máximo (ml/kg/min)
    const vo2=20+prog*35+Math.sin(simT/15)*2+Math.random()*1.5;
    // RER real progresivo: 0.78 (reposo lipídico) → 1.05+ (umbral anaeróbico)
    const rer_real=0.78+prog*0.22+Math.random()*0.03;
    const vco2_real=vo2*rer_real;
    const hr=80+prog*90+Math.random()*4;
    const ve=20+prog*80+Math.random()*3;
    const rr=12+prog*18+Math.random()*1;

    // Fracciones gaseosas realistas (ejercicio)
    // FeO₂ baja de 20.93 ambiente a ~16-17% en ejercicio intenso
    // FeCO₂ sube de 0.04 ambiente a ~3.5-4.5% en ejercicio
    const feo2=20.93-(3.5*prog+Math.random()*0.3);   // ~20.9→~17.1%
    const feco2=0.04+(3.5*prog+Math.random()*0.2);    // ~0.04→~3.7%

    // Simular artefacto Haldane cada ~30s: firmware reporta VCO₂ erróneo
    // → RER raw = 0.44 (artificialmente bajo por Haldane mismatch)
    // → computeRER() debe corregir vía fracciones gaseosas
    const haldaneGlitch=simT%30===0&&prog>0.2;
    const vco2_fw=haldaneGlitch?vo2*0.44:vco2_real;

    processData({vo2,vco2:vco2_fw,rer:vco2_fw/vo2,hr,ve,freq:rr,vol:ve/rr,
      o2:feo2,co2:feco2,
      temp:20+Math.random()*0.5,pres:101300,rho:1.2,battery:95-simT/50,batteryV:4.1,
      calTotal:simT*0.1,time:simT*1000,humidity:50,mode:'sim',demo:true});

    // ── HRV: simular RR-intervals realistas para activar pipeline completo ──
    // Mean RR decrece con ejercicio: ~750ms reposo → ~400ms pico
    // Variabilidad (SDNN proxy) decrece con intensidad: ~60ms → ~15ms
    const meanRR=750-prog*350;
    const rrVariability=60-prog*45;
    const rrCount=Math.round(60000/meanRR); // ~1-2 RR per second
    const simRRList=[];
    for(let r=0;r<rrCount;r++){
      const rr_ms=meanRR+((Math.random()-0.5)*2*rrVariability)+(Math.sin(simT/4+r)*rrVariability*0.3);
      simRRList.push(Math.max(300,Math.min(1200,Math.round(rr_ms))));
    }
    feedRR(simRRList,hr);
  },1000);
  toast(t('toast_demo_on'),'success');
}

