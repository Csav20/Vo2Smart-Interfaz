function getCaloProtocolSnapshot(){
  const saved=G.caloProtocol||{};
  const type=document.getElementById('calo-protocol-type')?.value || saved.type || 'RMR';
  const state=document.getElementById('calo-protocol-state')?.value || saved.state || 'fasting';
  const duration=parseInt(document.getElementById('calo-protocol-duration')?.value,10) || safeN(saved.duration,10) || 10;
  return {
    type,
    state,
    duration,
    typeLabel:getSelectedLabel('calo-protocol-type', CALO_PROTOCOL_LABELS[type] || type),
    stateLabel:getSelectedLabel('calo-protocol-state', CALO_STATE_LABELS[state] || state),
    durationLabel:duration+' min'
  };
}

function formatCaloProtocol(proto){
  if(!proto)return'--';
  const typeLabel=proto.typeLabel || CALO_PROTOCOL_LABELS[proto.type] || proto.type || '--';
  const stateLabel=proto.stateLabel || CALO_STATE_LABELS[proto.state] || proto.state || '--';
  const duration=parseInt(proto.duration,10);
  const durationLabel=(isFinite(duration)&&duration>0?duration+' min':proto.durationLabel)||'--';
  return [typeLabel,stateLabel,durationLabel].filter(Boolean).join(' · ');
}

const CALO_DEMO_PATIENT_DEFAULTS = {
  weight: 70,
  height: 175,
  age: 35,
  sex: 'M'
};

function getCalorimetryPatient(patient){
  const src = patient || getPatient() || {};
  const resolved = {...src};
  if(G.simOn){
    if(!(safeN(resolved.weight,0)>0))resolved.weight=CALO_DEMO_PATIENT_DEFAULTS.weight;
    if(!(safeN(resolved.height,0)>0))resolved.height=CALO_DEMO_PATIENT_DEFAULTS.height;
    if(!(safeN(resolved.age,0)>0))resolved.age=CALO_DEMO_PATIENT_DEFAULTS.age;
    if(!String(resolved.sex||'').trim())resolved.sex=CALO_DEMO_PATIENT_DEFAULTS.sex;
  }
  return resolved;
}

function estimateHarrisBenedict(patient){
  const weight=safeN(patient?.weight,0);
  const height=safeN(patient?.height,0);
  const age=safeN(patient?.age,0);
  const sex=String(patient?.sex||'').toUpperCase();
  if(!(weight>0&&height>0&&age>0))return 0;
  return sex==='F'
    ?(447.593+9.247*weight+3.098*height-4.330*age)
    :(88.362+13.397*weight+4.799*height-5.677*age);
}

function getCaloMeasurementContext(cal, patientOverride){
  const patient=getCalorimetryPatient(patientOverride);
  const proto=getCaloProtocolSnapshot();
  const isRMR=String(proto.type||'').toUpperCase()==='RMR';
  const currentEE=cal?safeN(cal.eeH,0):0;
  let eeBasis=currentEE;
  let usesSessionAverage=false;
  let demoFallback=false;
  const eeSeries=Array.isArray(G.fullHist?.ee)?G.fullHist.ee:[];
  if(isRMR&&eeSeries.length>=5){
    const validEE=eeSeries.filter(v=>v>0&&v<2.5);
    if(validEE.length>=3){
      eeBasis=validEE.reduce((a,b)=>a+b,0)/validEE.length;
      usesSessionAverage=true;
    }
  }
  if(G.simOn&&isRMR&&!(eeBasis>0&&eeBasis<2.5)){
    const hb=estimateHarrisBenedict(patient);
    const demoRmrDaily=hb>0?hb:1650;
    eeBasis=demoRmrDaily/1440;
    usesSessionAverage=false;
    demoFallback=true;
  }
  const rmrValid=isRMR&&eeBasis>0&&eeBasis<2.5;
  const rmrDaily=rmrValid?eeBasis*1440:0;
  return {
    patient,
    proto,
    protoStr:formatCaloProtocol(proto),
    isRMR,
    eeBasis,
    currentEE,
    usesSessionAverage,
    demoFallback,
    rmrValid,
    rmrDaily,
    tee:rmrValid?(rmrDaily/0.71):0
  };
}

function getCalorimetryPresentation(cal, opts={}){
  const patient=getCalorimetryPatient(opts.patient || getPatient() || {});
  const weight=safeN(opts.weight!=null?opts.weight:patient.weight,0);
  const height=safeN(opts.height!=null?opts.height:patient.height,0);
  const age=safeN(opts.age!=null?opts.age:patient.age,0);
  const sex=String(opts.sex||patient.sex||'').toUpperCase();
  const vo2Current=safeN(opts.vo2Current!=null?opts.vo2Current:G.currentData?.vo2,0);
  const vco2Current=safeN(opts.vco2Current!=null?opts.vco2Current:G.currentData?.vco2,0);
  const ctx=getCaloMeasurementContext(cal,patient);
  const eeDisplay=ctx.isRMR&&ctx.eeBasis>0?ctx.eeBasis:safeN(cal?.eeH,0);
  const vo2L=weight>0&&vo2Current>0?(vo2Current*weight/1000):0;
  const vco2L=weight>0&&vco2Current>0?(vco2Current*weight/1000):0;
  const bsa=weight>0&&height>0?0.007184*Math.pow(height,0.725)*Math.pow(weight,0.425):0;
  const hb=estimateHarrisBenedict({weight,height,age,sex});

  const fatRaw=Math.max(0,safeN(cal?.fat_pct,0));
  const choRaw=Math.max(0,safeN(cal?.cho_pct,0));
  const pctDen=(fatRaw+choRaw)>0?(fatRaw+choRaw):100;
  const fatPct=(fatRaw+choRaw)>0?(fatRaw/pctDen*100):0;
  const choPct=(fatRaw+choRaw)>0?(choRaw/pctDen*100):0;
  const fatShare=fatPct/100;
  const choShare=choPct/100;
  const fatKcalDay=ctx.rmrValid?(ctx.rmrDaily*fatShare):0;
  const choKcalDay=ctx.rmrValid?(ctx.rmrDaily*choShare):0;
  const fatDay=ctx.rmrValid?(fatKcalDay/9):0;
  const choDay=ctx.rmrValid?(choKcalDay/4):0;

  const rer=safeN(cal?.rer,0);
  const rqClass=rer<0.76?'ok':rer>0.95?'danger':'warn';
  const rqLabel=rer<0.76?'Predominio graso':rer>0.95?'Predominio CHO':'Metabolismo mixto';

  const confNotes=[];
  if(ctx.isRMR){
    confNotes.push(ctx.rmrValid?'RMR extrapolable':'RMR aún no válida');
  }else{
    confNotes.push('No basal');
  }
  confNotes.push(ctx.demoFallback?'Base demo estimada':(ctx.usesSessionAverage?'EE promedio de sesión':'EE instantánea'));
  confNotes.push(cal?.rerWarning?'RER fuera de rango':'RER fisiológico');

  let rmrBadgeClass='warn';
  let rmrBadgeText='Validación pendiente';
  let rmrNote='Interpretación pendiente.';
  let rmrDiffStr='--';

  if(ctx.demoFallback){
    rmrBadgeClass='ok';
    rmrBadgeText='Estimación demo';
    rmrNote='Modo demo: RMR basal estimado para poblar la vista. No usar con fines clínicos.';
    rmrDiffStr='Demo';
  }else if(hb>0&&ctx.rmrValid){
    const diff=((ctx.rmrDaily-hb)/hb*100);
    rmrDiffStr=(diff>0?'+':'')+diff.toFixed(1)+'%';
    if(Math.abs(diff)<=10){
      rmrBadgeClass='ok';
      rmrBadgeText=(diff>0?'+':'')+diff.toFixed(1)+'% vs HB';
      rmrNote='RMR dentro del rango esperado frente a Harris-Benedict (±10%).';
    }else if(diff>10){
      rmrBadgeClass='danger';
      rmrBadgeText='Elevado vs HB';
