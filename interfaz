function rebuildChartsFromFullHistory(){
  const fh=G.fullHist;
  if(!fh.labels.length)return;
  // Helper: set chart data from arrays
  function setChartData(chart,labelsArr,...dataArrays){
    if(!chart)return;
    chart.data.labels=labelsArr.slice();
    dataArrays.forEach((arr,i)=>{
      if(chart.data.datasets[i])chart.data.datasets[i].data=arr.slice();
    });
    // Adjust x-axis ticks for readability
    if(chart.options.scales&&chart.options.scales.x){
      // Do NOT self-assign .ticks — triggers infinite recursion on Chart.js 4.x proxy
      chart.options.scales.x.ticks.maxTicksLimit=Math.min(12,Math.max(6,Math.floor(labelsArr.length/20)));
    }
    chart.update('none');
  }
  setChartData(G.charts.main,fh.labels,fh.vo2,fh.vco2,fh.veVCO2,fh.veVO2);
  setChartData(G.charts.hr,fh.labels,fh.hr);
  setChartData(G.charts.rer,fh.labels,fh.rer);
  setChartData(G.charts.ee,fh.labels,fh.ee);
  setChartData(G.charts.o2pulse,fh.labels,fh.o2pulse);
  setChartData(G.charts.pet,fh.labels,fh.peto2,fh.petco2);
  // Kinetics chart: rebuild from session VO₂ + tau curve
  if(G.charts.kinetics){
    const K=G.kinetics;
    const vo2Arr=fh.vo2.slice();
    const tauArr=vo2Arr.map((_,i)=>{
      if(K.tau!=null&&K.valid&&K.transitionStart!=null&&K.amplitude){
        const elapsed=(i/vo2Arr.length)*((Date.now()-G.sessionStart)/1000);
        const tStart=(K.transitionStart-G.sessionStart)/1000;
        if(elapsed>=tStart)return K.baseline+K.amplitude*(1-Math.exp(-(elapsed-tStart)/K.tau));
      }
      return NaN;
    });
    const blArr=vo2Arr.map(()=>K.baseline>0?K.baseline:NaN);
    const tgArr=vo2Arr.map(()=>K.peak>0?K.peak:NaN);
    setChartData(G.charts.kinetics,fh.labels,vo2Arr,tauArr,blArr,tgArr);
  }
  // Rebuild fcvo2 scatter from full history
  if(G.charts.fcvo2){
    const pts=[];
    for(let i=0;i<fh.vo2.length;i++){
      if(fh.vo2[i]>0&&fh.hr[i]>0)pts.push({x:fh.vo2[i],y:fh.hr[i]});
    }
    G.charts.fcvo2.data.datasets[0].data=pts;
    G.charts.fcvo2.update('none');
  }
  // Rebuild eeM chart from full history
  if(G.charts.eeM&&fh.ee){
    setChartData(G.charts.eeM,fh.labels,fh.ee,fh.ee1,fh.ee2,fh.ee3);
  }
  // Rebuild hrv chart from full history
  if(G.charts.hrv&&fh.hrv){
    setChartData(G.charts.hrv,fh.labels,fh.hrv);
  }
  // Rebuild substrate chart from full history
  if(G.charts.substrate&&fh.fat&&fh.cho){
    setChartData(G.charts.substrate,fh.labels,fh.fat,fh.cho);
  }
}

function trimChartsToLive(){
  // Trim each chart back to MAX_PTS
  function trimChart(chart){
    if(!chart)return;
    while(chart.data.labels.length>MAX_PTS){
      chart.data.labels.shift();
      chart.data.datasets.forEach(ds=>{if(ds.data.length>0)ds.data.shift();});
    }
    if(chart.options.scales&&chart.options.scales.x){
      // Do NOT self-assign .ticks — triggers infinite recursion on Chart.js 4.x proxy
      chart.options.scales.x.ticks.maxTicksLimit=6;
    }
    chart.update('none');
  }
  [G.charts.main,G.charts.hr,G.charts.rer,G.charts.ee,G.charts.o2pulse,G.charts.pet,G.charts.kinetics,G.charts.eeM,G.charts.substrate,G.charts.hrv].forEach(trimChart);
  // Scatter chart: trim separately (uses {x,y} objects)
  if(G.charts.fcvo2){
    while(G.charts.fcvo2.data.datasets[0].data.length>MAX_PTS)G.charts.fcvo2.data.datasets[0].data.shift();
    G.charts.fcvo2.update('none');
  }
}

