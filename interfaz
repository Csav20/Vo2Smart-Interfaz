  row.innerHTML=`<td>${e.t}</td><td style="font-size:0.65rem;color:var(--muted);">${phaseMap[e.phase]||'--'}</td><td>${safeN(e.vo2).toFixed(2)}</td><td>${safeN(e.vco2).toFixed(2)}</td><td style="color:${rerColor}" title="gas:${safeN(e.rerGas).toFixed(3)} flow:${safeN(e.rerFlow).toFixed(3)} [${e.rerMethod||'?'}] conf:${rerConfVal}%">${rerVal.toFixed(3)}${rerClamped?' ⚠':''}</td>
    <td>${safeN(e.ve).toFixed(1)}</td><td>${safeN(e.fr).toFixed(0)}</td><td>${safeN(e.vol).toFixed(3)}</td>
