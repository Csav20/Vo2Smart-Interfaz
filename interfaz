function setProtocolAdvanceMode(mode,btn){
  const rt=G.protocolRuntime;
  if(!rt)return;
  rt.advanceMode=mode;
  if(mode==='manual'){
    rt.manualStageIndex=rt.stageIndex;
    rt.stagePauseActive=false;rt.stagePauseStart=null;
  }
  const toggle=document.getElementById('protocol-advance-toggle');
  if(toggle)toggle.querySelectorAll('.toggle-btn').forEach(b=>b.classList.toggle('active',b===btn));
  renderProtocolPanel(true);
}
window.setProtocolAdvanceMode=setProtocolAdvanceMode;

function protocolAdvanceStage(){
  const rt=G.protocolRuntime;
  if(!rt||rt.advanceMode!=='manual')return;
  const max=rt.active.stages.length-1;
  rt.stageChecked[rt.manualStageIndex]=true;
  if(rt.stagePauseActive)protocolToggleStagePause();
  if(rt.manualStageIndex<max){
    rt.manualStageIndex++;
    rt.stageIndex=rt.manualStageIndex;
  }else{
    rt.completed=true;
  }
  renderProtocolPanel(true);
  toast('Etapa avanzada','info');
}
window.protocolAdvanceStage=protocolAdvanceStage;

function protocolToggleStagePause(){
  const rt=G.protocolRuntime;
  if(!rt||G.testState!=='running')return;
  if(rt.stagePauseActive){
    const pausedMs=Date.now()-rt.stagePauseStart;
    rt.stagePauseElapsedAll[rt.stageIndex]=(rt.stagePauseElapsedAll[rt.stageIndex]||0)+pausedMs;
    rt.stagePauseActive=false;rt.stagePauseStart=null;
  }else{
    rt.stagePauseActive=true;rt.stagePauseStart=Date.now();
  }
  renderProtocolPanel(true);
}
window.protocolToggleStagePause=protocolToggleStagePause;

function onProtocolStageCheck(idx){
  const rt=G.protocolRuntime;
  if(!rt)return;
  rt.stageChecked[idx]=!rt.stageChecked[idx];
  renderProtocolPanel(true);
}
window.onProtocolStageCheck=onProtocolStageCheck;

