async function captureChartsForReport(){
  const section=document.getElementById('rep-charts-section');
  if(!section)return;
  if(G.fullHist.labels.length<2){section.style.display='none';return;}
  section.style.display='block';

  // Switch to full view so charts have full-test data
  const prevView=G.chartView;
  if(prevView==='live')rebuildChartsFromFullHistory();

  // One RAF + short delay so data assignment settles before resize
  await new Promise(r=>requestAnimationFrame(r));
  await new Promise(r=>setTimeout(r,80));

  // Explicit capture dimensions — works even when chart canvases are in display:none pages.
  // Chart.js 4.x resize(w,h) bypasses container measurement entirely.
  const CAPTURE_W=800;
  const CAPTURE_H={main:300,hr:220,rer:220,ee:220,kinetics:300,o2pulse:220,pet:220,fcvo2:220,substrate:220};
  const BG='#0a0f1e'; // matches --card (chart card background)

  const chartMap={
    'main':'rep-img-main','hr':'rep-img-hr','rer':'rep-img-rer',
    'ee':'rep-img-ee','kinetics':'rep-img-kinetics','o2pulse':'rep-img-o2pulse',
    'fcvo2':'rep-img-fcvo2','pet':'rep-img-pet','substrate':'rep-img-substrate'
  };

  console.log('📷 captureChartsForReport — fullHist pts:',G.fullHist.labels.length,'chartView:',prevView);

  let capturedCount=0;
  for(const[key,imgId]of Object.entries(chartMap)){
    const chart=G.charts[key];
    const img=document.getElementById(imgId);
    if(!chart||!img){
      console.warn('📷 Chart skip:',key,'chart:',!!chart,'img:',!!img);
      if(img)img.style.display='none';continue;
    }
    try{
      const h=CAPTURE_H[key]||220;
      // Force canvas to explicit pixel dimensions — bypasses display:none layout issue
      chart.resize(CAPTURE_W,h);
      chart.update('none');
      // Composite chart (transparent bg) onto a dark background for readability
      const src=chart.canvas;
      const dst=document.createElement('canvas');
      dst.width=src.width; dst.height=src.height;
      const dctx=dst.getContext('2d');
      dctx.fillStyle=BG;
      dctx.fillRect(0,0,dst.width,dst.height);
      dctx.drawImage(src,0,0);
      img.src=dst.toDataURL('image/png');
      img.style.display='block';
      capturedCount++;
    }catch(e){
      img.style.display='none';
      console.warn('📷 Chart capture error:',key,e);
    }
  }
  console.log('📷 captureChartsForReport done —',capturedCount,'of',Object.keys(chartMap).length,'captured');

  // Restore previous view
  if(prevView==='live')trimChartsToLive();

  // Defer chart resize restoration — only resize when their parent page becomes visible again.
  // Resizing now (while chart pages are display:none) would shrink canvases to 0×0.
  // Charts self-heal via goPage('graficos') which already calls resize+update.
}

