function updateBariatric(){
  const _bp=getPatient();
  const weight = _bp.weight;
  const height = _bp.height;
  const age    = _bp.age;
  const sex    = _bp.sex;
  const isFem  = sex === 'F' || sex === 'Femenino';

  if(!weight || !height || !age){
    setText('bari-mifflin','--'); setText('bari-owen','--');
    setText('bari-hb','--'); setText('bari-rmr','--');
    return;
  }

  // ── 1. Ecuaciones TMB ──────────────────────────────────────────────────────
  // Mifflin-St Jeor (1990): más precisa en obesidad
  const mifflin = isFem
    ? (10*weight)+(6.25*height)-(5*age)-161
    : (10*weight)+(6.25*height)-(5*age)+5;
  // Owen (♂ 1986, ♀ 1987): válida en obesidad severa
  const owen = isFem
    ? 795 + (7.18*weight)
    : 879 + (10.2*weight);
  // Harris-Benedict revisada Roza-Shizgal (1984)
  const hb = isFem
    ? 447.6 + (9.2*weight) + (3.1*height) - (4.3*age)
    : 88.4  + (13.4*weight)+ (4.8*height) - (5.7*age);
  // RMR medido (Weir híbrido desde VO₂ actual)
  const cal  = G.currentData?.cal;
  const vo2  = safeN(G.currentData?.vo2, 0);
  const rer  = safeN(G.currentData?.rer, 0);
  // SSOT: RMR siempre vía calcHybrid — nunca Weir independiente
  let rmr = 0;
  if(cal){ rmr = cal.rmr; }
  else if(vo2 > 0 && rer > 0){
    const _fb = calcHybrid(vo2*weight, vo2*rer*weight, rer);
    if(_fb) rmr = _fb.rmr;
  }

  setText('bari-mifflin', mifflin.toFixed(0));
  setText('bari-owen',    owen.toFixed(0));
  setText('bari-hb',      hb.toFixed(0));
  setText('bari-rmr',     rmr > 0 ? rmr.toFixed(0) : '--');

  // ── 2. Acuerdo RMR medido vs ecuaciones ──────────────────────────────────
  if(rmr > 0){
    const diffM = ((rmr-mifflin)/mifflin*100);
    const diffO = ((rmr-owen)/owen*100);
    const diffH = ((rmr-hb)/hb*100);
    const _fmt  = v => (v > 0 ? '+' : '') + v.toFixed(1) + '%';
    const _col  = v => Math.abs(v) <= 10 ? '#22c55e' : Math.abs(v) <= 20 ? '#fbbf24' : '#f87171';
    document.getElementById('bari-diff-mifflin').style.color = _col(diffM);
    document.getElementById('bari-diff-owen').style.color    = _col(diffO);
    document.getElementById('bari-diff-hb').style.color      = _col(diffH);
    setText('bari-diff-mifflin', _fmt(diffM));
    setText('bari-diff-owen',    _fmt(diffO));
    setText('bari-diff-hb',      _fmt(diffH));
    const avgDiff = (Math.abs(diffM)+Math.abs(diffO)+Math.abs(diffH))/3;
    const agree   = Math.max(0, Math.min(100, 100 - avgDiff*2));
    const agreeEl = document.getElementById('bari-agree-bar');
    if(agreeEl) agreeEl.style.width = agree.toFixed(0) + '%';
    const agreeLabel = agree >= 80 ? '✅ Buen acuerdo (±10%)' : agree >= 60 ? '⚠️ Acuerdo moderado' : '❌ Discrepancia significativa';
    const agreeColor = agree >= 80 ? '#22c55e' : agree >= 60 ? '#fbbf24' : '#f87171';
    const agreeEl2 = document.getElementById('bari-rmr-agree');
    if(agreeEl2){agreeEl2.textContent = agreeLabel; agreeEl2.style.color = agreeColor;}
  }

  // ── 3. RQ interpretación clínica ──────────────────────────────────────────
  const rqDisplay = document.getElementById('bari-rq');
  if(rer > 0 && rqDisplay){
    rqDisplay.textContent = rer.toFixed(3);
    const cursor = document.getElementById('bari-rq-cursor');
    const pct = Math.max(0, Math.min(100, (rer - 0.70) / 0.50 * 100));  // [0.70, 1.20] → [0, 100%]
    if(cursor) cursor.style.left = pct.toFixed(0) + '%';
    // Interpretación clínica RQ
    let rqLabel, rqColor, rqInterp;
    if(rer < 0.75){
      rqLabel = 'Cetosis / Predominio Grasas'; rqColor = '#ff6b35';
      rqInterp = [
        {icon:'🔥',txt:'Oxidación de ácidos grasos dominante (>80% sustrato lipídico)'},
        {icon:'⚠️',txt:'Posible ayuno prolongado o dieta muy restringida en CHO'},
        {icon:'🩺',txt:'Verificar aporte calórico mínimo y estado nutricional'},
        {icon:'💊',txt:'Considerar suplementación proteica para preservar masa magra'}
      ];
    } else if(rer <= 0.85){
      rqLabel = 'Predominio Grasas (óptimo bariátrico)'; rqColor = '#22c55e';
      rqInterp = [
        {icon:'✅',txt:'RQ en rango ideal para pérdida de peso post-bariátrica'},
        {icon:'🔥',txt:'Alta eficiencia en oxidación de grasas (60–80% lipídico)'},
        {icon:'💪',txt:'Buena adaptación metabólica post-quirúrgica'},
        {icon:'🏃',txt:'Intensidad de ejercicio adecuada para FatMax en esta fase'}
      ];
    } else if(rer <= 0.95){
      rqLabel = 'Metabolismo Mixto'; rqColor = '#60a5fa';
      rqInterp = [
        {icon:'⚖️',txt:'Mezcla de sustratos. Adaptación a ingesta normal de CHO'},
        {icon:'📊',txt:'Esperable en fase avanzada con reintroducción de carbohidratos'},
        {icon:'🔍',txt:'Monitorear evolución hacia mayor oxidación lipídica en reposo'},
        {icon:'🥗',txt:'Ajustar distribución de macros según objetivo de la fase'}
      ];
    } else if(rer <= 1.05){
      rqLabel = 'Predominio CHO / Lípogenesis'; rqColor = '#fbbf24';
      rqInterp = [
        {icon:'⚠️',txt:'Ingesta de CHO supera oxidación — posible síntesis de grasa'},
        {icon:'🍞',txt:'Evaluar calidad y cantidad de carbohidratos en la dieta'},
        {icon:'💡',txt:'Ejercicio en zona VT1 puede mejorar partición metabólica'},
        {icon:'🩺',txt:'Revisar cumplimiento del plan nutricional por fase'}
      ];
    } else if(rer <= 1.20){
      rqLabel = 'Anaerobiosis / Ejercicio Intenso (RQ > 1.05)'; rqColor = '#ec4899';
      rqInterp = [
        {icon:'⚡',txt:'RER > 1.0 normal en ejercicio anaeróbico (>VT2)'},
        {icon:'🍯',txt:'Oxidación completa de CHO + síntesis de grasa a partir de CHO'},
        {icon:'🔥',txt:'Esperado en esfuerzo máximo o cargas > 80% VO₂max'},
        {icon:'📈',txt:'Verificar que la mascarilla está bien sellada (no es artefacto)'}
      ];
    } else {
      rqLabel = 'RQ > 1.20 — Posible Artefacto'; rqColor = '#f87171';
      rqInterp = [
        {icon:'🚨',txt:'RQ > 1.20 es muy raro — probablemente error de medición'},
        {icon:'🔧',txt:'Verificar sellado de mascarilla y calibración del sensor CO₂'},
        {icon:'⚠️',txt:'Verificar que no hay entrada de aire externo o CO₂ residual'},
        {icon:'🔄',txt:'Repetir medición y calibrar sensores antes de continuar'}
      ];
    }
    const lEl = document.getElementById('bari-rq-label');
    if(lEl){lEl.textContent = rqLabel; lEl.style.color = rqColor;}
    const iEl = document.getElementById('bari-rq-interp');
    if(iEl) iEl.innerHTML = rqInterp.map(r=>
      `<div style="display:flex;gap:8px;font-size:0.75rem;color:var(--muted2);padding:3px 0;">`+
      `<span style="flex-shrink:0;">${r.icon}</span><span>${r.txt}</span></div>`
    ).join('');
  }

  // ── 4. Clasificación metabólica bariátrica ────────────────────────────────
  const pctPred = G.vo2pred > 0 ? (vo2 / G.vo2pred * 100) : 0;
  const classes = [];
  if(vo2 > 0){
    if(vo2 < 14)     classes.push({icon:'🔴',label:'Capacidad aeróbica muy baja',sub:'VO₂ <14 — alto riesgo perioperatorio (AHA 2022)',color:'#f87171'});
    else if(vo2 < 18) classes.push({icon:'🟠',label:'Capacidad aeróbica baja',sub:'VO₂ 14–18 — riesgo moderado, indicación de prehab',color:'#fb923c'});
    else if(vo2 < 25) classes.push({icon:'🟡',label:'Capacidad aeróbica regular',sub:'VO₂ 18–25 — evolución esperada post-bariátrica',color:'#fbbf24'});
    else              classes.push({icon:'🟢',label:'Buena capacidad aeróbica',sub:'VO₂ >25 — excelente pronóstico funcional',color:'#22c55e'});
  }
  if(rer > 0){
    if(rer < 0.80)     classes.push({icon:'🔥',label:'Oxidador de grasas predominante',sub:'Ideal para mantenimiento ponderal a largo plazo',color:'#ff6b35'});
    else if(rer > 1.0) classes.push({icon:'⚠️',label:'Lipogénesis activa o medición atípica',sub:'Revisar dieta y condiciones de medición',color:'#f87171'});
    else               classes.push({icon:'⚗️',label:'Metabolismo mixto balanceado',sub:'Rango esperado en fase de consolidación',color:'#60a5fa'});
  }
  if(rmr > 0){
    const metaRatio = rmr / mifflin;
    if(metaRatio < 0.85)      classes.push({icon:'❄️',label:'Hipometabolismo (≤85% predicho)',sub:'Frecuente >12 meses post-bariátrica — ajustar prescripción',color:'#60a5fa'});
    else if(metaRatio > 1.15) classes.push({icon:'⚡',label:'Hipermetabolismo (≥115% predicho)',sub:'Verificar estado inflamatorio o error de medición',color:'#fbbf24'});
    else                       classes.push({icon:'✅',label:'Metabolismo basal esperado',sub:'Acuerdo ±15% con Mifflin (rango clínicamente aceptado)',color:'#22c55e'});
  }
  const gridEl = document.getElementById('bari-class-grid');
  if(gridEl && classes.length){
    gridEl.innerHTML = classes.map(c=>
      `<div style="background:var(--card2);border:1px solid ${c.color}33;border-left:3px solid ${c.color};border-radius:var(--radius-sm);padding:12px;">
        <div style="font-size:1rem;margin-bottom:4px;">${c.icon}</div>
        <div style="font-size:0.78rem;font-weight:700;color:${c.color};">${c.label}</div>
        <div style="font-size:0.65rem;color:var(--muted2);margin-top:3px;line-height:1.4;">${c.sub}</div>
      </div>`
    ).join('');
  }

  // ── 5. Prescripción calórica por fase ─────────────────────────────────────
  const rmrBase = rmr > 0 ? rmr : mifflin;
  const tableEl = document.getElementById('bari-phase-table');
  if(tableEl){
    const activePhase = _bariPhase >= 0 ? _bariPhase : -1;
    tableEl.innerHTML = BARI_PHASES.map((ph, idx)=>{
      const protG = (ph.prot_gkg * weight).toFixed(0);
      const isActive = idx === activePhase;
      const rowStyle = isActive ? `background:${BARI_PHASE_COLORS[idx]}18;` : '';
      const activeMarker = isActive ? '◀ ACTUAL' : '';
      return `<tr style="${rowStyle}border-bottom:1px solid rgba(255,255,255,0.04);">
        <td style="padding:8px 12px;font-weight:${isActive?'700':'400'};color:${BARI_PHASE_COLORS[idx]};">${ph.label} <span style="font-size:0.6rem;color:var(--accent);font-weight:800;">${activeMarker}</span></td>
        <td style="padding:8px 12px;text-align:center;font-family:var(--mono);">${ph.kcalMin}–${ph.kcalMax}</td>
        <td style="padding:8px 12px;text-align:center;font-family:var(--mono);">${protG} g/día (${ph.prot_gkg} g/kg)</td>
        <td style="padding:8px 12px;text-align:center;font-size:0.72rem;color:var(--muted2);">${ph.dur}</td>
        <td style="padding:8px 12px;font-size:0.72rem;color:var(--muted2);">${ph.goal}</td>
      </tr>`;
    }).join('');
  }

  // ── 6. TEE desglosado ─────────────────────────────────────────────────────
  if(rmrBase > 0){
    const tee  = rmrBase / 0.71;
    const tef  = tee * 0.10;
    const eat  = tee * 0.19;
    setText('bari-tee-rmr',   rmrBase.toFixed(0));
    setText('bari-tee-tef',   tef.toFixed(0));
    setText('bari-tee-eat',   eat.toFixed(0));
    setText('bari-tee-total', tee.toFixed(0));
  }

  // ── 7. Macronutrientes ────────────────────────────────────────────────────
  const curPhase = BARI_PHASES[_bariPhase >= 0 ? _bariPhase : 0];
  const kcalTarget = (curPhase.kcalMin + curPhase.kcalMax) / 2;
  const protG  = (curPhase.prot_gkg * weight);
  const protKcal = protG * 4;
  const remKcal  = Math.max(0, kcalTarget - protKcal);
  const carbG  = (remKcal * 0.55 / 4);
  const fatG   = (remKcal * 0.45 / 9);
  setText('bari-prot-g', protG.toFixed(0));
  setText('bari-prot-gkg', curPhase.prot_gkg.toFixed(1));
  setText('bari-carb-g',  carbG.toFixed(0));
  setText('bari-fat-g',   fatG.toFixed(0));
  const protPct = kcalTarget > 0 ? (protKcal/kcalTarget*100) : 0;
  const carbPct = kcalTarget > 0 ? (remKcal*0.55/kcalTarget*100) : 0;
  const fatPct  = kcalTarget > 0 ? (remKcal*0.45/kcalTarget*100) : 0;
  const pBarEl = document.getElementById('bari-prot-bar');
  const cBarEl = document.getElementById('bari-carb-bar');
  const fBarEl = document.getElementById('bari-fat-bar');
  if(pBarEl) pBarEl.style.width = protPct.toFixed(0)+'%';
  if(cBarEl) cBarEl.style.width = carbPct.toFixed(0)+'%';
  if(fBarEl) fBarEl.style.width = fatPct.toFixed(0)+'%';

  // ── 8. IRB Score ──────────────────────────────────────────────────────────
  let irb = 0, irbFactors = 0;
  let vo2Pts = 0, rqPts = 0, tmbPts = 0;
  if(vo2 > 0)   { vo2Pts = Math.min(40, (vo2 / 40) * 40); irb += vo2Pts; irbFactors++; }
  if(rer > 0)   { rqPts = rer <= 0.85 ? 25 : rer <= 0.95 ? 20 : rer <= 1.05 ? 10 : 0; irb += rqPts; irbFactors++; }
  if(rmr > 0)   { const metaRatio = rmr/mifflin; tmbPts = (metaRatio >= 0.85 && metaRatio <= 1.15) ? 25 : (metaRatio >= 0.75 && metaRatio <= 1.25) ? 15 : 5; irb += tmbPts; irbFactors++; }
  const irbFinal = irbFactors > 0 ? Math.round(irb) : 0;
  const irbLabel = irbFinal >= 75 ? 'Excelente' : irbFinal >= 55 ? 'Moderado' : irbFinal >= 35 ? 'Bajo' : irbFinal > 0 ? 'Crítico' : 'Sin datos';
  const irbColor = irbFinal >= 75 ? '#d6da13' : irbFinal >= 55 ? '#60a5fa' : irbFinal >= 35 ? '#fbbf24' : '#f87171';
  const scoreBadgeEl = document.getElementById('bari-score-badge');
  if(scoreBadgeEl){scoreBadgeEl.textContent = irbFinal > 0 ? irbFinal : '--'; scoreBadgeEl.style.background=`linear-gradient(135deg,${irbColor},#00aeff)`;}
  const irbLabelEl = document.getElementById('bari-irb-label');
  if(irbLabelEl){irbLabelEl.textContent = irbLabel; irbLabelEl.style.color = irbColor;}
  // Desglose IRB — barras por componente
  setText('bari-irb-vo2-pts', vo2Pts > 0 ? vo2Pts.toFixed(0) : '--');
  setText('bari-irb-rq-pts',  rer > 0    ? rqPts.toFixed(0)  : '--');
  setText('bari-irb-tmb-pts', rmr > 0    ? tmbPts.toFixed(0) : '--');
  const vo2BarEl = document.getElementById('bari-irb-vo2-bar');
  const rqBarEl  = document.getElementById('bari-irb-rq-bar');
  const tmbBarEl = document.getElementById('bari-irb-tmb-bar');
  if(vo2BarEl) vo2BarEl.style.width = (vo2Pts / 40 * 100).toFixed(0) + '%';
  if(rqBarEl)  rqBarEl.style.width  = (rqPts  / 25 * 100).toFixed(0) + '%';
  if(tmbBarEl) tmbBarEl.style.width = (tmbPts / 25 * 100).toFixed(0) + '%';
  const phaseBadgeEl = document.getElementById('bari-phase-badge');
  if(phaseBadgeEl && _bariPhase >= 0){
    phaseBadgeEl.textContent = BARI_PHASES[_bariPhase].label;
    phaseBadgeEl.style.color = BARI_PHASE_COLORS[_bariPhase];
    phaseBadgeEl.style.borderColor = BARI_PHASE_COLORS[_bariPhase]+'66';
    phaseBadgeEl.style.background  = BARI_PHASE_COLORS[_bariPhase]+'22';
  }
  const phaseDescEl = document.getElementById('bari-phase-desc');
  if(phaseDescEl && _bariPhase >= 0){
    const ph = BARI_PHASES[_bariPhase];
    phaseDescEl.innerHTML = `<strong style="color:${BARI_PHASE_COLORS[_bariPhase]}">${ph.label}</strong> · ${ph.kcalMin}–${ph.kcalMax} kcal/día · Proteína: ${ph.prot_gkg} g/kg · Duración: ${ph.dur}<br><span style="font-size:0.72rem;color:var(--muted2);">${ph.goal}</span>`;
  }

  // ── 9. Riesgo pérdida masa magra ──────────────────────────────────────────
  if(curPhase && weight > 0){
    const protReq_gkg   = curPhase.prot_gkg;
    const protReq_g     = protReq_gkg * weight;
    const rawInput      = parseFloat(document.getElementById('bari-prot-input')?.value);
    const protIntake_g  = isFinite(rawInput) && rawInput > 0 ? rawInput : 0;
    const protIntake_gkg = protIntake_g > 0 ? protIntake_g / weight : 0;
    const hasInput      = protIntake_g > 0;

    if(hasInput){
      // ASMBS 2022: <1.0 g/kg = alto; 1.0–1.2 = moderado; ≥1.2–<1.5 = bajo; ≥1.5 = mínimo
      const riskPct   = protIntake_gkg < 1.0 ? 90 : protIntake_gkg < 1.2 ? 55 : protIntake_gkg < 1.5 ? 25 : 10;
      const riskColor = riskPct >= 70 ? '#f87171' : riskPct >= 40 ? '#fbbf24' : '#22c55e';
      const riskLabel = riskPct >= 70 ? '🔴 Alto' : riskPct >= 40 ? '🟡 Moderado' : '🟢 Bajo';
      const protDeficit_g = Math.max(0, protReq_g - protIntake_g);
      setText('bari-mm-prot-intake',  protIntake_gkg.toFixed(2));
      setText('bari-mm-prot-req',     protReq_gkg.toFixed(1));
      const defEl = document.getElementById('bari-mm-prot-deficit');
      if(defEl){
        defEl.textContent = protDeficit_g > 0 ? protDeficit_g.toFixed(0) : '0';
        defEl.style.color = protDeficit_g > 0 ? '#f87171' : '#22c55e';
      }
      const mmRiskLabelEl = document.getElementById('bari-mm-risk-label');
      if(mmRiskLabelEl){ mmRiskLabelEl.textContent = riskLabel; mmRiskLabelEl.style.color = riskColor; }
      const mmRiskBarEl = document.getElementById('bari-mm-risk-bar');
      if(mmRiskBarEl){ mmRiskBarEl.style.width = riskPct + '%'; mmRiskBarEl.style.background = riskColor; }
      const riskInterp = riskPct >= 70
        ? '⚠️ Aporte proteico insuficiente (ASMBS 2022). Riesgo elevado de catabolismo muscular. Meta: ' + protReq_gkg.toFixed(1) + ' g/kg/día (' + protReq_g.toFixed(0) + ' g/día). Déficit actual: ' + protDeficit_g.toFixed(0) + ' g/día. Considerar suplementación con proteína de suero o caseína.'
        : riskPct >= 40
        ? '⚠️ Aporte proteico en límite inferior (ASMBS 2022). Monitorear masa magra con bioimpedancia cada 4 semanas. Priorizar fuentes de alto valor biológico (huevo, pescado, lácteos). Déficit: ' + protDeficit_g.toFixed(0) + ' g/día vs meta ' + protReq_g.toFixed(0) + ' g/día.'
        : '✅ Aporte proteico adecuado para la fase actual (' + protIntake_gkg.toFixed(2) + ' g/kg/día ≥ ' + protReq_gkg.toFixed(1) + ' g/kg recomendado). Mantener distribución en 4–6 comidas pequeñas. Evaluar tolerancia a textura según evolución clínica.';
      setText('bari-mm-risk-interp', riskInterp);
    } else {
      // Sin dato de aporte: mostrar objetivo de fase como referencia
      setText('bari-mm-prot-intake',  '--');
      setText('bari-mm-prot-req',     protReq_gkg.toFixed(1));
      setText('bari-mm-prot-deficit', '--');
      const mmRiskLabelEl = document.getElementById('bari-mm-risk-label');
      if(mmRiskLabelEl){ mmRiskLabelEl.textContent = '--'; mmRiskLabelEl.style.color = 'var(--muted)'; }
      const mmRiskBarEl = document.getElementById('bari-mm-risk-bar');
      if(mmRiskBarEl){ mmRiskBarEl.style.width = '0%'; }
      setText('bari-mm-risk-interp', 'Ingrese el aporte proteico real del paciente (g/día) para calcular riesgo. Meta fase actual: ' + protReq_gkg.toFixed(1) + ' g/kg/día (' + protReq_g.toFixed(0) + ' g/día para ' + weight + ' kg).');
    }
  }

  // ── 10. Recomendaciones clínicas integradas ───────────────────────────────
  const recs = [];
  if(vo2 > 0 && vo2 < 18)  recs.push({icon:'🏥',title:'Prehabilitation física',body:'VO₂ < 18 ml/kg/min indica alto riesgo. Prescribir ejercicio preoperatorio supervisado 4–6 sem.',color:'#f87171'});
  if(vo2 >= 18)             recs.push({icon:'🏃',title:'Entrenamiento en VT1',body:'Ejercicio en zona aeróbica baja (50–60% VO₂max) para optimizar partición de sustratos.',color:'#22c55e'});
  recs.push({icon:'💪',title:'Fuerza 3× semana',body:'Preservar masa magra es prioridad en todas las fases. Mínimo 2 sesiones resistencia/semana.',color:'#60a5fa'});
  if(rer < 0.80)            recs.push({icon:'🥑',title:'Monitorear ingesta calórica',body:'RQ < 0.80 puede indicar déficit calórico excesivo. Verificar aporte mínimo proteico ('+protG.toFixed(0)+' g/día).',color:'#fbbf24'});
  if(rer > 1.0)             recs.push({icon:'🍽️',title:'Revisar distribución de CHO',body:'RQ > 1.0 indica exceso de carbohidratos. Reducir índice glucémico y frecuencia de ingesta.',color:'#fbbf24'});
  recs.push({icon:'💊',title:'Suplementación micronutrientes',body:'Vitamina D, B12, hierro, calcio y zinc según protocolo ASMBS. Control analítico cada 3 meses.',color:'#a855f7'});
  if(_bariPhase >= 1 && _bariPhase <= 2) recs.push({icon:'💧',title:'Hidratación prioritaria',body:'Mínimo 1.5 L/día sorbos pequeños. Evitar ingesta durante 30 min post-comida.',color:'#60a5fa'});
  const recGrid = document.getElementById('bari-rec-grid');
  if(recGrid) recGrid.innerHTML = recs.map(r=>
    `<div style="background:var(--card);border:1px solid ${r.color}33;border-left:3px solid ${r.color};border-radius:var(--radius-sm);padding:12px;">
      <div style="font-size:0.82rem;font-weight:700;color:${r.color};margin-bottom:4px;">${r.icon} ${r.title}</div>
      <div style="font-size:0.72rem;color:var(--muted2);line-height:1.5;">${r.body}</div>
    </div>`
  ).join('');

  // ── 11. Alertas clínicas ──────────────────────────────────────────────────
  const alerts = [];
  if(vo2 > 0 && vo2 < 14) alerts.push('🚨 VO₂ < 14 ml/kg/min — alto riesgo quirúrgico. Consultar equipo multidisciplinario.');
  if(rer > 1.10)           alerts.push('⚠️ RQ > 1.10 — verificar sellado mascarilla, calibración sensor CO₂ o hiperventilación.');
  if(rmr > 0 && rmr < mifflin * 0.75) alerts.push('❄️ Hipometabolismo severo (< 75% predicho). Evaluar función tiroidea y adherencia nutricional.');
  const alertsBox  = document.getElementById('bari-alerts-box');
  const alertsList = document.getElementById('bari-alerts-list');
  if(alertsBox && alertsList){
    alertsBox.style.display  = alerts.length ? 'block' : 'none';
    alertsList.innerHTML = alerts.map(a=>`<div>${a}</div>`).join('');
  }
}

