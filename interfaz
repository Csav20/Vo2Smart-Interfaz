async function connectHR(){
  // ── UUIDs Garmin propietarios (identificados via nRF Connect) ──
  // GARMIN_ADV_UUID: UUID que el Forerunner anuncia en advertising packet (visible en nRF)
  // GARMIN_SVC_RUN:  Servicio disponible DESPUÉS de conectar (no en advertising)
  const GARMIN_ADV_UUID = '6a4e3e10-667b-11e3-949a-0800200c9a66';
  const GARMIN_SVC_RUN  = '6a4e2500-667b-11e3-949a-0800200c9a66';
  const GARMIN_CHR_HR   = '6a4e2502-667b-11e3-949a-0800200c9a66';
  const GARMIN_SVC_CMD  = '6a4e2401-667b-11e3-949a-0800200c9a66';

  if(!navigator.bluetooth){toast('Web Bluetooth no soportado','error');return;}
  try{
    // Filtros OR: usa el UUID ANUNCIADO por el Garmin (6A4E3E10) + estándar + namePrefix
    const dev=await navigator.bluetooth.requestDevice({
      filters:[
        {services:['heart_rate']},
        {services:[GARMIN_ADV_UUID]},
        {namePrefix:'Forerunner'},
        {namePrefix:'Garmin'},
        {namePrefix:'fenix'},
        {namePrefix:'vivoactive'},
        {namePrefix:'epix'}
      ],
      optionalServices:[
        'heart_rate',
        GARMIN_ADV_UUID,
        GARMIN_SVC_RUN,
        GARMIN_SVC_CMD,
        '6a4e8022-667b-11e3-949a-0800200c9a66',
        '6a4e2800-667b-11e3-949a-0800200c9a66'
      ]
    });

    const srv=await dev.gatt.connect();
    const devName=dev.name||'HR Sensor';
    let hrChar, isGarmin=false;

    // Intento 1: Heart Rate Service estándar (Bluetooth SIG 0x180D)
    try{
      const svc=await srv.getPrimaryService('heart_rate');
      hrChar=await svc.getCharacteristic('heart_rate_measurement');
    }catch(_){
      // Sin servicio estándar → Garmin propietario (6A4E2500 / 6A4E2502)
      try{
        const svc=await srv.getPrimaryService(GARMIN_SVC_RUN);
        hrChar=await svc.getCharacteristic(GARMIN_CHR_HR);
        isGarmin=true;
      }catch(_2){
        throw new Error('No se encontró servicio HR compatible.\n'+
          'Garmin: activa Settings > Heart Rate > Broadcast HR');
      }
    }

    await hrChar.startNotifications();
    hrChar.addEventListener('characteristicvaluechanged',e=>{
      const dv=e.target.value;
      const rrList=[];
      let hr=0;

      if(!isGarmin){
        // ── Protocolo estándar Bluetooth SIG (0x180D) ──
        const flags=dv.getUint8(0);
        let offset=1;
        if(flags&0x01){hr=dv.getUint16(offset,true);offset+=2;}
        else{hr=dv.getUint8(offset);offset+=1;}
        if(flags&0x08)offset+=2;// energy expended
        if(flags&0x10){// RR-intervals
          while(offset+1<dv.byteLength){
            const rrMs=dv.getUint16(offset,true)/1024*1000;
            if(rrMs>200&&rrMs<2000)rrList.push(rrMs);
            offset+=2;
          }
        }
      }else{
        // ── Protocolo Garmin propietario (6A4E2502) ──
        // Diagnóstico: muestra bytes crudos en consola para ajuste de offset
        const raw=Array.from({length:dv.byteLength},(_,i)=>
          dv.getUint8(i).toString(16).padStart(2,'0'));
        console.log('[Garmin 6A4E2502 raw]',raw.join(' '));
        // Extraer HR: busca el primer byte en rango fisiológico [30-220]
        // Formato Garmin running metrics: byte 0=flags, byte 1=HR uint8
        for(let b=0;b<Math.min(dv.byteLength,4);b++){
          const c=dv.getUint8(b);
          if(c>=30&&c<=220){hr=c;break;}
        }
      }

      // Fallback: sintetizar RR desde FC si no hay RR reales
      if(rrList.length===0&&hr>30&&hr<220)rrList.push(60000/hr);
      if(hr>0)feedRR(rrList,hr);
    });

    G.hrDevice=dev;
    const modeLabel=isGarmin
      ? '\uD83D\uDD35 '+devName+' (Garmin directo — sin RR reales)'
      : '\uD83D\uDD35 '+devName+' — RR-intervals reales activos';
    setText('hrv-source',modeLabel);
    setText('hrv-count','0 RR recibidos');
    dev.addEventListener('gattserverdisconnected',()=>{
      toast('Monitor FC desconectado','warn');
      G.hrDevice=null;
      G.lastBleHR=0;
      G.lastBleHRts=0;
      setText('hrv-source','Sin sensor HR');
      setText('hrv-count','0 RR recibidos');
    });
    toast('Monitor FC: '+devName+(isGarmin?' (Garmin directo)':'  OK'),'success');
  }catch(e){toast('Error FC: '+e.message,'error');}
}

// Helper: alimenta RR-intervals al motor HRV
function feedRR(rrList,hr){
  const now=Date.now();
  // Persist latest BLE HR for use by processData when VO2 data arrives without HR
  if(hr>0){
    G.lastBleHR=hr;
    G.lastBleHRts=now;
  }
  for(const rr of rrList){G.rrBuffer.push(rr);G.rrTimestamps.push(now);}
  const cutoff=now-120000;
  while(G.rrTimestamps.length>0&&G.rrTimestamps[0]<cutoff){
    G.rrTimestamps.shift();G.rrBuffer.shift();
  }
  if(G.rrBuffer.length>=6)computeHRV();
  // Update HR display immediately (dashboard + mini chart) without re-processing all data
  // This avoids duplicate chart entries and rawBuffer pollution
  if(hr>0){
    setText('d-hr',hr.toFixed(0));
    if(hr>G.hrPeak)G.hrPeak=hr;
    const hrMax=getPatient().hrMax||190;
    const hrRest=getPatient().hrRest||60;
    const hrr=hrMax>hrRest?Math.round((hr-hrRest)/(hrMax-hrRest)*100):0;
    setText('d-hrr',isFinite(hrr)?hrr:'--');
    pushMini(G.charts.mc.hr,hr);
  }
}

function handleBLE(event){
  G.bleBuffer+=G.decoder.decode(event.target.value);
  let depth=0,start=-1,cu=0;
  for(let i=0;i<G.bleBuffer.length;i++){
    if(G.bleBuffer[i]==='{'){if(!depth)start=i;depth++;}
    else if(G.bleBuffer[i]==='}'&&depth>0){depth--;if(!depth&&start>=0){
      try{const _bd=JSON.parse(G.bleBuffer.slice(start,i+1));processData(_bd);vtUpdateFromData(_bd);}catch(e){console.warn('BLE JSON parse error:',e.message);}
      cu=i+1;start=-1;
    }}
  }
  G.bleBuffer=cu>0?G.bleBuffer.slice(cu):G.bleBuffer;
  if(G.bleBuffer.length>1200)G.bleBuffer=G.bleBuffer.slice(-400);
}

