  _markerCatSelected=btn.dataset.cat;
  document.querySelectorAll('.marker-cat-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function showMarkerInput(){
  if(G.testState==='idle')return;
  initBorgGrid();
  _markerBorgSelected=null;
  _markerCatSelected='RPE';
  document.querySelectorAll('.borg-btn').forEach(b=>b.classList.remove('selected'));
  document.querySelectorAll('.marker-cat-btn').forEach(b=>b.classList.remove('active'));
  const rpeBtn=document.querySelector('[data-cat="RPE"]');
  if(rpeBtn)rpeBtn.classList.add('active');
  const elapsed=getTestElapsed();
  const el=document.getElementById('marker-modal-elapsed');
  if(el)el.textContent=formatDur(elapsed);
  const inp=document.getElementById('marker-text-input');
  if(inp){inp.value='';setTimeout(()=>inp.focus(),180);}
  const ov=document.getElementById('marker-modal-overlay');
  if(ov)ov.classList.add('open');
}

function closeMarkerModal(){
  const ov=document.getElementById('marker-modal-overlay');
  if(ov)ov.classList.remove('open');
}

function confirmMarkerInput(){
  const inp=document.getElementById('marker-text-input');
  const freeText=(inp?inp.value.trim():'');
  const borg=_markerBorgSelected;
  const cat=_markerCatSelected||'Nota';
  // Build label
  let parts=[];
  if(borg)parts.push('Borg '+borg);
  if(freeText)parts.push(freeText);
  const label=parts.length?parts.join(' · '):('Marcador #'+(G.testMarkers.length+1));
  closeMarkerModal();
  addMarker(label,borg,cat);
}

function addMarker(label,borg,cat){
  if(G.testState==='idle')return;
  const elapsed=getTestElapsed();
  const ts=new Date().toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const ml=label||('Marcador #'+(G.testMarkers.length+1));
  G.testMarkers.push({time:ts,elapsed:formatDur(elapsed),label:ml,borg:borg||null,cat:cat||null});

  const container=document.getElementById('markers-container');
  container.style.display='block';
  const bar=document.getElementById('markers-bar');
  const borgStr=borg?` <span style="color:${BORG_COLORS[borg]||'#c084fc'};font-weight:900;">[${borg}]</span>`:'';
  bar.innerHTML+=`<span class="marker-tag">${formatDur(elapsed)}${borgStr} · ${escHtml(ml)}</span>`;
  sendMarkerToDevice(ml);
  toast(t('toast_marker')+' '+ml,'info');
}

function updateTestTimer(){
  if(G.testState==='idle')return;
  const el=document.getElementById('test-timer');
  if(!el)return;
  const elapsed=getTestElapsed();
  el.textContent=formatDur(elapsed);
  updateProtocolPanelTick(false);
}

function getTestElapsed(){
  if(!G.testStartTime)return 0;
  let e=Date.now()-G.testStartTime-G.testPauseElapsed;
  if(G.testPauseStart)e-=(Date.now()-G.testPauseStart);
  return Math.max(0,e);
}

function updateTestUI(){
  const bar=document.getElementById('test-bar');
  const timer=document.getElementById('test-timer');
  const recDot=document.getElementById('rec-dot');
  const btnStart=document.getElementById('btn-start');
  const btnPause=document.getElementById('btn-pause');
  const btnStop=document.getElementById('btn-stop');
  const btnMarker=document.getElementById('btn-marker');
  const btnPhase=document.getElementById('btn-phase');
  const pSelect=document.getElementById('protocol-select');

  if(G.testState==='running'){
    bar.classList.add('recording');bar.classList.remove('paused');
    timer.classList.add('recording');timer.classList.remove('paused');
    recDot.classList.add('on');
    btnStart.disabled=true;btnPause.disabled=false;btnStop.disabled=false;
    btnMarker.disabled=false;btnPhase.disabled=false;
    pSelect.disabled=true;
  }else if(G.testState==='paused'){
    bar.classList.remove('recording');bar.classList.add('paused');
    timer.classList.remove('recording');timer.classList.add('paused');
    recDot.classList.remove('on');
    setTestPhase('paused');
    btnStart.disabled=false;btnStart.innerHTML=t('btn_resume','▶ Reanudar');
    btnPause.disabled=true;btnStop.disabled=false;
    btnMarker.disabled=false;btnPhase.disabled=true;
    pSelect.disabled=true;
  }else{
    bar.classList.remove('recording','paused');
    timer.classList.remove('recording','paused');
    recDot.classList.remove('on');
    btnStart.disabled=false;btnStart.innerHTML=t('btn_start','▶ Iniciar Prueba');
    btnPause.disabled=true;btnStop.disabled=true;
    btnMarker.disabled=true;btnPhase.disabled=true;
    pSelect.disabled=false;
  }
}

