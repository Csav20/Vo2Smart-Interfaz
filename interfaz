function saveSessionToArchive(){
  if(!G.session.length||G.session.length<3)return;
  const sessions=getSavedSessions();
  const patientName=(document.getElementById('u-name')?.value||'').trim();
  const entry={
    id:Date.now().toString(36)+Math.random().toString(36).slice(2,6),
    date:new Date().toISOString(),
    patient:patientName||'Sin nombre',
    evaluator:(document.getElementById('u-evaluator')?.value||'').trim()||'--',
