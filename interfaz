function getPreviousSession(patientName){
  if(!patientName)return null;
  const sessions=getSavedSessions();
  const name=patientName.toLowerCase().trim();
  // Find most recent session for this patient (skip current - it may have just been saved)
  const matches=sessions.filter(s=>s.patient.toLowerCase().trim()===name);
  return matches.length>1?matches[1]:matches.length===1?matches[0]:null;
