// BLE CONNECTION - VO2Smart
// ═══════════════════════════════════════════════════
// ═══════════════════════════════════════════════════
// BLE COMMAND SYSTEM — Bidireccional con ESP32
// Protocolo: WEIGHT:xx.x, GET_WEIGHT, PROTOCOL:xxx,
// SET_PHASE:xxx, START_TEST, STOP_TEST, ADD_MARKER:xxx
// ═══════════════════════════════════════════════════
// R-DASH-03: BLE command queue — serializa comandos para evitar GATT collision
let _bleChain=Promise.resolve();
async function sendBLECommand(cmd){
  const task=_bleChain.then(()=>_sendBLEImpl(cmd));
  _bleChain=task.catch(()=>{});
  return task;
}
async function _sendBLEImpl(cmd){
  const ch = G.bleApiCh || G.bleCh;
  if(!ch){
    if(G.serialWriter){
      try{
        await G.serialWriter.write(new TextEncoder().encode(cmd+'\n'));
        console.log('📤 SERIAL TX:',cmd);
        return true;
      }catch(e){
        console.error('SERIAL TX error:',e.message);
        return false;
      }
    }
    console.warn('BLE/Serial not connected:',cmd);
    return null;
  }
  try{
    await ch.writeValue(new TextEncoder().encode(cmd));
    console.log('📤 BLE TX:',cmd);
    return true;
  }catch(e){
    console.error('BLE TX error:',e.message);
    if(ch===G.bleApiCh && G.bleCh){
      try{await G.bleCh.writeValue(new TextEncoder().encode(cmd));return true;}catch(e2){}
    }
    if(G.serialWriter){
      try{await G.serialWriter.write(new TextEncoder().encode(cmd+'\n'));return true;}catch(e3){}
    }
    return false;
  }
}

function handleRemoteCommandRaw(raw){
  console.log('📨 BLE API:',raw);
  try{
    const r=JSON.parse(raw);
    if(r.device&&(G.serialConnected||G.bleCh||G.bleApiCh)){
      setDiagDeviceName(r.device);
      setConnected(true,`Conectado: ${r.device}`);
    }
    if((r.cmd==='GET_WEIGHT'||r.cmd==='WEIGHT')&&r.weight&&r.status==='OK'){
      const el=document.getElementById('u-weight');
      if(el&&(!el.value||el.value==='0'||el.value==='75')){
        el.value=r.weight;
        updateCalcFields();
        toast(t('toast_weight_synced')+' '+r.weight+' kg','success');
      }
    }
    if(r.cmd==='GET_CONFIG'){
      console.log('📋 Device config:',r);
      if(r.weight){
        const el=document.getElementById('u-weight');
        if(el&&!el.value){el.value=r.weight;updateCalcFields();}
      }
      // R-XL-03: Guardar version para inferencia de board
      if(r.version)G._lastFwVersion=r.version;
      // FIX-BLE-01: Diferir DOM-heavy applyHardwareProfile fuera del callback BLE
      // para evitar backpressure GATT → WDT timeout en ESP32
      if(r.board) requestAnimationFrame(()=>applyHardwareProfile(r.board));
      else if(r.version) requestAnimationFrame(()=>applyHardwareProfile(null));
      vtUpdateFromConfig(r);
    }
    if(r.cmd==='GET_VERSION'){
      console.log('📦 Firmware:',r.version,r.build);
      if(r.version)G._lastFwVersion=r.version;
      toast('Firmware: '+r.version,'info');
    }
    if(r.cmd==='GET_SENSORS') console.log('🔬 Sensors:',r);
    if(r.cmd==='GET_AMBIENT') console.log('🌡️ Ambient:',r);
    if(r.cmd==='GET_SCREEN'||r.cmd==='SCREEN'||r.cmd==='NEXT'||r.cmd==='PREV'){
      if(typeof r.screen==='number'){
        updateDiagScreenIndicator(r.screen);
        logDiagResponse(r.cmd,'Pantalla activa: '+r.screen);
      } else {
        logDiagResponse(r.cmd,raw);
      }
    }
    if(r.cmd==='GET_BOOT_STATE'||r.cmd==='BOOT_CONTINUE'){
      if(r.stage){
        updateDiagBootStage(r.stage,!!r.ready);
        logDiagResponse(r.cmd,'Stage: '+r.stage+(r.ready?' (READY)':''));
      } else {
        logDiagResponse(r.cmd,raw);
      }
    }
    if(r.cmd==='LANG') console.log('🌐 Language set:',r.lang);
    if(r.cmd==='CAL_O2') toast('O₂ recalibrated: '+r.baseline+'%','success');
    if(r.cmd==='CAL_FLOW'&&r.msg) toast(r.msg,'info');
    if(r.cmd==='RESTART'){
      toast('Device restarting...','info');
      if(!G.serialConnected)setConnected(false,t('status_disconnected'));
    }
    if(r.cmd==='FACTORY_RESET'&&r.msg) toast(r.msg,'success');
    if(r.status==='ERROR') console.warn('❌ BLE error:',r);
  }catch(e){
    if(raw.startsWith('WEIGHT:')){
      const w=parseFloat(raw.substring(7));
      if(w>=20&&w<=200){
        const el=document.getElementById('u-weight');
        if(el&&(!el.value||el.value==='0')){el.value=w;updateCalcFields();}
      }
    }
  }
}

function handleBLECommandResponse(event){
  const raw=new TextDecoder().decode(event.target.value);
  handleRemoteCommandRaw(raw);
}

