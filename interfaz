function applyHardwareProfile(boardName){
  let p=HW_PROFILES[boardName];
  let inferred=false;
  if(!p){
    // R-XL-03: Inferir board desde version string cuando board falta
    if(G._lastFwVersion){
      const v=G._lastFwVersion.toLowerCase();
      if(v.includes('c6'))p=HW_PROFILES['Waveshare ESP32-C6-LCD-1.47'];
      else if(v.includes('c3'))p=HW_PROFILES['ESP32-C3 LCD'];
      else if(v.includes('ttgo')||v.includes('t-display'))p=HW_PROFILES['TTGO T-Display'];
      if(p)inferred=true;
    }
    if(!p){
      p=HW_PROFILES['_default'];
      // R-XL-03: Alertar al usuario que se usa perfil por defecto
      console.warn('[HW] Board "'+boardName+'" no encontrado en HW_PROFILES → usando _default (FR÷'+p.FR_DIVISOR+')');
      toast('⚠️ Hardware no identificado — usando perfil por defecto (FR÷'+p.FR_DIVISOR+')','warning');
    }
  }
  G.correctionLayer.FR_DIVISOR=p.FR_DIVISOR;
  G.correctionLayer.VE_FALLBACK=p.VE_FALLBACK;
  G.detectedHW=p.label+(inferred?' (inferido)':'');
  // Sync UI checkboxes
  const chkFR=document.getElementById('corr-fr');
  if(chkFR){chkFR.checked=p.FR_DIVISOR>1.0;chkFR.disabled=!p.frEnabled;}
  // Show HW badge in connection strip
  const badge=document.getElementById('hw-profile-badge');
  if(badge){
    badge.textContent=p.label+(inferred?' (inferido)':'')+' · FR÷'+p.FR_DIVISOR+' · VE×'+p.VE_FALLBACK;
    badge.style.display='inline-block';
  }
  console.log('[HW] Profile applied:',p.label,'FR÷'+p.FR_DIVISOR,'VE×'+p.VE_FALLBACK,inferred?'(inferred from version)':'');
  // FIX-BLE-02: Diferir toast fuera del microtask BLE (evita DOM reflow en callback)
  setTimeout(()=>toast('Hardware: '+p.label+(inferred?' (inferido)':''),'info'),0);
}

