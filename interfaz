}

function deleteSession(sessionId){
  const sessions=getSavedSessions().filter(s=>s.id!==sessionId);
  try{localStorage.setItem(SESSION_STORAGE_KEY,JSON.stringify(sessions));}catch(e){console.warn('Delete session error:',e.message);}
  loadSessionHistory();
}

function loadSessionHistory(){
  const container=document.getElementById('session-history-list');
