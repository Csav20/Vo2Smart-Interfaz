function lerp(a,b,t){return a+t*(b-a);}
function clamp(v,min,max){return Math.min(Math.max(v,min),max);}
function computeCaloricEquivalent(rer){
  return isFinite(rer)&&rer>0?(3.941+(1.106*rer)):RER_TABLE[1.00].k;
}
function waterVaporPressureMmHg(tempC,humidityPct){
  const rh=clamp(safeN(humidityPct,50),0,100)/100;
  const esKPa=0.61078*Math.exp((17.2694*tempC)/(tempC+237.29));
  return(esKPa*7.50062)*rh;
}
function computeAmbientFactors(tempC,presPa,humidityPct){
  const pressureMmHg=presPa>0?(presPa*0.00750062):760;
  const ph2o=waterVaporPressureMmHg(tempC,humidityPct);
  const dryPressure=Math.max(1,pressureMmHg-ph2o);
  const stpd=pressureMmHg>0?(273.15/(273.15+tempC))*(dryPressure/760):1;
  const btps=pressureMmHg>47?((273.15+37)/(273.15+tempC))*(dryPressure/Math.max(1,pressureMmHg-47)):1;
  return{stpd,btps,pressureMmHg,ph2o,dryPressure};
}
function getRERData(rer){
  const keys=Object.keys(RER_TABLE).map(Number).sort((a,b)=>a-b);
  const minKey=keys[0],maxKey=keys[keys.length-1];
  const rc=clamp(isFinite(rer)?rer:minKey,minKey,maxKey);
  let lo=keys[0],hi=keys[keys.length-1];
  for(let i=0;i<keys.length-1;i++){if(rc>=keys[i]&&rc<=keys[i+1]){lo=keys[i];hi=keys[i+1];break;}}
  const t=(rc-lo)/(hi-lo)||0;
  const ld=RER_TABLE[lo],hd=RER_TABLE[hi];
  const kTable=lerp(ld.k,hd.k,t);
  const substrateValid=isFinite(rer)&&rer>=minKey&&rer<=maxKey;
  return{
    k:substrateValid?kTable:computeCaloricEquivalent(rer),
    kTable,
    pf:lerp(ld.pf,hd.pf,t),
    pc:lerp(ld.pc,hd.pc,t),
    substrateValid,
    substrateClamped:!substrateValid,
    rerForTable:rc,
    tableMin:minKey,
    tableMax:maxKey,
    kSource:substrateValid?'table':'weir_linear'
  };
}

// ── SSOT: computeRER() — Fuente única de verdad para RER ──
//
// Corrección de prioridad de método (2026-04-22 · hallazgo RER-PRIORITY-01):
// El diseño original usaba fracciones gaseosas como PRIMARIO porque se asumía que
// "ΔCO₂/ΔO₂ es independiente de VE". Ese argumento es incorrecto: la fórmula de
// fracciones NO aplica la transformación Haldane (N₂-balance) que el firmware SÍ aplica
// en vo2maxCalc() → VE_STPD × (haldane×FiO₂ − FeO₂). Al reordenar:
//   - rer_flow = vco2/vo2 = firmware respq = Haldane-corregido → MÁS preciso
//   - rer_gas  = ΔCO₂/ΔO₂ = sin Haldane → MENOS preciso (válido solo como cross-check)
// Las fracciones gaseosas pasan a rol de cross-check y penalización de confianza,
// no de fuente primaria. Cuando el firmware no envía vco2/vo2 válidos, rer_gas actúa
// como fallback único.
// Por qué no se detectó antes: el comentario original ("independiente de Haldane") era
// técnicamente incorrecto. La corrección de Haldane en el firmware nunca se cruzó con el
// código de computeRER() en una auditoría transversal FW↔HTML.
function computeRER(vo2,vco2,feo2,feco2,ve){
  const FiO2_REF=20.93, FiCO2_REF=0.04;
  // rer_flow: ratio directo de flujos STPD del firmware (Haldane incluido)
  const rer_flow=vco2>0&&vo2>0?vco2/vo2:0;
  let rer_raw=rer_flow||0.85;
  let vco2_corrected=vco2;
  let method='none';

  // ── Fracciones gaseosas: cross-check de confianza (no fuente primaria) ──
  // rer_gas = ΔCO₂/ΔO₂ — útil para detectar divergencia con flujos y penalizar score.
  // Solo toma el rol de PRIMARIO cuando vco2/vo2 del firmware no están disponibles.
  const hasGas=feo2>10&&feo2<FiO2_REF&&feco2>FiCO2_REF&&feco2<10;
  const deltaO2=hasGas?(FiO2_REF-feo2):0;
  const deltaCO2=hasGas?(feco2-FiCO2_REF):0;
  let rer_gas=0;
  if(hasGas&&deltaO2>0.1) rer_gas=deltaCO2/deltaO2;

  if(rer_flow>0){
    // PRIMARIO: flujo de firmware (Haldane-corregido, STPD)
    rer_raw=rer_flow;
    method='flow_primary';
    if(rer_gas>=0.50&&rer_gas<=1.40&&Math.abs(rer_gas-rer_flow)>0.10){
      // Cross-check: divergencia >10% entre flujos y fracciones → penalizar confianza downstream
      // No overrides el valor; se registra en method para que computeRERConfidence lo penalice.
      method='flow_primary_gas_diverge';
      if(!G._logThrottles._rerDelta||Date.now()-G._logThrottles._rerDelta>10000){
        console.warn('⚠️ RER divergencia flow vs gas:',rer_flow.toFixed(3),'vs',rer_gas.toFixed(3),
          '→ usando flow (Haldane). Verificar sensor CO₂.');
        G._logThrottles._rerDelta=Date.now();
      }
    }
  } else if(rer_gas>=0.50&&rer_gas<=1.40){
    // FALLBACK: fracciones gaseosas solo cuando firmware no envió vco2/vo2 válidos
    rer_raw=rer_gas;
    // Sintetizar VCO₂ a partir del RER gaseoso (sin Haldane — aproximación)
    vco2_corrected=vo2>0?vo2*rer_gas:vco2;
    method='gas_fallback';
    if(!G._logThrottles._rerOOR||Date.now()-G._logThrottles._rerOOR>10000){
      console.log('ℹ️ RER: sin flujos de firmware, usando fracciones gaseosas como fallback.');
      G._logThrottles._rerOOR=Date.now();
    }
  } else {
    // Sin datos válidos de flujos ni de fracciones
    rer_raw=0.85; // RER metabólico mixto en reposo (Beaver et al. 1973)
    method='default';
  }

  // ── Validación fisiológica (no clamp en cálculo) ──
  let rer_flag=false;
  if(!isFinite(rer_raw)||rer_raw<0.50||rer_raw>1.80){
    rer_flag=true;
    if(!G._logThrottles._rerClamp||Date.now()-G._logThrottles._rerClamp>10000){
      console.warn('⚠️ RER fuera de rango fisiológico:',isFinite(rer_raw)?rer_raw.toFixed(3):'NaN',
        {vo2,vco2,method});
      G._logThrottles._rerClamp=Date.now();
    }
  }

  // EMA suavizado (reemplaza clamp duro — mantiene continuidad sin ocultar errores)
  const alpha_rer=0.25;
  if(!isFinite(G._lastRER))G._lastRER=rer_raw||0.85;
  let rer_smoothed=isFinite(rer_raw)?alpha_rer*rer_raw+(1-alpha_rer)*G._lastRER:G._lastRER;
  G._lastRER=rer_smoothed;

  // rer interno = suavizado (sin clamp), rer_display = con clamp UI suave para visualización
  const rer=rer_smoothed;
  const rer_display=Math.min(Math.max(rer_smoothed,0.60),1.50);

  // Confianza (penaliza flag y divergencia gas vs flow)
  const confidence=computeRERConfidence(vo2,vco2_corrected,rer_raw,rer_flow,rer_gas,feo2,feco2,ve,method);

  // correctionApplied: true cuando VCO₂ fue sintetizado desde rer_gas (fallback únicamente)
  return{rer,rer_raw,rer_flow,rer_gas,rer_display,rer_flag,vco2_corrected,confidence,
    debug:{correctionApplied:method==='gas_fallback',method}};
}

// ── SSOT: computeRERConfidence() — Score de calidad del dato RER ──
// Scoring actualizado para nueva jerarquía de métodos (R-RER-PRIORITY-01, 2026-04-22):
//   flow_primary             = flujos firmware Haldane, sin divergencia gas → máxima confianza
//   flow_primary_gas_diverge = flujos Haldane pero gas difiere >10% → penalización leve
//   gas_fallback             = fracciones gaseosas sin flujos → confianza media
//   default                  = sin datos reales → baja confianza
function computeRERConfidence(vo2,vco2,rer_raw,rer_flow,rer_gas,feo2,feco2,ve,method){
  let score=100;
  if(method==='flow_primary')score=100;           // flujos Haldane + gas coherente
  else if(method==='flow_primary_gas_diverge')score=80; // flujos OK, gas difiere >10%
  else if(method==='gas_fallback')score=70;       // solo fracciones, sin flujos firmware
  else if(method==='default')score=50;            // sin datos reales

  // Penalizaciones adicionales
  if(!vo2||vo2<=0||!vco2||vco2<=0)score-=25;
  if(rer_raw<0.60||rer_raw>1.35)score-=15;
  // Divergencia gas vs flow cuando ambos disponibles (ya penalizado por method, refuerzo leve)
  if(rer_gas>0&&rer_flow>0&&Math.abs(rer_gas-rer_flow)>0.20)score-=10;
  // VO₂ muy bajo (señal pobre)
  if(vo2>0&&vo2<2)score-=10;
  // VE muy baja (posible fuga)
  if(ve!=null&&ve>0&&ve<3)score-=10;
  return Math.max(0,Math.min(100,score));
}

// ── SSOT: computeVentEquiv — fuente única para VE/VO₂ y VE/VCO₂ ──
function computeVentEquiv(ve,vo2ml,vco2ml,corrected){
  // ve: L/min, vo2ml/vco2ml: mL/min, corrected: true si usar fórmula corregida
  if(corrected){
    return{
      veVO2: vo2ml>0?(ve/(vo2ml/1000)):0,
      veVCO2:vco2ml>0?(ve/(vco2ml/1000)):0
    };
  }
  // Fórmula original: vo2 en mL/kg/min, ve en L/min
  const vo2Lmin=vo2ml/1000;
  const vco2Lmin=vco2ml/1000;
  return{
    veVO2: vo2Lmin>0?(ve/vo2Lmin):0,
    veVCO2:vco2Lmin>0?(ve/vco2Lmin):0
  };
}

function calcHybrid(vo2ml,vco2ml,rerOverride){
  if(!vo2ml||vo2ml<=0)return null;
  const v2=vo2ml/1000,vc2=vco2ml/1000;
  if(rerOverride===undefined||rerOverride===null){
    console.warn('⚠️ calcHybrid: RER no recibido — violación SSOT. Retornando null.');
    return null;
  }
  const rer=rerOverride;
  const wd=getRERData(rer);
  if(wd.substrateClamped&&rer>wd.tableMax){
    if(!G._logThrottles._rerTableRange||Date.now()-G._logThrottles._rerTableRange>10000){
      console.warn('⚠️ RER fuera de rango de tabla de sustratos:',rer.toFixed(3),
        '→ usando equivalente energético dinámico (Weir) sin extrapolar % de sustratos');
      G._logThrottles._rerTableRange=Date.now();
    }
  }
  const ee1=(3.941*v2)+(1.106*vc2);
  const ee2=v2*wd.k;
  const vo2e=vc2/Math.max(rer,0.01);
  const ee3=(3.941*vo2e)+(1.106*vc2);
  const qv=vo2ml>=200&&vo2ml<=5000?100:70;
  const qc=vco2ml>=150&&vco2ml<=4500?100:70;
  const qr=rer>=0.70&&rer<=1.0?100:rer>1.0&&rer<=1.15?60:20;
  const conf=qv*0.4+qc*0.3+qr*0.3;
  const rerWarning=rer>1.10;
  let w1,w2,w3;
  if(conf>=90){w1=0.4;w2=0.4;w3=0.2;}
  else if(conf>=70){w1=0.35;w2=0.45;w3=0.2;}
  else{w1=0.25;w2=0.6;w3=0.15;}
  const s=w1+w2+w3;w1/=s;w2/=s;w3/=s;
  const eeH=w1*ee1+w2*ee2+w3*ee3;
  const fat=Math.max(0,1.67*v2-1.67*vc2);
  const cho=Math.max(0,4.55*vc2-3.21*v2);
  const tot=fat+cho;
  return{rer,ee1,ee2,ee3,eeH,conf,w1,w2,w3,rerWarning,
    kSource:wd.kSource,substrateTableValid:wd.substrateValid,
    fat_g:fat,cho_g:cho,fat_kcal:fat*9,cho_kcal:cho*4,
    fat_pct:tot>0?fat/tot*100:0,cho_pct:tot>0?cho/tot*100:0,
    rmr:eeH*1440};
}

// Decode artifact bitfield to human-readable flag names
function decodeArtFlags(flags){
  const names=['VO2neg','VO2supra','VO2jump','RERhi','RERneg','FRhi','FRlo','CO2stale','O2drift','Pneg','dO2hi','VEext','NaN','CO2base'];
  if(!flags)return '';
  return names.filter((_,i)=>flags&(1<<i)).join(', ');
}

/* ── STABILITY INDICATOR SYSTEM ── */
let _stabFirstTs=null;
let _stabPlateauStart=null;

function _stabMean(arr){if(!arr.length)return 0;return arr.reduce((a,b)=>a+b,0)/arr.length;}
function _stabStd(arr){const m=_stabMean(arr);return Math.sqrt(arr.reduce((s,v)=>s+(v-m)*(v-m),0)/arr.length);}
function _stabCV(arr){const m=_stabMean(arr);return m>0?(_stabStd(arr)/m)*100:999;}
function _stabSlope(arr){
  const n=arr.length;if(n<3)return 0;
  const xm=(n-1)/2,ym=_stabMean(arr);
  let num=0,den=0;
  for(let i=0;i<n;i++){num+=(i-xm)*(arr[i]-ym);den+=(i-xm)*(i-xm);}
  return den>0?num/den:0;
}

function computeSignalStability(buf,windowSec){
  const cutoff=Date.now()-(windowSec*1000);
  const w=buf.filter(r=>r._ts>=cutoff);
  if(w.length<8)return null;
  const vo2s=w.map(r=>r.vo2||0).filter(v=>v>0);
  const rers=w.map(r=>r.rer||r.rq||0).filter(v=>v>0);
  if(vo2s.length<5)return null;
  return{vo2_cv:_stabCV(vo2s),rer_cv:rers.length>=5?_stabCV(rers):999,vo2_slope:_stabSlope(vo2s),n:w.length};
}

function detectRestState(buf){
  const last30=buf.filter(r=>r._ts>=Date.now()-30000);
  if(last30.length<10)return{isRest:false,confidence:0};
  const avgVO2=_stabMean(last30.map(r=>r.vo2||0));
  const avgVE=_stabMean(last30.map(r=>r.ve||0));
  const avgFR=_stabMean(last30.map(r=>r.freq||r.rr||0));
  const avgHR=_stabMean(last30.map(r=>r.hr||r.heartRate||0));
  let score=0;
  if(avgVO2<7)score+=30;
  if(avgVE<15)score+=25;
  if(avgFR>0&&avgFR<22)score+=20;
  if(avgHR>0&&avgHR<100)score+=25; else if(avgHR===0)score+=15;
  return{isRest:score>=70,confidence:score};
}

function classifyStabilityState(elapsed,stab,rest){
  if(!stab)return{state:'NO_SIGNAL',color:'#6b7280',icon:'⚫',msg:'Sin señal'};
  const cv=stab.vo2_cv,sl=Math.abs(stab.vo2_slope);
  if(elapsed<180)return{state:'WARMING',color:'#f87171',icon:'🔴',msg:'Calentando... '+(180-elapsed)+'s'};
  if(elapsed<300||cv>15)return{state:'STABILIZING',color:'#fbbf24',icon:'🟡',msg:'Estabilizando (CV:'+cv.toFixed(1)+'%)'};
  if(cv<=8&&sl<0.03)return{state:'PLATEAU',color:'#10b981',icon:'✅',msg:'Plateau (CV:'+cv.toFixed(1)+'%)'};
  if(cv<=15&&sl<0.1)return{state:'STABLE',color:'#34d399',icon:'🟢',msg:'Estable (CV:'+cv.toFixed(1)+'%)'};
  return{state:'STABILIZING',color:'#fbbf24',icon:'🟡',msg:'CV alto: '+cv.toFixed(1)+'%'};
}

function updateStabilityIndicator(){
  if(!G.rawBuffer.length)return;
  if(!_stabFirstTs)_stabFirstTs=Date.now();
  const elapsed=Math.floor((Date.now()-_stabFirstTs)/1000);
  const stab=computeSignalStability(G.rawBuffer,30);
  const rest=detectRestState(G.rawBuffer);
  const st=classifyStabilityState(elapsed,stab,rest);

  // Topbar pill
  const pill=document.getElementById('stability-pill');
  if(pill)pill.style.display='flex';
  const sDot=document.getElementById('stabilityDot');
  if(sDot){sDot.style.background=st.color;if(st.state==='STABLE'||st.state==='PLATEAU')sDot.classList.add('on');else sDot.classList.remove('on');}
  setText('stabilityStatus',st.msg.length>22?st.msg.substring(0,22)+'…':st.msg);

  // Strip panel
  const strip=document.getElementById('stability-strip');
  if(strip)strip.style.display='flex';

  // Ring progress (0-300s = 0-100%)
  const pct=Math.min(100,(elapsed/300)*100);
  const ringPath=document.getElementById('stab-ring-path');
  if(ringPath){ringPath.setAttribute('stroke-dasharray',pct.toFixed(1)+', 100');ringPath.setAttribute('stroke',st.color);}
  const min=Math.floor(elapsed/60),sec=elapsed%60;
  setText('stab-ring-text',min+':'+String(sec).padStart(2,'0'));

  // CV metrics
  if(stab){
    const cvEl=document.getElementById('stab-cv-vo2');
    if(cvEl){cvEl.textContent=stab.vo2_cv.toFixed(1)+'%';cvEl.style.color=stab.vo2_cv<=8?'#34d399':stab.vo2_cv<=15?'#fbbf24':'#f87171';}
    const rerEl=document.getElementById('stab-cv-rer');
    if(rerEl){rerEl.textContent=stab.rer_cv<900?stab.rer_cv.toFixed(1)+'%':'--';rerEl.style.color=stab.rer_cv<=10?'#34d399':stab.rer_cv<=20?'#fbbf24':'#f87171';}
    setText('stab-slope',(stab.vo2_slope>=0?'↗':'↘')+Math.abs(stab.vo2_slope).toFixed(2));
  }

  // State icon + text
  setText('stab-icon',st.icon);
  let msg=st.msg;
  if(G.testPhase==='rest'&&(st.state==='PLATEAU'||st.state==='STABLE'))msg+=' — Listo';
  setText('stab-text',msg);

  // Rest badge
  const rb=document.getElementById('stab-rest-badge');
  if(rb)rb.style.display=rest.isRest?'block':'none';
}

function resetStabilityIndicator(){
  _stabFirstTs=null;_stabPlateauStart=null;
  const pill=document.getElementById('stability-pill');if(pill)pill.style.display='none';
  const strip=document.getElementById('stability-strip');if(strip)strip.style.display='none';
}

function processData(d){
  // Normalize BLE field name: firmware ≤v4.0.3 solo enviaba "rq"; v4.0.4+ envía ambos.
  // Mantener aliasing como red de seguridad para firmware legacy.
  if(d.rq!==undefined&&d.rer===undefined)d.rer=d.rq;
  // Inject last known BLE HR if this packet has no HR (avoids flicker when HR sensor + VO2 sensor connected)
  if((!d.hr||safeN(d.hr)<=0)&&(!d.heartRate||safeN(d.heartRate)<=0)&&G.lastBleHR>0&&(Date.now()-G.lastBleHRts)<10000){
    d.hr=G.lastBleHR;
  }
  const isDemo=d.demo===true||d.mode==='sim';
  const ambientTemp=safeN(d.temp,20);
  const ambientPres=safeN(d.pres||d.pressure,101300);
  const ambientHumidity=safeN(d.humid!=null?d.humid:d.humidity,50);
  const ambient=computeAmbientFactors(ambientTemp,ambientPres,ambientHumidity);
  const scaleField=(obj,key,factor)=>{
    if(obj[key]!==undefined&&obj[key]!==null&&obj[key]!=='')obj[key]=safeN(obj[key])*factor;
  };

  // R-STPD-01 (2026-04-22): Firmware v4.0.4+ aplica rhoBTPS/rhoSTPD internamente en
  // vco2Total y VE_STPD → VO₂ y VCO₂ llegan ya en STPD. Señales de detección:
  //   a) d.stpdApplied===1  (campo explícito, FW-STPD-01)
  //   b) d.rfm_mode presente (cualquier valor → firmware que hace su propia corrección)
  // Sin esta detección: APPLY_AMBIENT multiplicaba otra vez por ~0.93 → subestimación ~7%.
  // Por qué no se detectó antes: cada capa tenía comentarios correctos aislados;
  // el contrato FW↔HTML nunca se auditó transversalmente hasta 2026-04-22.
  const fwAppliedStpd=d.stpdApplied===true||d.stpdApplied===1||d.rfm_mode!==undefined;
  const stpdAlreadyApplied=fwAppliedStpd;
  // VE/VT: firmware NO aplica BTPS al VE (envía en ATPS); CL.VE_RECALC lo corrige downstream.
  const btpsAlreadyApplied=d.btpsApplied===true||d.btpsApplied===1;
  if(G.correctionLayer.APPLY_AMBIENT&&!isDemo){
    if(!stpdAlreadyApplied){
      ['vo2','vco2','VO2','VCO2'].forEach(k=>scaleField(d,k,ambient.stpd));
      d.stpdApplied=true;
    }
    if(!btpsAlreadyApplied){
      ['ve','vol','vt','VE','VT'].forEach(k=>scaleField(d,k,ambient.btps));
      d.btpsApplied=true;
    }
  }
  d.humidity=ambientHumidity;
  d.ambientStpd=ambient.stpd;
  d.ambientBtps=ambient.btps;
  // Add to raw buffer with timestamp for smoothing
  d._ts=Date.now();
  G.rawBuffer.push(d);
  // Keep buffer limited to 60s
  const cutoff60=Date.now()-60000;
  G.rawBuffer=G.rawBuffer.filter(r=>r._ts>=cutoff60);

  // If test is paused, don't process
  if(G.testState==='paused')return;

  // ── Epoch (block) averaging: skip display until epoch completes ──
  if(G.smoothEpoch&&G.smoothWindowSec>0){
    G.epochBuffer.push(d);
    const elapsed=(Date.now()-G.lastEpochUpdate)/1000;
    if(elapsed<G.smoothWindowSec)return; // wait for epoch to complete
    // Epoch complete → compute block average and continue to display
    G.lastEpochUpdate=Date.now();
  }

  // Apply smoothing: rolling for rolling10/bxb, epoch for avgN
  const sd=G.smoothEpoch?getEpochData(d):getSmoothedData(d);
  // Clear epoch buffer after use
  if(G.smoothEpoch)G.epochBuffer=[];

  const vo2=safeN(sd.vo2);
  const _vco2raw=(sd.vco2!=null&&sd.vco2!=='')?sd.vco2:(sd.vco2max!=null?sd.vco2max:null);
  // R-VCO2-SYNTH-01 (2026-04-22): Cuando el firmware no envía VCO₂ válido, sintetizar
  // usando sd.rq (= respq del firmware, Haldane-corregido) como referencia de RER,
  // nunca sd.rer solo (que es un alias frágil de sd.rq). Prioridad: sd.rq > sd.rer > 0.85.
  // Valor 0.85 = RER mixto en reposo (Beaver et al. 1973) solo cuando no hay dato alguno.
  // El "SSOT fix hallazgo #1" downstream (computeRER → vco2_corrected) sigue activo como
  // segunda capa de corrección cuando gas fractions producen un rer diferente al de flujos.
  const _rerFwRef=safeN(sd.rq||sd.rer,0);
  let vco2=(_vco2raw!=null&&isFinite(parseFloat(_vco2raw))&&parseFloat(_vco2raw)>0)
    ?parseFloat(_vco2raw)
    :(vo2>0&&_rerFwRef>0?vo2*_rerFwRef:0);
  let hr=safeN(sd.hr||sd.heartRate);
  // Fallback: use last BLE HR if current data lacks HR and BLE HR is recent (<10s)
  if(hr<=0&&G.lastBleHR>0&&(Date.now()-G.lastBleHRts)<10000)hr=G.lastBleHR;
  const ve=safeN(sd.ve);
  const rr_raw=(sd.freq!=null&&sd.freq!==''&&isFinite(parseFloat(sd.freq)))?parseFloat(sd.freq):safeN(sd.rr||sd.rr_val);
  const rr=Math.min(Math.max(rr_raw,0),80); // physiological clamp: 0-80 resp/min
  if(rr_raw<0||rr_raw>80){
    if(!G._logThrottles._rrClamp||Date.now()-G._logThrottles._rrClamp>10000){
      console.warn('⚠️ RR clamped:',rr_raw,'→',rr);
      G._logThrottles._rrClamp=Date.now();
    }
  }
  const vol=safeN(sd.vol);
  const o2=safeN(sd.o2||sd.feo2);
  const co2=safeN(sd.co2||sd.feco2);
  const temp=safeN(sd.temp,20);
  const pres=safeN(sd.pres||sd.pressure,101300);
  const humidity=safeN(sd.humid!=null?sd.humid:sd.humidity,50);
  const rho=safeN(sd.rho,1.2);
  const bat=safeN(sd.battery,100);
  const batV=safeN(sd.batteryV,4.2);
  const calTotal=safeN(sd.calTotal);

  // ── SSOT: Usar computeRER() como fuente única de verdad ──
  const rerData=computeRER(vo2,vco2,o2,co2,ve);
  let rer_raw=rerData.rer_raw;
  const rer=rerData.rer;
  const rerDisplay=rerData.rer_display;
  const rerFlag=rerData.rer_flag;
  const rerConf=rerData.confidence;
  const rerMethod=rerData.debug.method;
  const rerFlow=rerData.rer_flow;
  const rerGas=rerData.rer_gas;
  // Actualizar VCO₂ si fue corregido por fracciones gaseosas
  if(rerData.debug.correctionApplied){vco2=rerData.vco2_corrected;}
  // SSOT fix hallazgo #1: si VCO₂ fue sintetizado con sd.rer crudo, recalcular con rer corregido
  else if(_vco2raw==null||!isFinite(parseFloat(_vco2raw))||parseFloat(_vco2raw)<=0){
    if(vo2>0)vco2=vo2*rer;
  }

  // ── Capa de corrección Venturi bidireccional ──
  // Solo aplicar a datos reales del dispositivo, NO a simulación/demo
  const CL=G.correctionLayer;
  const ve_raw=ve, rr_raw_orig=rr;
  let rr_c=rr, ve_c=ve;
  if(CL.enabled&&!isDemo){
    // C1: FR ÷ 2 (doble conteo por ΔP positivo en ambas fases respiratorias)
    rr_c=Math.round(rr/CL.FR_DIVISOR);
    // C2: VE propagada via FR corregida
    // Derivar VT independiente de VE y RR originales (no usar vol directo — puede estar desacoplado)
    const vt_raw=rr>0?ve/rr:vol; // VT = VE/RR (coherente), fallback a vol si RR=0
    if(CL.VE_RECALC&&vt_raw>0&&rr_c>0){
      ve_c=vt_raw*rr_c; // VE_nueva = VT_original × RR_corregida (sin circularidad)
    } else {
      ve_c=ve/CL.VE_FALLBACK;
    }
  }

  // ── Check de coherencia fisiológica VE–VT–RR ──
  if(ve_c>0&&rr_c>0){
    const vt_check=ve_c/rr_c;
    const inconsistency=Math.abs((vt_check*rr_c)-ve_c)/(ve_c||1);
    if(inconsistency>0.01){
      if(!G._logThrottles._veCoherence||Date.now()-G._logThrottles._veCoherence>10000){
        console.warn('⚠️ Desacople VE-VT-RR:',{ve_c:ve_c.toFixed(2),vt:vt_check.toFixed(3),rr_c,product:(vt_check*rr_c).toFixed(2),delta:inconsistency.toFixed(4)});
        G._logThrottles._veCoherence=Date.now();
      }
    }
  }

  const _p=getCalorimetryPatient(getPatient());
  const weight=_p.weight||70;
  const hrMax=_p.hrMax||190;
  const hrRest=_p.hrRest||60;
  const hrr=hrMax>hrRest?Math.round((hr-hrRest)/(hrMax-hrRest)*100):0;

  const vo2ml=vo2*weight,vco2ml=vco2*weight;

  // C3-C4: VE/VO₂ y VE/VCO₂ — SSOT vía computeVentEquiv()
  const _useCorr=CL.enabled&&CL.FIX_VE_RATIOS&&!isDemo;
  const _veq=computeVentEquiv(ve_c,vo2ml,vco2ml,_useCorr);
  let veVO2=_veq.veVO2, veVCO2=_veq.veVCO2;
  const cal=calcHybrid(vo2ml,vco2ml,rer);

  // Elapsed
  let elapsed='--:--';
  if(G.sessionStart){const s=Math.floor((Date.now()-G.sessionStart)/1000);elapsed=`${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;}

  // Peaks
  if(vo2>G.vo2Peak)G.vo2Peak=vo2;
  if(hr>G.hrPeak)G.hrPeak=hr;
  if(ve_c>G.vePeak)G.vePeak=ve_c;
  if(rer>G.rerPeak)G.rerPeak=rer;

  // Calories accumulation
  if(cal)G.totalCalories+=(cal.eeH/60); // per second approx

  // O2 Pulse
  const o2pulse=hr>0&&vo2>0?(vo2ml/hr):0;

  // End-tidal pressures (estimated from FE fractions)
  const peto2=o2>0?((o2/100)*(pres*0.0075006-47)):0;
  const petco2=co2>0?((co2/100)*(pres*0.0075006-47)):0;

  // STPD / BTPS factors
  const {stpd,btps}=computeAmbientFactors(temp,pres,humidity);

  // VO2 predicted % — SSOT: leer de G.vo2pred (calculado en updateCalcFields), no del DOM
  const pred=safeN(G.vo2pred,0);
  const pctPred=pred>0&&vo2>0?vo2/pred*100:0;

  updateZone(vo2);
  updateRefPanel(vo2);

  // Update DOM - Dashboard
  setText('d-vo2',vo2.toFixed(1));
  setText('d-vco2',vco2.toFixed(1));
  setText('d-hr',hr.toFixed(0)||'--');
  setText('d-ee',cal?cal.eeH.toFixed(2):'--');
  setText('d-ve',ve_c.toFixed(1));
  setText('d-rer',rerDisplay.toFixed(3));
  setText('d-rer-sub','Conf: '+rerConf+'%'+(rerFlag?' ⚠':''));
  // Color the RER display based on flag + confidence + physiological range
  const rerEl=document.getElementById('d-rer');
  if(rerEl)rerEl.style.color=rerFlag?'#e04040':rerConf>=85&&rer>=0.67&&rer<=1.30?'':rerConf>=60?'#f0a030':'#e04040';
  setText('d-rr',rr_c.toFixed(0));
  setText('d-vevo2',veVO2.toFixed(1));
  setText('d-vevco2',veVCO2.toFixed(1));
  // Badge de corrección activa
  const corrBadge=document.getElementById('correction-active-badge');
  if(corrBadge)corrBadge.style.display=CL.enabled?'inline-block':'none';
  setText('d-vol',vol.toFixed(3));
  setText('d-feo2',o2.toFixed(2));
  setText('d-feco2',co2.toFixed(2));
  setText('d-peto2',peto2>0?peto2.toFixed(1):'--');
  setText('d-petco2',petco2>0?petco2.toFixed(1):'--');
  setText('d-temp',temp.toFixed(1));
  setText('d-bat',bat.toFixed(0));
  setText('d-cal-total',G.totalCalories.toFixed(1));
  setText('d-elapsed',elapsed);
  setText('d-vo2-peak',G.vo2Peak.toFixed(1));
  setText('d-vo2-pctpred',pctPred>0?pctPred.toFixed(0):'--');
  setText('d-hrr',isFinite(hrr)?hrr:'--');
  setText('d-o2pulse',o2pulse>0?o2pulse.toFixed(1):'--');
  if(cal){
    const caloCtx=getCaloMeasurementContext(cal);
    setText('d-rmr',caloCtx.rmrValid?caloCtx.rmrDaily.toFixed(0):'--');
  }

  // Ambient
  setText('amb-temp',temp.toFixed(1));
  setText('amb-humid',humidity.toFixed(0));
  setText('amb-pres',(pres/100).toFixed(1));
  setText('amb-rho',rho.toFixed(3));
  setText('amb-stpd',stpd.toFixed(4));
  setText('amb-btps',btps.toFixed(4));

  // Calibración panel
  setText('c-ve',ve_c.toFixed(1));
  setText('c-vt',vol.toFixed(2));
  setText('c-fr',rr_c.toFixed(0));
  updateCortexDiffs(ve_c,vol,rr_c);

  // Calorimetría
  if(cal){
    const calView=getCalorimetryPresentation(cal,{patient:_p,vo2Current:vo2,vco2Current:vco2});
    const caloCtx=calView.ctx;
    setText('ee-hybrid-big',calView.eeDisplay.toFixed(2));
    setText('cal-ee-caption',calView.eeCaption);
    setText('cal-rmr',caloCtx.rmrValid?caloCtx.rmrDaily.toFixed(0):'--');
    setText('cal-rq-big',cal.rer.toFixed(3));
    setText('cal-substrate',calView.rqLabel);
    setText('cal-confidence',cal.conf.toFixed(0));
    setText('cal-confidence-note',calView.confNote);
    setText('w-weir',(cal.w1*100).toFixed(0));
    setText('w-vo2',(cal.w2*100).toFixed(0));
    setText('w-rer',(cal.w3*100).toFixed(0));
    setText('ee-weir',cal.ee1.toFixed(2));
    setText('ee-vo2m',cal.ee2.toFixed(2));
    setText('ee-rerm',cal.ee3.toFixed(2));
    setText('cal-ee1-clinical',cal.ee1.toFixed(2)+' kcal/min');
    setText('cal-ee2-clinical',cal.ee2.toFixed(2)+' kcal/min');
    setText('cal-ee3-clinical',cal.ee3.toFixed(2)+' kcal/min');
    // VO₂/VCO₂: mostrar valor si está disponible, o contexto si no
    const vo2Display = calView.vo2L > 0 ? calView.vo2L.toFixed(3) + ' L/min' : 
                       (weight > 0 ? '(peso sí, sin sensor VO₂)' : '(sin peso ni datos)');
    const vco2Display = calView.vco2L > 0 ? calView.vco2L.toFixed(3) + ' L/min' : 
                        (weight > 0 ? '(peso sí, sin sensor VO₂)' : '(sin peso ni datos)');
    setText('cal-vo2-lmin', vo2Display);
    setText('cal-vco2-lmin', vco2Display);
    setText('cal-rer-clinical',cal.rer.toFixed(3));
    setText('cal-ee-minute',calView.eeDisplay.toFixed(2)+' kcal/min');
    setText('cal-rmrkg',caloCtx.rmrValid&&calView.hb>=0&&_p.weight>0?(caloCtx.rmrDaily/_p.weight).toFixed(1)+' kcal/d/kg':'--');
    setText('cal-rmrbsa',caloCtx.rmrValid&&calView.bsa>0?(caloCtx.rmrDaily/calView.bsa).toFixed(0)+' kcal/d/m²':'--');
    setText('cal-cho-day',caloCtx.rmrValid?calView.choDay.toFixed(0)+' g/d':'--');
    setText('cal-fat-day',caloCtx.rmrValid?calView.fatDay.toFixed(0)+' g/d':'--');
    setText('cal-ee-cho-day',caloCtx.rmrValid?calView.choKcalDay.toFixed(0)+' kcal/d':'--');
    setText('cal-ee-fat-day',caloCtx.rmrValid?calView.fatKcalDay.toFixed(0)+' kcal/d':'--');
    setText('cal-pro-day','N/D');
    // Sustratos
    setText('fat-gmin',cal.fat_g.toFixed(2));
    setText('fat-kcal',cal.fat_kcal.toFixed(2));
    setText('fat-pct',cal.fat_pct.toFixed(0)+'%');
    setText('cho-gmin',cal.cho_g.toFixed(2));
    setText('cho-kcal',cal.cho_kcal.toFixed(2));
    setText('cho-pct',cal.cho_pct.toFixed(0)+'%');
    setText('cal-fat-gmin',cal.fat_g.toFixed(2)+' g/min ('+calView.fatPct.toFixed(0)+'%)');
    setText('cal-cho-gmin',cal.cho_g.toFixed(2)+' g/min ('+calView.choPct.toFixed(0)+'%)');
    setText('cal-fat-legend','Grasas '+calView.fatPct.toFixed(0)+'%');
    setText('cal-cho-legend','CHO '+calView.choPct.toFixed(0)+'%');
    const fb=document.getElementById('fat-bar'),cb=document.getElementById('cho-bar');
    if(fb)fb.style.width=cal.fat_pct.toFixed(0)+'%';
    if(cb)cb.style.width=cal.cho_pct.toFixed(0)+'%';
    const calFatSeg=document.getElementById('cal-fat-seg');
    if(calFatSeg){
      calFatSeg.style.width=calView.fatPct.toFixed(0)+'%';
      calFatSeg.textContent=calView.fatPct>=18?'Grasas '+calView.fatPct.toFixed(0)+'%':'';
    }
    const calChoSeg=document.getElementById('cal-cho-seg');
    if(calChoSeg){
      calChoSeg.style.width=calView.choPct.toFixed(0)+'%';
      calChoSeg.textContent=calView.choPct>=18?'CHO '+calView.choPct.toFixed(0)+'%':'';
    }
    const calRmrBadge=document.getElementById('cal-rmr-badge');
    if(calRmrBadge){
      calRmrBadge.textContent=calView.rmrBadgeText;
      calRmrBadge.className='calo-proto-badge '+calView.rmrBadgeClass;
    }
    const calRqBadge=document.getElementById('cal-rq-badge');
    if(calRqBadge){
      calRqBadge.textContent=calView.rqLabel;
      calRqBadge.className='calo-proto-badge '+calView.rqClass;
    }

    // Mejora M: RMR medido vs Harris-Benedict predicho
    setText('rmr-hb',calView.hb>0?calView.hb.toFixed(0):'--');
    setText('rmr-measured',caloCtx.rmrValid?caloCtx.rmrDaily.toFixed(0):'--');
    setText('rmr-diff',calView.rmrDiffStr);
    const bar=document.getElementById('rmr-bar');
    if(bar){
      bar.style.width=caloCtx.rmrValid&&calView.hb>0
        ?Math.min(100,Math.max(5,caloCtx.rmrDaily/calView.hb*100)).toFixed(0)+'%'
        :'0%';
    }
    setText('rmr-interpretation',calView.rmrNote);
    const rmrCard=document.getElementById('rmr-comparison-card');
    if(rmrCard)rmrCard.style.display='block';
    G.harrisBenedict=calView.hb;

    const calNutrition=document.getElementById('cal-nutrition-section');
    if(calNutrition&&calView.nutritionVisible){
      calNutrition.style.display='block';
      setText('cal-nutri-profile',calView.profileLabel);
      setText('cal-rec-maint',calView.maintenance.toFixed(0));
      setText('cal-rec-loss',calView.loss.toFixed(0));
      setText('cal-rec-gain',calView.gain.toFixed(0));
      setText('cal-macro-prot',calView.protein.toFixed(0)+' g');
      setText('cal-macro-carbs',calView.carbs.toFixed(0)+' g');
      setText('cal-macro-fats',calView.fats.toFixed(0)+' g');
      setText('cal-nutri-followup',calView.followup);
    }else if(calNutrition){
      calNutrition.style.display='none';
    }

    setText('cal-fatmax',G.fatmaxDetected?G.fatmaxDetected.fat_g.toFixed(2)+' g/min @ '+G.fatmaxDetected.vo2pct.toFixed(0)+'% VO₂max':'-- g/min @ --% VO₂max');
    setText('cal-crossover',G.crossoverDetected?G.crossoverDetected.vo2pct.toFixed(0)+'% VO₂max':'--% VO₂max');

    // Mejora K: Detección Crossover Point + FatMax
    const vo2pctNow = G.vo2Peak > 0 ? (vo2 / G.vo2Peak * 100) : 0;
    // Crossover: cuando cho_pct supera fat_pct
    if (!G.crossoverDetected && G.prevFatPct != null && G.prevFatPct > G.prevChoPct && cal.cho_pct > cal.fat_pct && vo2pctNow > 20) {
      G.crossoverDetected = { vo2pct: vo2pctNow, time: Math.floor(getTestElapsed()/1000) };
      setText('crossover-vo2pct', vo2pctNow.toFixed(0));
      setText('cal-crossover',vo2pctNow.toFixed(0)+'% VO₂max');
      const cp = document.getElementById('crossover-panel');
      if (cp) cp.style.display = 'block';
    }
    G.prevFatPct = cal.fat_pct;
    G.prevChoPct = cal.cho_pct;
    // FatMax: máximo de fat_g observado
    if (!G.fatmaxDetected || cal.fat_g > G.fatmaxDetected.fat_g) {
      G.fatmaxDetected = { fat_g: cal.fat_g, vo2pct: vo2pctNow };
      setText('fatmax-value', cal.fat_g.toFixed(2));
      setText('fatmax-vo2pct', vo2pctNow.toFixed(0));
      setText('cal-fatmax',cal.fat_g.toFixed(2)+' g/min @ '+vo2pctNow.toFixed(0)+'% VO₂max');
      if (cal.fat_g > 0.05) {
        const fp = document.getElementById('fatmax-panel');
        if (fp) fp.style.display = 'block';
      }
    }
  }

  // HRV: use real data if available, otherwise show waiting state
  if(G.rrBuffer.length>=6){
    // Real HRV from BLE RR-intervals — display handled by computeHRV/updateHRVDisplay
  } else if(G.hrDevice){
    setText('hrv-big','...');
    setText('rmssd','Recolectando RR');
  } else {
    setText('hrv-big','--');
    setText('rmssd','Conectar HR');
  }

  // Cinética VO2 — computeKinetics actualiza G.kinetics (Whipp & Ward 1990)
  computeKinetics(vo2);
  const K = G.kinetics;
  const tauStr  = K.tau  != null && K.valid ? K.tau.toFixed(1)              : (vo2 > 5 ? '⌛' : '--');
  const mrtStr  = K.tau  != null && K.valid ? (K.tau * 1.3).toFixed(1)       : (vo2 > 5 ? '⌛' : '--');  // MRT ≈ τ × 1.3 (Bearden & Moffatt 2001)
  const ampStr  = K.amplitude != null && K.valid ? K.amplitude.toFixed(1)   : '--';
  setText('tau-val',  tauStr);
  setText('mrt-val',  mrtStr);
  // Umbrales: V-slope estimado + cinética cuando disponible
  const vt1 = K.valid && K.baseline > 0 ? K.baseline.toFixed(1) : (vo2 > 5 ? (vo2 * 0.75).toFixed(1) : 'Detectando…');
  const vt2 = vo2 > 5 ? (vo2 * 0.88).toFixed(1) : 'Detectando…';
  const rcp  = vo2 > 5 ? (vo2 * 0.92).toFixed(1) : 'Detectando…';
  setText('vt1-val', vt1);
  setText('vt2-val', vt2);
  setText('rcp-val', rcp);
  G.vt1Rep=vt1; G.vt2Rep=vt2; G.rcpRep=rcp;
  // Mejora D: Feedback dinámico de estado cinético (Grassi 2011, Jones & Poole 2005)
  {
    const fitnessEl = document.getElementById('fitness-val');
    let fitText, fitColor;
    if (K.tau != null && K.valid) {
      const t = K.tau;
      if (t < 20)      { fitText = '🏆 Élite (τ ' + t.toFixed(0) + 's)';    fitColor = '#22c55e'; }
      else if (t < 30) { fitText = '✅ Bueno (τ ' + t.toFixed(0) + 's)';     fitColor = '#60a5fa'; }
      else if (t < 45) { fitText = '⚠️ Moderado (τ ' + t.toFixed(0) + 's)';  fitColor = '#f97316'; }
      else              { fitText = '🔴 Bajo (τ ' + t.toFixed(0) + 's)';      fitColor = '#ef4444'; }
    } else if (K.transitionStart) {
      const pct = K.amplitude && K.peak > K.baseline ? ((vo2 - K.baseline) / K.amplitude * 100) : 0;
      fitText = 'Capturando… ' + Math.min(99, Math.max(0, pct)).toFixed(0) + '%';
      fitColor = '#60a5fa';
    } else if (K.baseline > 0 && vo2 > 5) {
      fitText = 'Baseline estable';
      fitColor = '#f97316';
    } else if (vo2 > 5) {
      fitText = 'Esperando…';
      fitColor = 'var(--muted)';
    } else if (!K.transitionStart && K.tau != null) {
      fitText = 'Listo para nueva captura';
      fitColor = 'var(--muted)';
    } else {
      fitText = '--';
      fitColor = 'var(--accent)';
    }
    setText('fitness-val', fitText);
    if (fitnessEl) fitnessEl.style.color = fitColor;
    // Mejora A: Actualizar barra visual de fitness basada en τ
    const tauBar = document.getElementById('tau-fitness-bar');
    if (tauBar) {
      if (K.tau != null && K.valid) {
        const pct = Math.max(5, Math.min(100, (1 - (K.tau - 10) / 110) * 100));
        tauBar.style.width = pct.toFixed(0) + '%';
      } else if (K.transitionStart) {
        tauBar.style.width = '30%';
      } else {
        tauBar.style.width = '0%';
      }
    }
  }
  // OUES estimation
  if(ve_c>0&&vo2>0){
    const oues=vo2ml/(Math.log10(ve_c));
    setText('oues-val',oues>0?oues.toFixed(0):'--');
  }

  // Update charts
  const ts=new Date().toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  // Store to full history (never trimmed) for full-test view
  G.fullHist.labels.push(ts);
  G.fullHist.vo2.push(vo2);G.fullHist.vco2.push(vco2);
  G.fullHist.hr.push(hr);G.fullHist.rer.push(rer);
  G.fullHist.ee.push(cal?cal.eeH:0);G.fullHist.ve.push(ve_c);
  G.fullHist.fat.push(cal?cal.fat_g:0);G.fullHist.cho.push(cal?cal.cho_g:0);
  G.fullHist.veVCO2.push(veVCO2);G.fullHist.veVO2.push(veVO2);
  G.fullHist.o2pulse.push(o2pulse);
  G.fullHist.peto2.push(peto2);G.fullHist.petco2.push(petco2);
  G.fullHist.ee1.push(cal?cal.ee1:0);G.fullHist.ee2.push(cal?cal.ee2:0);G.fullHist.ee3.push(cal?cal.ee3:0);
  const lastRR=G.rrBuffer.length>0?G.rrBuffer[G.rrBuffer.length-1]:(hr>0?60000/hr:0);
  G.fullHist.hrv.push(lastRR);
  pushChart(G.charts.main,[vo2,vco2,veVCO2,veVO2],ts);
  pushChart(G.charts.hr,[hr],ts);
  pushChart(G.charts.rer,[rer],ts);
  pushChart(G.charts.ee,cal?[cal.eeH]:[0],ts);
  // Kinetics chart: VO2 real + curva τ + baseline + target (Mejora B: 4 datasets)
  const tauFit = (K.tau != null && K.valid && K.transitionStart != null)
    ? (K.baseline + K.amplitude * (1 - Math.exp(-(Date.now() - K.transitionStart) / 1000 / K.tau)))
    : null;
  const baselineVal = K.baseline > 0 ? K.baseline : NaN;
  const targetVal = (K.peak > 0 && K.transitionStart) ? K.peak : NaN;
  pushChart(G.charts.kinetics, [vo2, tauFit !== null ? tauFit : NaN, baselineVal, targetVal], ts);
  if(cal)pushChart(G.charts.eeM,[cal.eeH,cal.ee1,cal.ee2,cal.ee3],ts);
  pushChart(G.charts.substrate,cal?[cal.fat_g,cal.cho_g]:[0,0],ts);
  pushChart(G.charts.hrv,[lastRR],ts);
  pushChart(G.charts.o2pulse,[o2pulse],ts);
  pushChart(G.charts.pet,[peto2,petco2],ts);
  // Scatter
  if(G.charts.fcvo2&&hr>0&&vo2>0){
    G.charts.fcvo2.data.datasets[0].data.push({x:vo2,y:hr});
    if(G.chartView==='live'&&G.charts.fcvo2.data.datasets[0].data.length>MAX_PTS)G.charts.fcvo2.data.datasets[0].data.shift();
    G.charts.fcvo2.update('none');
  }
  // Mini charts
  pushMini(G.charts.mc.vo2,vo2);
  pushMini(G.charts.mc.vco2,vco2);
  pushMini(G.charts.mc.hr,hr);
  if(cal)pushMini(G.charts.mc.ee,cal.eeH);

  // Artifact system: extract firmware artifact flags + raw values
  const artFlag=safeN(sd.artifact);
  const vo2r=sd.vo2r!=null?safeN(sd.vo2r):vo2;
  const rqr=sd.rqr!=null?safeN(sd.rqr):rer;
  const frr=sd.frr!=null?safeN(sd.frr):rr;
  const do2r=sd.do2r!=null?safeN(sd.do2r):0;
  G.currentData={vo2,vco2,rer,rer_raw,rerDisplay,rerFlag,rerConf,rerMethod,rerFlow,rerGas,ve:ve_c,rr:rr_c,vol,hr,o2,co2,bat,cal,temp,peto2,petco2,o2pulse,artFlag,vo2r,rqr,frr,do2r,ve_raw,rr_raw_orig};
  recordEntry(G.currentData);
  updateStabilityIndicator();
}

function pushChart(chart,values,ts){
  if(!chart)return;
  chart.data.labels.push(ts);
  values.forEach((v,i)=>{if(chart.data.datasets[i])chart.data.datasets[i].data.push(v);});
  if(G.chartView==='live'&&chart.data.labels.length>MAX_PTS){
    chart.data.labels.shift();
    chart.data.datasets.forEach(ds=>{if(ds.data.length>0)ds.data.shift();});
  }
  chart.update('none');
}

function pushMini(chart,value){
  if(!chart)return;
  chart.data.labels.push('');
  chart.data.datasets[0].data.push(value);
  if(chart.data.labels.length>20){chart.data.labels.shift();chart.data.datasets[0].data.shift();}
  chart.update('none');
}

